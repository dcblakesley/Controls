@typeparam T
@inherits EditControlBase<T>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequired Description=@Description Tooltip=@Tooltip IsLabelHidden=@ShouldHideLabel IsForLabelable=@ShowEditor />

        @if (ShowEditor)
        {
            @* @bind-value uses the default onchange event (NOT oninput): browsers report
               type=number as "" while the text is a partial number ("-", "3.", "1e"), so
               per-keystroke binding flashed "must be a number" mid-typing. Matches Microsoft's
               InputNumber. (Comment deliberately outside the tag — a Razor comment inside an
               attribute list compiles into a literal attribute name and breaks setAttribute.) *@
            <div class="edit-input-with-icon">
                <input type="number"
                       style="padding-right: 2rem"
                       disabled=@IsDisabled
                       id=@_id
                       data-test-id=@_id
                       step=@Step.ToString(CultureInfo.InvariantCulture)
                       @bind-value=@CurrentValueAsString
                       class=@($"edit-input edit-number-input {CssClass}")
                       aria-required=@_isRequired
                       aria-invalid=@(IsInvalid ? "true" : null)
                       aria-describedby=@_describedBy
                       aria-errormessage=@(IsInvalid ? _errorMsgId : null) />
                <InvalidIcon IsInvalid=@IsInvalid />
            </div>
        }
        else
        {
            <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel CssClass=@CssClass Text=@GetFormattedNumber() />
        }

        <FieldValidationDisplay Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label />
        @if (FormOptions != null && FormOptions.ShowBoundValues)
        {
            <div class="bound-value">@CurrentValueAsString</div>
        }
    </div>
}