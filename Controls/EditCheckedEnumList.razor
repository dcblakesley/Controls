@typeparam TEnum
@inherits EditControlListBase<TEnum>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        <fieldset class="edit-checkedList-fieldset">
        <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequired Description=@Description Tooltip=@Tooltip IsLegend="true" IsLabelHidden=@ShouldHideLabel />

            @if (ShowEditor)
            {
                // Resolve the invalid state once per render instead of re-querying per checkbox.
                var isInvalid = IsInvalid;
                <div class=@(IsHorizontal
                               ? "edit-checkedList-checkboxes-container-horizontal"
                               : "edit-checkedList-checkboxes-container-vertical")>
                    @foreach (var option in GetOptions())
                    {
                        <label @key="option" class=@($"edit-checkbox-label {LabelClass}") for=@($"cbx-{_id}-{option.ToId()}")>
                            <input type="checkbox"
                                   value=@option
                                   checked="@(Value?.Contains(option) == true)"
                                   disabled=@IsDisabled
                                   aria-disabled=@IsDisabled
                                   aria-invalid=@(isInvalid ? "true" : null) aria-describedby=@_describedBy
                                   tabindex="0"
                                   @onchange="() => ToggleAsync(option)"
                                   id=@($"cbx-{_id}-{option.ToId()}")
                                   data-test-id=@($"cbx-{_id}-{option.ToId()}")
                                   class="edit-checkedList-checkbox @(isInvalid ? "invalid" : "")" />
                            @option.GetName()
                        </label>
                    }
                </div>
            }
            else
            {
                @if(!Value.Any())
                {
                    <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel Text=""/>
                }
                else
                {
                    @foreach (var option in Value)
                    {
                        <ReadOnlyValue Id=@($"{_id}-option-{option.ToId()}") IsLabelHidden="true" Text=@option.GetName()/>
                    }
                }
            }
            <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label/>
            @if (FormOptions != null && FormOptions.ShowBoundValues)
            {
                <div class="bound-value">@string.Join(", ", (Value ?? []).Select(x => x.GetName()))</div>
            }

        </fieldset>
    </div>
}