@inherits InputRadioGroup<TValue>
@typeparam TValue

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        @* CssClass (InputBase: consumer class + field-state classes) goes on the fieldset — unlike
           EditRadioEnum/EditRadioString this control doesn't render its own radio inputs (they come
           from ChildContent), so the group root is the only element it owns to carry the class.
           Edit mode only: the read-only branch already forwards CssClass to its ReadOnlyValue. *@
        <fieldset class="edit-radio-fieldset @(ShowEditor ? CssClass : null)"
                  id=@(ShowEditor ? _id : null)
                  data-test-id=@(ShowEditor ? _id : null)
                  role=@(ShowEditor ? "radiogroup" : null)
                  aria-labelledby=@(ShowEditor && !ShouldHideLabel ? $"lbl-{_id}" : null)
                  aria-required=@(ShowEditor ? _isRequired : null)
                  aria-invalid=@(ShowEditor && IsInvalid ? "true" : null)
                  aria-describedby=@(ShowEditor ? _describedBy : null)
                  aria-errormessage=@(ShowEditor && IsInvalid ? _errorMsgId : null)>
       <FormLabel Id=@_id
                  FieldIdentifier=@_fieldIdentifier 
                  Attributes=@_attributes 
                  Label=@Label
                  IsRequired=@IsRequiredResolved
                  Description=@Description
                  Tooltip=@Tooltip 
                  IsLegend=true
                  IsLabelHidden=@ShouldHideLabel />

            @if (ShowEditor)
            {
                @* InputRadioGroup renders no HTML element, so a `disabled` attribute on it goes
                   nowhere — the nested fieldset natively disables every descendant radio instead.
                   ValueExpression is forwarded so the inner group notifies/styles the real model
                   field rather than a bogus FieldIdentifier("CurrentValue"). *@
                <InputRadioGroup TValue="TValue" Value=@CurrentValue ValueChanged=@OnGroupValueChanged ValueExpression=@ValueExpression>
                    <fieldset class="edit-radio-disable-scope" disabled=@IsDisabled>
                        <div class=@(IsHorizontal
                                              ? "edit-radio-buttons-container-horizontal"
                                              : "edit-radio-buttons-container-vertical")>
                            @ChildContent
                        </div>
                    </fieldset>
                </InputRadioGroup>
            }
            else
            {
                <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel CssClass=@CssClass Text=@CurrentValueAsString />
            }

            <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
            @if (FormOptions != null && FormOptions.ShowBoundValues)
            {
                <div class="bound-value">@CurrentValueAsString</div>
            }
        </fieldset>
    </div>
}