
@* Display-only value (EditMode=false). Rendered as plain text, not a role="textbox": a screen
   reader should not announce a non-editable value as an editable field, and it shouldn't be a tab
   stop. The field name is conveyed via aria-labelledby; validation (if any) is announced by the
   sibling FieldValidationDisplay's own live region. *@
<div class="edit-readonly-value @CssClass"
     id=@Id
     data-test-id=@Id
     aria-labelledby=@($"lbl-{Id}")>

    @if (!string.IsNullOrEmpty(Text))
    {
        @Text
    }
    else
    {
        <span aria-hidden="true" style="visibility: hidden">No Value</span>
    }

</div>
