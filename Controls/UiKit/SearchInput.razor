@namespace Controls

<div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
     class="wss-search @(Disabled ? "wss-search-disabled" : null) @AttributeSplat.ConsumerClass(AdditionalAttributes)"
     style="@AttributeSplat.MergeStyle(WidthStyle, AdditionalAttributes)">

    @if (AddonContent is not null || !string.IsNullOrEmpty(AddonLabel))
    {
        <span class="wss-search-addon" id="@(Id is null ? null : $"{Id}-addon")">
            @if (AddonContent is not null)
            {
                @AddonContent
            }
            else
            {
                @AddonLabel
            }
        </span>
    }

    <input class="wss-search-input"
           id="@Id"
           data-test-id="@Id"
           type="text"
           autocomplete="off"
           placeholder="@Placeholder"
           disabled="@Disabled"
           aria-label="@InputAriaLabel"
           aria-labelledby="@AddonLabelledBy"
           value="@Value"
           @oninput="OnInputAsync"
           @onkeydown="OnKeyDownAsync" />

    @if (ShowClear)
    {
        <button type="button" class="wss-search-clear" aria-label="@ClearButtonLabel" @onclick="ClearAsync">
            @EditIcons.ClearCircle
        </button>
    }

    <button type="button" class="wss-search-btn @(HasEnterButtonText ? "wss-search-btn-enter" : null)"
            aria-label="@(HasEnterButtonText ? null : SearchButtonLabel)"
            disabled="@(Disabled || Loading)" aria-busy="@(Loading ? "true" : null)"
            @onclick="RaiseSearchAsync">
        @if (Loading)
        {
            @LoadingIcon
        }
        else if (HasEnterButtonText)
        {
            @EnterButtonText
        }
        else
        {
            @SearchIcon
        }
    </button>
</div>
