@namespace Controls
@inherits PickerBase

@* Backdrop: closes the dropdown on any outside click without needing JS interop. Rendered as the
   wrapper's previous sibling so placePanel can stack it just under the raised wrapper (the same
   contract as Select). tabindex="-1": iOS-class WebKit only synthesizes a click from a tap when
   the target chain contains a focusable element; -1 keeps it out of the Tab order. *@
@if (_open)
{
    <div class="wss-picker-backdrop" tabindex="-1" @onclick="CloseAsync"></div>
}

<div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
     class="@WrapperClass @AttributeSplat.ConsumerClass(AdditionalAttributes)"
     style="@AttributeSplat.MergeStyle(WrapperStyle, AdditionalAttributes)"
     @ref="_wrapperRef"
     @onkeydown="OnWrapperKeyDownAsync" @onkeydown:stopPropagation="@_open">

    @* tabindex="-1": a click on the field's non-input chrome (separator, padding) then focuses
       the field itself instead of <body>, so Escape still bubbles through the wrapper's keydown
       and the focus-out close wiring sees focus as inside. (Same pattern as Select's wrapper;
       also iOS tap-to-click synthesis.) *@
    <div class="wss-picker-input" tabindex="-1" @onclick="OnFieldClickAsync">
        <span class="wss-picker-input-slot @(_open && _activeInput == 0 ? "wss-picker-slot-active" : null)">
            <input @ref="_startInputRef"
                   class="wss-picker-input-start"
                   id="@Id"
                   data-test-id="@Id"
                   type="text"
                   autocomplete="off"
                   aria-label="@StartInputLabel"
                   aria-haspopup="dialog"
                   aria-expanded="@(_open ? "true" : "false")"
                   aria-required="@StartAriaRequired"
                   aria-invalid="@(StartAriaInvalid ? "true" : null)"
                   aria-describedby="@StartAriaDescribedBy"
                   aria-errormessage="@StartAriaErrorMessage"
                   placeholder="@(StartPlaceholder ?? DefaultPlaceholder)"
                   disabled="@Disabled"
                   value="@StartDisplay"
                   @oninput="@(e => _startEdit = e.Value?.ToString() ?? string.Empty)"
                   @onchange="CommitStartTextAsync"
                   @onfocus="@(() => OnInputFocus(0))" />
        </span>
        <span class="wss-picker-separator" aria-hidden="true">@PickerIcons.SwapRightIcon</span>
        <span class="wss-picker-input-slot @(_open && _activeInput == 1 ? "wss-picker-slot-active" : null)">
            <input @ref="_endInputRef"
                   class="wss-picker-input-end"
                   id="@EndId"
                   data-test-id="@EndId"
                   type="text"
                   autocomplete="off"
                   aria-label="@EndInputLabel"
                   aria-haspopup="dialog"
                   aria-expanded="@(_open ? "true" : "false")"
                   aria-required="@EndAriaRequired"
                   aria-invalid="@(EndAriaInvalid ? "true" : null)"
                   aria-describedby="@EndAriaDescribedBy"
                   aria-errormessage="@EndAriaErrorMessage"
                   placeholder="@(EndPlaceholder ?? DefaultPlaceholder)"
                   disabled="@Disabled"
                   value="@EndDisplay"
                   @oninput="@(e => _endEdit = e.Value?.ToString() ?? string.Empty)"
                   @onchange="CommitEndTextAsync"
                   @onfocus="@(() => OnInputFocus(1))" />
        </span>
        <span class="wss-picker-suffix">@PickerIcons.CalendarIcon</span>
        @if (ShowClear)
        {
            <button type="button" class="wss-picker-clear" aria-label="@ClearLabel"
                    @onclick="ClearAsync" @onclick:stopPropagation>@PickerIcons.CloseCross</button>
        }
    </div>

    @if (_open)
    {
        <div class="wss-picker-dropdown @(_positioned ? null : "wss-measuring")" @ref="_panelRef"
             role="dialog" aria-label="@DialogLabel" tabindex="-1">
            @if (Presets is { Count: > 0 })
            {
                <ul class="wss-picker-presets" aria-label="@PresetsLabel">
                    @foreach (var preset in Presets)
                    {
                        var p = preset;
                        <li>
                            <button type="button" class="wss-picker-preset"
                                    @onclick="@(() => OnPresetClickAsync(p))">@p.Label</button>
                        </li>
                    }
                </ul>
            }
            <div class="wss-picker-panels">
                @for (var i = 0; i < 2; i++)
                {
                    var panel = i;
                    @if (EffectiveMode == DatePickerMode.Month || EffectiveMode == DatePickerMode.Quarter)
                    {
                        var year = panel == 0 ? LeftYear : RightYear;
                        var (fromYear, toYear) = YearRange(year);
                        <div class="wss-picker-month">
                            <div class="wss-picker-month-header">
                                @if (panel == 0)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@PrevYearLabel"
                                            disabled="@PrevYearDisabled" @onclick="PrevYear">@PickerIcons.PrevIcon</button>
                                }
                                else
                                {
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                                <div class="wss-picker-month-selects">
                                    <span class="wss-picker-select">
                                        <select aria-label="@YearSelectLabel" value="@year"
                                                @onchange="@(e => OnRangeYearSelectChanged(panel, e))">
                                            @for (var y = fromYear; y <= toYear; y++)
                                            {
                                                <option value="@y" selected="@(y == year)">@y.ToString(PickerCulture)</option>
                                            }
                                        </select>
                                        @PickerIcons.DownIcon
                                    </span>
                                </div>
                                @if (panel == 1)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@NextYearLabel"
                                            disabled="@NextYearDisabled" @onclick="NextYear">@PickerIcons.NextIcon</button>
                                }
                                else
                                {
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                            </div>
                            @if (EffectiveMode == DatePickerMode.Month)
                            {
                                <div class="wss-picker-month-grid" @ref="_gridRefs[panel]"
                                     @onkeydown="OnMonthGridKeyDown"
                                     @onpointerleave="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, OnGridPointerLeave) : default)">
                                    @for (var m = 1; m <= 12; m++)
                                    {
                                        var month = new DateTime(year, m, 1);
                                        <button type="button" class="@UnitBtnClass(month)"
                                                disabled="@IsMonthDisabled(month)"
                                                tabindex="@(IsMonthFocusStop(month) ? "0" : "-1")"
                                                data-date="@month.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                                aria-label="@month.ToString("MMMM yyyy", PickerCulture)"
                                                aria-pressed="@(IsEndpoint(month) ? "true" : "false")"
                                                aria-current="@(month == FirstOfMonth(DateTime.Today) ? "date" : null)"
                                                @onclick="@(() => OnUnitClickAsync(month))"
                                                @onpointerenter="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, () => OnUnitPointerEnter(month)) : default)">@MonthName(m)</button>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="wss-picker-quarter-grid" @ref="_gridRefs[panel]"
                                     @onkeydown="OnQuarterGridKeyDown"
                                     @onpointerleave="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, OnGridPointerLeave) : default)">
                                    @for (var q = 1; q <= 4; q++)
                                    {
                                        var quarter = q;
                                        var quarterStart = QuarterStart(year, quarter);
                                        <button type="button" class="@UnitBtnClass(quarterStart)"
                                                disabled="@IsQuarterDisabled(quarterStart)"
                                                tabindex="@(IsQuarterFocusStop(year, quarter) ? "0" : "-1")"
                                                data-date="@quarterStart.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                                aria-label="@($"Q{quarter.ToString(PickerCulture)} {year.ToString(PickerCulture)}")"
                                                aria-pressed="@(IsEndpoint(quarterStart) ? "true" : "false")"
                                                aria-current="@(year == DateTime.Today.Year && quarter == QuarterOf(DateTime.Today) ? "date" : null)"
                                                @onclick="@(() => OnUnitClickAsync(quarterStart))"
                                                @onpointerenter="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, () => OnUnitPointerEnter(quarterStart)) : default)">Q@(quarter.ToString(PickerCulture))</button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else if (EffectiveMode == DatePickerMode.Year)
                    {
                        var decadeStart = panel == 0 ? LeftDecadeStart : RightDecadeStart;
                        <div class="wss-picker-month">
                            <div class="wss-picker-month-header">
                                @if (panel == 0)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@PrevDecadeLabel"
                                            disabled="@PrevDecadeDisabled" @onclick="PrevDecade">@PickerIcons.PrevIcon</button>
                                }
                                else
                                {
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                                <div class="wss-picker-month-selects">
                                    <span class="wss-picker-decade-label">@DecadeLabelFor(decadeStart)</span>
                                </div>
                                @if (panel == 1)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@NextDecadeLabel"
                                            disabled="@NextDecadeDisabled" @onclick="NextDecade">@PickerIcons.NextIcon</button>
                                }
                                else
                                {
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                            </div>
                            <div class="wss-picker-month-grid" @ref="_gridRefs[panel]"
                                 @onkeydown="OnYearGridKeyDown"
                                 @onpointerleave="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, OnGridPointerLeave) : default)">
                                @for (var j = -1; j <= 10; j++)
                                {
                                    var yr = decadeStart + j;
                                    var yearStart = new DateTime(yr, 1, 1);
                                    var outside = yr < decadeStart || yr > decadeStart + 9;
                                    <button type="button" class="@UnitBtnClass(yearStart, outside)"
                                            disabled="@IsYearDisabled(yearStart)"
                                            tabindex="@(IsYearFocusStop(yr, outside) ? "0" : "-1")"
                                            data-date="@yearStart.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                            aria-label="@yr.ToString(PickerCulture)"
                                            aria-pressed="@(IsEndpoint(yearStart) ? "true" : "false")"
                                            aria-current="@(yr == DateTime.Today.Year ? "date" : null)"
                                            @onclick="@(() => OnUnitClickAsync(yearStart))"
                                            @onpointerenter="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, () => OnUnitPointerEnter(yearStart)) : default)">@yr.ToString(PickerCulture)</button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        var month = _viewMonth.AddMonths(panel);
                        var (fromYear, toYear) = YearRange(month.Year);
                        <div class="wss-picker-month">
                            <div class="wss-picker-month-header">
                                @if (panel == 0)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@PrevMonthLabel"
                                            disabled="@PrevMonthDisabled" @onclick="PrevMonth">@PickerIcons.PrevIcon</button>
                                }
                                else
                                {
                                    @* Invisible stand-in for the nav button this panel doesn't render (prev lives on
                                       the left panel, next on the right), so every header keeps three flex children
                                       and space-between centers the selects instead of shoving them at the divider. *@
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                                <div class="wss-picker-month-selects">
                                    <span class="wss-picker-select">
                                        <select aria-label="@MonthSelectLabel" value="@month.Month"
                                                @onchange="@(e => OnMonthSelectChanged(panel, e))">
                                            @for (var m = 1; m <= 12; m++)
                                            {
                                                <option value="@m" selected="@(m == month.Month)">@MonthName(m)</option>
                                            }
                                        </select>
                                        @PickerIcons.DownIcon
                                    </span>
                                    <span class="wss-picker-select">
                                        <select aria-label="@YearSelectLabel" value="@month.Year"
                                                @onchange="@(e => OnYearSelectChanged(panel, e))">
                                            @for (var y = fromYear; y <= toYear; y++)
                                            {
                                                <option value="@y" selected="@(y == month.Year)">@y.ToString(PickerCulture)</option>
                                            }
                                        </select>
                                        @PickerIcons.DownIcon
                                    </span>
                                </div>
                                @if (panel == 1)
                                {
                                    <button type="button" class="wss-picker-nav" aria-label="@NextMonthLabel"
                                            disabled="@NextMonthDisabled" @onclick="NextMonth">@PickerIcons.NextIcon</button>
                                }
                                else
                                {
                                    <span class="wss-picker-nav wss-picker-nav-placeholder" aria-hidden="true"></span>
                                }
                            </div>
                            <div class="@(ShowWeekRows ? "wss-picker-week-header wss-picker-week-header-weeks" : "wss-picker-week-header")" aria-hidden="true">
                                @if (ShowWeekRows)
                                {
                                    <div class="wss-picker-week-no-header"></div>
                                }
                                @foreach (var name in WeekdayHeaders)
                                {
                                    <div class="wss-picker-week-day">@name</div>
                                }
                            </div>
                            @* The pointer handlers only exist while a range pick is in progress: wiring them
                               unconditionally would re-render the component (a SignalR round trip per cell on
                               Blazor Server) for every cell the idle pointer crosses. An EventCallback without
                               a delegate is omitted from the render tree entirely. *@
                            @if (ShowWeekRows)
                            {
                                <div class="wss-picker-grid-rows" @ref="_gridRefs[panel]"
                                     @onkeydown="OnGridKeyDown"
                                     @onpointerleave="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, OnGridPointerLeave) : default)">
                                    @foreach (var row in GridWeekRows(month))
                                    {
                                        var weekStart = row[0];
                                        <div class="@WeekRowClass(weekStart)">
                                            <div class="wss-picker-week-no" aria-hidden="true">@WeekNumberOf(weekStart).ToString(PickerCulture)</div>
                                            @foreach (var day in row)
                                            {
                                                var d = day;
                                                var pressed = EffectiveMode == DatePickerMode.Week ? IsWeekRowEndpoint(weekStart) : IsEndpoint(d);
                                                <div class="@CellClass(d)">
                                                    <button type="button" class="@DayClass(d, month)"
                                                            disabled="@IsDayDisabled(d)"
                                                            tabindex="@(IsFocusStop(d, month) ? "0" : "-1")"
                                                            data-date="@d.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                                            aria-label="@d.ToString("D", PickerCulture)"
                                                            aria-pressed="@(pressed ? "true" : "false")"
                                                            @onclick="@(() => OnGridDayClickAsync(d))"
                                                            @onpointerenter="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, () => OnGridDayPointerEnter(d)) : default)">@d.Day.ToString("00", CultureInfo.CurrentCulture)</button>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="wss-picker-grid" @ref="_gridRefs[panel]"
                                     @onkeydown="OnGridKeyDown"
                                     @onpointerleave="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, OnGridPointerLeave) : default)">
                                    @foreach (var day in GridDays(month))
                                    {
                                        var d = day;
                                        <div class="@CellClass(d)">
                                            <button type="button" class="@DayClass(d, month)"
                                                    disabled="@IsDayDisabled(d)"
                                                    tabindex="@(IsFocusStop(d, month) ? "0" : "-1")"
                                                    data-date="@d.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                                    aria-label="@d.ToString("D", PickerCulture)"
                                                    aria-pressed="@(IsEndpoint(d) ? "true" : "false")"
                                                    @onclick="@(() => OnGridDayClickAsync(d))"
                                                    @onpointerenter="@(_selecting ? EventCallback.Factory.Create<PointerEventArgs>(this, () => OnGridDayPointerEnter(d)) : default)">@d.Day.ToString("00", CultureInfo.CurrentCulture)</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>
