@namespace Controls

@if (Loading)
{
    @* role=status + aria-busy announce the loading state; the bars are decorative (aria-hidden) so a
       screen reader hears the loading text, not a string of empty elements. *@
    <div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
         class="wss-skeleton @(Active ? "wss-skeleton-active" : null) @AttributeSplat.ConsumerClass(AdditionalAttributes)"
         style="@AttributeSplat.MergeStyle(null, AdditionalAttributes)"
         role="status" aria-busy="true">
        <span class="wss-sr-only">@LoadingText</span>
        @if (Title)
        {
            <div class="wss-skeleton-title" aria-hidden="true"></div>
        }
        <ul class="wss-skeleton-paragraph" aria-hidden="true">
            @for (var i = 0; i < Rows; i++)
            {
                <li style="@(i == Rows - 1 && Rows > 1 ? "width:61%;" : null)"></li>
            }
        </ul>
    </div>
}
else
{
    @ChildContent
}

@code {
    /// <summary>When true (default) show the placeholder; when false render <see cref="ChildContent"/>.</summary>
    [Parameter] public bool Loading { get; set; } = true;

    /// <summary>Show the shimmer animation.</summary>
    [Parameter] public bool Active { get; set; } = true;

    /// <summary>Render a title bar above the paragraph lines.</summary>
    [Parameter] public bool Title { get; set; } = true;

    /// <summary>Number of paragraph lines.</summary>
    [Parameter] public int Rows { get; set; } = 3;

    /// <summary>Screen-reader text announced while loading (the bars themselves are hidden from AT).</summary>
    [Parameter] public string LoadingText { get; set; } = "Loading";

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the component's root element. <c>class</c> and <c>style</c> merge with the
    /// component's own; the rest are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}
