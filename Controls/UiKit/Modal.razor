@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Visible)
{
    @* tabindex="-1": iOS-class WebKit only synthesizes a click from a tap on a focusable/interactive
       target chain, so without it a mask tap never reaches @onclick (mask-close dead on touch). The
       JS focus trap preventDefaults outside mousedown, so the wrap can't actually steal focus. *@
    <div class="wss-modal-wrap" tabindex="-1" @onmousedown="OnMaskMouseDown" @onmouseup="OnMaskMouseUp" @onclick="OnMaskClickAsync">
        <div class="wss-modal" style="width:@Width" role="dialog" aria-modal="true"
             aria-labelledby="@(HasTitle ? _titleId : null)" aria-label="@(HasTitle ? null : AriaLabel ?? "Dialog")" tabindex="-1"
             @ref="_panelRef" @onkeydown="OnKeyDownAsync" @onkeydown:stopPropagation="true"
             @onmousedown="OnPanelMouseDown" @onmousedown:stopPropagation="true"
             @onmouseup:stopPropagation="true" @onclick:stopPropagation="true">
            @if (HasTitle || Closable)
            {
                <div class="wss-modal-header">
                    <div class="wss-modal-title" id="@_titleId">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                    @if (Closable)
                    {
                        <button type="button" class="wss-modal-close" aria-label="Close" @onclick="CancelAsync">
                            <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                        </button>
                    }
                </div>
            }
            <div class="wss-modal-body">@ChildContent</div>
            @if (!HideFooter)
            {
                <div class="wss-modal-footer">
                    @if (Footer != null)
                    {
                        @Footer
                    }
                    else
                    {
                        <button type="button" class="wss-dialog-btn" @onclick="CancelAsync">@CancelText</button>
                        <button type="button" class="wss-dialog-btn wss-dialog-btn-primary" disabled="@ConfirmLoading" @onclick="OkAsync">@OkText</button>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public bool HideFooter { get; set; }
    [Parameter] public string OkText { get; set; } = "OK";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public EventCallback OnOk { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string Width { get; set; } = "520px";
    [Parameter] public bool Closable { get; set; } = true;
    [Parameter] public bool MaskClosable { get; set; } = true;
    [Parameter] public bool ConfirmLoading { get; set; }
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    readonly string _titleId = $"wss-modal-title-{Guid.NewGuid():N}";
    ElementReference _panelRef;
    IJSObjectReference? _module;
    IJSObjectReference? _focusHandle;
    bool _active;
    bool _disposed;

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    async Task CloseAsync()
    {
        if (VisibleChanged.HasDelegate) await VisibleChanged.InvokeAsync(false);
    }

    async Task CancelAsync()
    {
        await CloseAsync();
        if (OnCancel.HasDelegate) await OnCancel.InvokeAsync();
    }

    // OK does not auto-close: the caller decides (e.g. after async work / validation).
    async Task OkAsync()
    {
        if (OnOk.HasDelegate) await OnOk.InvokeAsync();
    }

    bool _maskMouseDown;
    bool _maskMouseUp;

    // Close only when a click both STARTS and ENDS on the mask. A cross-boundary drag (press on the
    // mask, release in the panel — or the reverse) is a "changed my mind" gesture that AntD keeps
    // open; its composed click dispatches to the wrap (the mousedown/mouseup common ancestor), so the
    // click handler alone can't tell where the gesture began or ended. The panel stops mousedown AND
    // mouseup propagation, so these wrap handlers only ever fire for events on the mask itself.
    void OnMaskMouseDown() { _maskMouseDown = true; _maskMouseUp = false; }
    void OnMaskMouseUp() => _maskMouseUp = true;

    // A fresh press inside the panel starts a new gesture that can't close — and also clears a STALE
    // mask-down flag from a press that released outside the window (which fires no click to reset it).
    void OnPanelMouseDown() { _maskMouseDown = false; _maskMouseUp = false; }

    async Task OnMaskClickAsync()
    {
        var closeOnMask = _maskMouseDown && _maskMouseUp;
        _maskMouseDown = _maskMouseUp = false;
        if (MaskClosable && closeOnMask) await CancelAsync();
    }

    async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && Closable) await CancelAsync();
    }

    int _activationSeq;

    // Focus trap + body-scroll-lock while open; restores focus to the opener on close.
    // Degrades to no-op when JS is unavailable (prerender / tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_active)
        {
            _active = true;
            // Sequence token: a close (and possibly a reopen, which starts a *new* activation)
            // while this activation's JS call is in flight makes this one stale. Without the token
            // a close→reopen race left the first handle orphaned — its ref-counted body-scroll
            // lock was never released, permanently freezing page scroll.
            var seq = ++_activationSeq;
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                if (_disposed)
                {
                    // Disposed while the import itself was in flight — DisposeAsync already ran with a null
                    // module, so this reference is ours to clean up (it would otherwise strand for the
                    // circuit's life). The seq/!Visible checks below cover the later activateModal handle.
                    try { await _module.DisposeAsync(); } catch { }
                    _module = null;
                    return;
                }
                var handle = await _module.InvokeAsync<IJSObjectReference>("activateModal", _panelRef);
                // Disposed (or closed/reopened) while activateModal was in flight? DisposeAsync already
                // ran — storing this handle would orphan it, leaking the body-scroll lock + document
                // listeners for the circuit's life. Release it here instead.
                if (_disposed || seq != _activationSeq || !Visible)
                {
                    try { await handle.InvokeVoidAsync("dispose"); await handle.DisposeAsync(); } catch { }
                }
                else
                {
                    _focusHandle = handle;
                }
            }
            catch { /* no JS — modal still usable, just no focus trap/scroll lock */ }
        }
        else if (!Visible && _active)
        {
            _active = false;
            _activationSeq++; // invalidate any in-flight activation
            await ReleaseFocusAsync();
        }
    }

    async Task ReleaseFocusAsync()
    {
        if (_focusHandle is not null)
        {
            try { await _focusHandle.InvokeVoidAsync("dispose"); await _focusHandle.DisposeAsync(); } catch { }
            _focusHandle = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _activationSeq++; // invalidate any in-flight activation so its handle is released, not stored
        await ReleaseFocusAsync();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
            _module = null;
        }
    }
}
