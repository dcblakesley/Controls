@namespace Controls

@if (Visible)
{
    <div class="wss-modal-wrap" @onclick="OnMaskClickAsync">
        <div class="wss-modal" style="width:@Width" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <div class="wss-modal-header">
                <div class="wss-modal-title">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                @if (Closable)
                {
                    <button type="button" class="wss-modal-close" aria-label="Close" @onclick="CancelAsync">
                        <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                    </button>
                }
            </div>
            <div class="wss-modal-body">@ChildContent</div>
            @if (!HideFooter)
            {
                <div class="wss-modal-footer">
                    @if (Footer != null)
                    {
                        @Footer
                    }
                    else
                    {
                        <button type="button" class="wss-dialog-btn" @onclick="CancelAsync">@CancelText</button>
                        <button type="button" class="wss-dialog-btn wss-dialog-btn-primary" disabled="@ConfirmLoading" @onclick="OkAsync">@OkText</button>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public bool HideFooter { get; set; }
    [Parameter] public string OkText { get; set; } = "OK";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public EventCallback OnOk { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public string Width { get; set; } = "520px";
    [Parameter] public bool Closable { get; set; } = true;
    [Parameter] public bool MaskClosable { get; set; } = true;
    [Parameter] public bool ConfirmLoading { get; set; }

    async Task CloseAsync()
    {
        if (VisibleChanged.HasDelegate) await VisibleChanged.InvokeAsync(false);
    }

    async Task CancelAsync()
    {
        await CloseAsync();
        if (OnCancel.HasDelegate) await OnCancel.InvokeAsync();
    }

    // OK does not auto-close: the caller decides (e.g. after async work / validation).
    async Task OkAsync()
    {
        if (OnOk.HasDelegate) await OnOk.InvokeAsync();
    }

    async Task OnMaskClickAsync()
    {
        if (MaskClosable) await CancelAsync();
    }
}
