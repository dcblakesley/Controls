@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Visible)
{
    <div class="wss-drawer-root">
        @* tabindex="-1": iOS-class WebKit only synthesizes a click from a tap on a focusable/
           interactive target chain — without it a mask tap never reaches @onclick on touch. *@
        <div class="wss-drawer-mask" tabindex="-1" @onclick="OnMaskClickAsync"></div>
        <div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
             class="wss-drawer wss-drawer-@PlacementName @AttributeSplat.ConsumerClass(AdditionalAttributes)"
             style="@AttributeSplat.MergeStyle(SizeStyle, AdditionalAttributes)" role="dialog" aria-modal="true"
             aria-labelledby="@(HasTitle ? _titleId : null)" aria-label="@(HasTitle ? null : AriaLabel ?? "Drawer")" tabindex="-1"
             @ref="_panelRef" @onkeydown="OnKeyDownAsync" @onkeydown:stopPropagation="true">
            @if (HasTitle || Closable || Extra is not null)
            {
                <div class="wss-drawer-header">
                    <div class="wss-drawer-title" id="@_titleId">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                    @if (Extra is not null)
                    {
                        <div class="wss-drawer-header-actions">
                            <span class="wss-drawer-extra">@Extra</span>
                            @if (Closable)
                            {
                                <button type="button" class="wss-drawer-close" aria-label="Close" @onclick="CloseAsync">
                                    <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                                </button>
                            }
                        </div>
                    }
                    else if (Closable)
                    {
                        <button type="button" class="wss-drawer-close" aria-label="Close" @onclick="CloseAsync">
                            <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                        </button>
                    }
                </div>
            }
            <div class="wss-drawer-body">@ChildContent</div>
            @if (Footer != null)
            {
                <div class="wss-drawer-footer">@Footer</div>
            }
        </div>
    </div>
}

@code {
    /// <summary>Whether the drawer is shown. Use <c>@bind-Visible</c> — the parent owns the state.</summary>
    [Parameter] public bool Visible { get; set; }
    /// <summary>Raised with <c>false</c> when the drawer requests close (close icon, mask click, or Escape).</summary>
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    /// <summary>Plain-text header title. Omit both title parameters to render a header-less drawer.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Rich header title; overrides <see cref="Title"/> when set.</summary>
    [Parameter] public RenderFragment? TitleContent { get; set; }
    /// <summary>The drawer body.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Optional footer content pinned to the bottom of the drawer.</summary>
    [Parameter] public RenderFragment? Footer { get; set; }
    /// <summary>Optional header-right slot rendered beside the close button (AntD's <c>extra</c>).
    /// When set, forces the header to render even if both <see cref="Title"/>/<see cref="TitleContent"/>
    /// and <see cref="Closable"/> are absent.</summary>
    [Parameter] public RenderFragment? Extra { get; set; }
    /// <summary>Which screen edge the drawer slides in from. Defaults to <see cref="DrawerPlacement.Right"/>.</summary>
    [Parameter] public DrawerPlacement Placement { get; set; } = DrawerPlacement.Right;
    /// <summary>Width for left/right placements (CSS length).</summary>
    [Parameter] public string Width { get; set; } = "378px";
    /// <summary>Height for top/bottom placements (CSS length).</summary>
    [Parameter] public string Height { get; set; } = "378px";
    /// <summary>Shows the header close icon. Defaults to true. Escape-to-close is governed
    /// independently by <see cref="Keyboard"/> — matching AntD, where <c>closable</c> only controls
    /// the X button.</summary>
    [Parameter] public bool Closable { get; set; } = true;
    /// <summary>When true (default), clicking the mask outside the drawer closes it.</summary>
    [Parameter] public bool MaskClosable { get; set; } = true;
    /// <summary>When true (default), pressing Escape closes the drawer. Independent of
    /// <see cref="Closable"/> (which only shows/hides the header X) — matching AntD's
    /// <c>keyboard</c> prop.</summary>
    [Parameter] public bool Keyboard { get; set; } = true;
    /// <summary>Raised after the drawer closes for any reason (close icon, mask click, or Escape).</summary>
    [Parameter] public EventCallback OnClose { get; set; }
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the drawer panel (<c>.wss-drawer</c>) — not <c>.wss-drawer-root</c>, whose inline
    /// z-index is JS-owned. <c>class</c> and <c>style</c> merge with the component's own; the rest
    /// are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] FormDefaults? FormDefaults { get; set; }

    readonly string _titleId = $"wss-drawer-title-{Guid.NewGuid():N}";
    ElementReference _panelRef;
    IJSObjectReference? _module;
    IJSObjectReference? _focusHandle;
    bool _active;
    bool _disposed;

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool IsHorizontal => Placement is DrawerPlacement.Left or DrawerPlacement.Right;

    string SizeStyle => IsHorizontal ? $"width:{Width}" : $"height:{Height}";

    async Task CloseAsync()
    {
        if (VisibleChanged.HasDelegate) await VisibleChanged.InvokeAsync(false);
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }

    async Task OnMaskClickAsync()
    {
        if (MaskClosable) await CloseAsync();
    }

    async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && Keyboard) await CloseAsync();
    }

    int _activationSeq;

    // Focus trap + body-scroll-lock while open; restores focus to the opener on close.
    // Degrades to no-op when JS is unavailable (prerender / tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_active)
        {
            _active = true;
            // Sequence token: a close (and possibly a reopen, which starts a *new* activation)
            // while this activation's JS call is in flight makes this one stale. Without the token
            // a close→reopen race left the first handle orphaned — its ref-counted body-scroll
            // lock was never released, permanently freezing page scroll.
            var seq = ++_activationSeq;
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", JsModuleUrl.Resolve(FormDefaults, "wss-overlay.js"));
                if (_disposed)
                {
                    // Disposed while the import itself was in flight — DisposeAsync already ran with a null
                    // module, so this reference is ours to clean up (it would otherwise strand for the
                    // circuit's life). The seq/!Visible checks below cover the later activateModal handle.
                    try { await _module.DisposeAsync(); } catch { }
                    _module = null;
                    return;
                }
                var handle = await _module.InvokeAsync<IJSObjectReference>("activateModal", _panelRef);
                // Disposed (or closed/reopened) while activateModal was in flight? DisposeAsync already
                // ran — storing this handle would orphan it, leaking the body-scroll lock + document
                // listeners for the circuit's life. Release it here instead.
                if (_disposed || seq != _activationSeq || !Visible)
                {
                    try { await handle.InvokeVoidAsync("dispose"); await handle.DisposeAsync(); } catch { }
                }
                else
                {
                    _focusHandle = handle;
                }
            }
            catch { /* no JS — drawer still usable */ }
        }
        else if (!Visible && _active)
        {
            _active = false;
            _activationSeq++; // invalidate any in-flight activation
            await ReleaseFocusAsync();
        }
    }

    async Task ReleaseFocusAsync()
    {
        if (_focusHandle is not null)
        {
            try { await _focusHandle.InvokeVoidAsync("dispose"); await _focusHandle.DisposeAsync(); } catch { }
            _focusHandle = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _activationSeq++; // invalidate any in-flight activation so its handle is released, not stored
        await ReleaseFocusAsync();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
            _module = null;
        }
    }
}
