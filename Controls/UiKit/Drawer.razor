@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (Visible)
{
    <div class="wss-drawer-root">
        <div class="wss-drawer-mask" @onclick="OnMaskClickAsync"></div>
        <div class="wss-drawer wss-drawer-@PlacementName" style="@SizeStyle" role="dialog" aria-modal="true"
             aria-labelledby="@(HasTitle ? _titleId : null)" aria-label="@(HasTitle ? null : AriaLabel)" tabindex="-1"
             @ref="_panelRef" @onkeydown="OnKeyDownAsync" @onkeydown:stopPropagation="true">
            <div class="wss-drawer-header">
                <div class="wss-drawer-title" id="@_titleId">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                @if (Closable)
                {
                    <button type="button" class="wss-drawer-close" aria-label="Close" @onclick="CloseAsync">
                        <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                    </button>
                }
            </div>
            <div class="wss-drawer-body">@ChildContent</div>
            @if (Footer != null)
            {
                <div class="wss-drawer-footer">@Footer</div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Footer { get; set; }
    [Parameter] public DrawerPlacement Placement { get; set; } = DrawerPlacement.Right;
    /// <summary>Width for left/right placements (CSS length).</summary>
    [Parameter] public string Width { get; set; } = "378px";
    /// <summary>Height for top/bottom placements (CSS length).</summary>
    [Parameter] public string Height { get; set; } = "378px";
    [Parameter] public bool Closable { get; set; } = true;
    [Parameter] public bool MaskClosable { get; set; } = true;
    [Parameter] public EventCallback OnClose { get; set; }
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    readonly string _titleId = $"wss-drawer-title-{Guid.NewGuid():N}";
    ElementReference _panelRef;
    IJSObjectReference? _module;
    IJSObjectReference? _focusHandle;
    bool _active;

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool IsHorizontal => Placement is DrawerPlacement.Left or DrawerPlacement.Right;

    string SizeStyle => IsHorizontal ? $"width:{Width}" : $"height:{Height}";

    async Task CloseAsync()
    {
        if (VisibleChanged.HasDelegate) await VisibleChanged.InvokeAsync(false);
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }

    async Task OnMaskClickAsync()
    {
        if (MaskClosable) await CloseAsync();
    }

    async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && Closable) await CloseAsync();
    }

    // Focus trap + body-scroll-lock while open; restores focus to the opener on close.
    // Degrades to no-op when JS is unavailable (prerender / tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible && !_active)
        {
            _active = true;
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                _focusHandle = await _module.InvokeAsync<IJSObjectReference>("activateModal", _panelRef);
                // Closed while awaiting the import/activation? The close path already ran with a null
                // handle, so release the one we just acquired — otherwise the body-scroll lock leaks.
                if (!Visible) await ReleaseFocusAsync();
            }
            catch { /* no JS — drawer still usable */ }
        }
        else if (!Visible && _active)
        {
            _active = false;
            await ReleaseFocusAsync();
        }
    }

    async Task ReleaseFocusAsync()
    {
        if (_focusHandle is not null)
        {
            try { await _focusHandle.InvokeVoidAsync("dispose"); await _focusHandle.DisposeAsync(); } catch { }
            _focusHandle = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await ReleaseFocusAsync();
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
            _module = null;
        }
    }
}
