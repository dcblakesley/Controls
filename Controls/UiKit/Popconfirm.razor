@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

<span class="wss-popconfirm-wrap">
    <span class="wss-popconfirm-trigger" @ref="_triggerRef" tabindex="0" role="button"
          aria-haspopup="dialog" aria-expanded="@_open"
          @onclick="Toggle" @onkeydown="OnTriggerKeyDown">@ChildContent</span>
    @if (_open)
    {
        <div class="wss-popconfirm-backdrop" @onclick="Close"></div>
        <div class="wss-popconfirm wss-popconfirm-@PlacementName @(_positioned ? null : "wss-measuring")" @ref="_panelRef" role="dialog" @onclick:stopPropagation="true">
            <div class="wss-popconfirm-inner">
                <div class="wss-popconfirm-message">
                    <span class="wss-popconfirm-icon">
                        <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48.01 48.01 0 010-96 48.01 48.01 0 010 96z"/></svg>
                    </span>
                    <div class="wss-popconfirm-title">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                </div>
                <div class="wss-popconfirm-buttons">
                    <button type="button" class="wss-dialog-btn wss-dialog-btn-sm" @onclick="CancelAsync">@CancelText</button>
                    <button type="button" class="wss-dialog-btn wss-dialog-btn-sm wss-dialog-btn-primary" @onclick="ConfirmAsync">@OkText</button>
                </div>
            </div>
            <span class="wss-popconfirm-arrow"></span>
        </div>
    }
</span>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string OkText { get; set; } = "OK";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public PopupPlacement Placement { get; set; } = PopupPlacement.Top;
    [Parameter] public bool Disabled { get; set; }

    ElementReference _triggerRef;
    ElementReference _panelRef;
    IJSObjectReference? _module;
    bool _open;
    bool _positioned;

    string PlacementName => Placement.ToString().ToLowerInvariant();

    void Toggle()
    {
        if (Disabled) return;
        _open = !_open;
    }

    void Close() => _open = false;

    void OnTriggerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") Toggle();
        else if (e.Key == "Escape") Close();
    }

    async Task ConfirmAsync()
    {
        _open = false;
        if (OnConfirm.HasDelegate) await OnConfirm.InvokeAsync();
    }

    async Task CancelAsync()
    {
        _open = false;
        if (OnCancel.HasDelegate) await OnCancel.InvokeAsync();
    }

    // After the panel opens, nudge it to stay within the viewport (flip/shift). Degrades to the
    // default CSS placement when JS isn't available (server prerender, unit tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_open && !_positioned)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                await _module.InvokeVoidAsync("place", _triggerRef, _panelRef, "wss-popconfirm", PlacementName, 10, 8);
            }
            catch
            {
                // No JS runtime / module — keep the CSS default placement.
            }
            _positioned = true;
            StateHasChanged(); // reveal the panel now that it's positioned (drops wss-measuring)
        }
        else if (!_open && _positioned)
        {
            _positioned = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
        }
    }
}
