@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

<span @attributes="AttributeSplat.Rest(AdditionalAttributes)"
      class="wss-popconfirm-wrap @AttributeSplat.ConsumerClass(AdditionalAttributes)"
      style="@AttributeSplat.MergeStyle(null, AdditionalAttributes)">
    @* The consumer's ChildContent normally holds the interactive trigger (e.g. a <button>): its
       native activation bubbles here as a click, so this wrapper carries no button semantics of its
       own (it used to be role="button", nesting a button inside a button — two tab stops, invalid
       ARIA). wss-overlay.js mirrors the popup ARIA onto that child (skipped while Disabled), or
       promotes this span to the button role when the content has nothing focusable. *@
    <span class="wss-popconfirm-trigger" @ref="_triggerRef"
          @onclick="ToggleAsync" @onkeydown="OnTriggerKeyDownAsync" @onkeydown:stopPropagation="@_open">@ChildContent</span>
    @if (_open)
    {
        @* tabindex="-1": iOS-class WebKit only synthesizes a click from a tap on a focusable/
           interactive target chain — without it a backdrop tap never reaches @onclick on touch. *@
        <div class="wss-popconfirm-backdrop" tabindex="-1" @onclick="CloseAsync"></div>
        <div class="wss-popconfirm wss-popconfirm-@(_resolvedPlacement ?? PlacementName) @(_positioned ? null : "wss-measuring")"
             @ref="_panelRef" role="dialog" aria-labelledby="@(HasTitle ? $"{_id}-title" : null)"
             aria-label="@(HasTitle ? null : AriaLabel)"
             @onkeydown="OnPanelKeyDown"
             @onkeydown:stopPropagation="true"
             @onclick:stopPropagation="true">
            <div class="wss-popconfirm-inner">
                <div class="wss-popconfirm-message">
                    <span class="wss-popconfirm-icon">
                        <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48.01 48.01 0 010-96 48.01 48.01 0 010 96z"/></svg>
                    </span>
                    @if (HasTitle)
                    {
                        <div class="wss-popconfirm-title" id="@($"{_id}-title")">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                    }
                </div>
                <div class="wss-popconfirm-buttons">
                    <button type="button" class="wss-dialog-btn wss-dialog-btn-sm" disabled="@_confirmLoading" @onclick="CancelAsync">@CancelText</button>
                    <button type="button" @ref="_okButtonRef"
                            class="wss-dialog-btn wss-dialog-btn-sm wss-dialog-btn-primary @(OkDanger ? "wss-dialog-btn-danger" : null)"
                            disabled="@_confirmLoading" aria-busy="@(_confirmLoading ? "true" : null)"
                            @onclick="ConfirmAsync">
                        @if (_confirmLoading)
                        {
                            <span class="wss-icon-spin">@EditIcons.LoadingSpinner</span>
                        }
                        @OkText
                    </button>
                </div>
            </div>
            <span class="wss-popconfirm-arrow"></span>
        </div>
    }
</span>

@code {
    /// <summary>Plain-text confirmation question shown in the popup.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Rich confirmation content; overrides <see cref="Title"/> when set.</summary>
    [Parameter] public RenderFragment? TitleContent { get; set; }
    /// <summary>The trigger element the popup attaches to — ideally an interactive element such as a <c>&lt;button&gt;</c>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Text of the confirm button. Defaults to "OK".</summary>
    [Parameter] public string OkText { get; set; } = "OK";
    /// <summary>Text of the cancel button. Defaults to "Cancel".</summary>
    [Parameter] public string CancelText { get; set; } = "Cancel";
    /// <summary>
    /// Raised when the confirm button is clicked. A synchronous handler (or one whose returned
    /// <see cref="Task"/> is already complete) keeps today's immediate-close feel. A genuinely
    /// pending <see cref="Task"/> (checked via <see cref="Task.IsCompleted"/> right after invoking)
    /// instead keeps the popup open with both buttons disabled and a spinner in the OK button until
    /// it completes; an exception closes the popup and rethrows (never swallowed). While pending,
    /// Escape, the backdrop, and the (already-disabled) Cancel button all wait/no-op rather than
    /// closing the popup and firing <see cref="OnCancel"/> out from under the still-running task --
    /// see <see cref="Visible"/> for the equivalent guard on an external controlled close.
    /// </summary>
    [Parameter] public EventCallback OnConfirm { get; set; }
    /// <summary>Raised when the popup is cancelled (Cancel button or Escape inside the panel).</summary>
    [Parameter] public EventCallback OnCancel { get; set; }
    /// <summary>Preferred side of the trigger for the popup; flips to the opposite side when it would leave the viewport. Defaults to <see cref="PopupPlacement.Top"/>.</summary>
    [Parameter] public PopupPlacement Placement { get; set; } = PopupPlacement.Top;
    /// <summary>When true, clicking the trigger does not open the popup; an already-open popup
    /// closes immediately when this becomes true (any control mode), and an externally-forced
    /// <see cref="Visible"/> = true is ignored while this is true.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Danger (red primary) styling on the OK button — AntD's <c>okButtonProps={{ danger: true }}</c> shorthand.</summary>
    [Parameter] public bool OkDanger { get; set; }
    /// <summary>
    /// Controls the popup's open state (two-way bindable via <c>@bind-Visible</c>). While
    /// <see cref="VisibleChanged"/> has a delegate, this becomes the source of truth: an external
    /// change routes through the same open/close path as user interaction (JS placement/focus still
    /// run), and every open/close (external or internal) raises <see cref="VisibleChanged"/> back. An
    /// echo of a value this component just raised is recognized and ignored. Ignored (and never
    /// echoed back as true) while <see cref="Disabled"/>. Also ignored while a genuinely pending
    /// <see cref="OnConfirm"/> task holds the popup open (the pending-confirm lock) -- an external
    /// <c>Visible = false</c> during that window waits rather than closing the popup out from under
    /// the in-flight task; the popup closes itself (raising <see cref="VisibleChanged"/>) once the
    /// task settles. With no delegate on <see cref="VisibleChanged"/> (the default, uncontrolled
    /// case), this parameter is inert.
    /// </summary>
    [Parameter] public bool Visible { get; set; }
    /// <summary>Raised on every open/close (external or internal). Supports <c>@bind-Visible</c>; see <see cref="Visible"/>.</summary>
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the outer wrapper (<c>.wss-popconfirm-wrap</c>) — never the floating panel, whose
    /// inline placement (z-index, <c>--wss-shift</c>) is JS-owned. <c>class</c> and <c>style</c>
    /// merge with the component's own; the rest are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] FormDefaults? FormDefaults { get; set; }

    ElementReference _triggerRef;
    ElementReference _panelRef;
    ElementReference _okButtonRef;
    IJSObjectReference? _module;
    bool _open;
    bool _positioned;
    bool _pendingFocus;
    bool _disposed;
    bool _confirmLoading;
    // The last Visible value this component has observed OR itself raised via
    // RaiseVisibleChangedAsync. Null until the first time VisibleChanged carries a delegate —
    // mirrors Select's controlled Open/OpenChanged design (_lastOpenParam) so a controlled
    // consumer's @bind-Visible field echoing its own value back in isn't mistaken for a fresh
    // external open/close request.
    bool? _lastVisibleParam;
    // Last (open, disabled) pair pushed to syncTrigger. syncTrigger re-resolves the trigger child on
    // every call, so we only re-invoke it when this pair changes (plus the first render) — otherwise
    // every ancestor re-render would cost one interop round trip per instance (e.g. a Popconfirm per
    // Table row).
    (bool Open, bool Disabled)? _lastSyncedTrigger;
    // Side the panel actually rendered on after the viewport flip. Null until measured (falls back to
    // the preferred PlacementName). Owned by C# so the re-render that drops `wss-measuring` keeps it.
    string? _resolvedPlacement;
    readonly string _id = $"wss-popconfirm-{Guid.NewGuid():N}";

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    // Single choke point for every open/close, internal or externally-driven: applies _open (the
    // one source of truth OnAfterRenderAsync's JS placement/focus logic reacts to, regardless of
    // who changed it) and notifies VisibleChanged. Mirrors Select's OpenAsync/CloseAsync +
    // RaiseOpenChangedAsync split.
    async Task SetOpenAsync(bool open)
    {
        if (open == _open) return;
        _open = open;
        await RaiseVisibleChangedAsync();
    }

    Task RaiseVisibleChangedAsync()
    {
        _lastVisibleParam = _open;
        return VisibleChanged.HasDelegate ? VisibleChanged.InvokeAsync(_open) : Task.CompletedTask;
    }

    async Task ToggleAsync()
    {
        if (Disabled) return;
        await SetOpenAsync(!_open);
    }

    // Pending-confirm lock: a backdrop click while _confirmLoading waits/no-ops instead of closing
    // out from under the in-flight OnConfirm task -- see CancelAsync.
    async Task CloseAsync()
    {
        if (_confirmLoading) return;
        await SetOpenAsync(false);
    }

    // Escape only: Enter/Space activation comes from the child's native click (or the JS fallback
    // synthesizing one for plain content) bubbling into @onclick — handling the keys here as well
    // would double-toggle when a button child's keystroke both clicks and bubbles.
    async Task OnTriggerKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseAsync();
    }

    // Escape from inside the panel cancels — the panel is a sibling of the trigger, so its keydown
    // never bubbles to the trigger's handler.
    async Task OnPanelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CancelAsync();
    }

    // Sync (or already-completed) handlers keep the immediate-close feel; a genuinely pending Task
    // keeps the popup open with a busy OK button until it resolves. Checking Task.IsCompleted right
    // after InvokeAsync (before awaiting) is what tells the two apart — EventCallback.InvokeAsync
    // runs the handler synchronously up to its first real await, same as any Task-returning method.
    async Task ConfirmAsync()
    {
        if (_confirmLoading) return; // a second click/Enter while already pending is a no-op
        if (!OnConfirm.HasDelegate)
        {
            await SetOpenAsync(false);
            return;
        }

        var task = OnConfirm.InvokeAsync();
        if (task.IsCompleted)
        {
            await SetOpenAsync(false);
            await task; // observe/propagate a synchronous exception, same as before this feature
            return;
        }

        _confirmLoading = true;
        StateHasChanged();
        try
        {
            await task;
            await SetOpenAsync(false);
        }
        catch
        {
            await SetOpenAsync(false); // close before rethrowing -- never left open on failure
            throw;                     // never swallowed
        }
        finally
        {
            _confirmLoading = false;
        }
    }

    async Task CancelAsync()
    {
        // Pending-confirm lock: while a genuinely pending OnConfirm has both buttons disabled and a
        // spinner running, Escape (routed here via OnPanelKeyDown) and the Cancel button (already
        // `disabled` in markup, but guarded here too for a programmatic/test dispatch) wait/no-op
        // instead of closing and firing OnCancel while OnConfirm keeps running unobserved. The popup
        // closes itself -- via ConfirmAsync's own SetOpenAsync(false) -- once the task settles.
        if (_confirmLoading) return;
        await SetOpenAsync(false);
        if (OnCancel.HasDelegate) await OnCancel.InvokeAsync();
    }

    // Controlled Visible/VisibleChanged, mirroring Select's controlled Open/OpenChanged design
    // (see SelectControlledOpenTests for the pattern this is copied from). Disabled invariant
    // enforced first and unconditionally, so it also catches a Disabled flip on an already-open
    // popup regardless of control mode.
    protected override async Task OnParametersSetAsync()
    {
        if (Disabled && _open && !_confirmLoading)
        {
            await SetOpenAsync(false); // close through the normal path so VisibleChanged fires
        }

        if (!VisibleChanged.HasDelegate)
        {
            // Uncontrolled (the default): Visible is inert. Reset so a consumer that later wires
            // VisibleChanged starts a fresh controlled session instead of comparing against a stale value.
            _lastVisibleParam = null;
            return;
        }

        if (_lastVisibleParam == Visible) return; // unchanged since we last observed/raised it (includes our own echo)

        if (Disabled)
        {
            // Ignore an external Visible=true request while disabled (the close above already
            // handled an external Visible=false against an open popup -- nothing further to do).
            // Deliberately NOT recorded into _lastVisibleParam: this request was suppressed, not
            // observed/honored, so it must still read as "new" once Disabled clears -- otherwise a
            // consumer holding Visible=true the whole time through a Disabled episode would compare
            // equal against this stale recording when Disabled clears and never reopen.
            return;
        }

        if (_confirmLoading)
        {
            // A pending OnConfirm holds the popup open regardless of external intent (mirrors the
            // Escape/backdrop lock in CancelAsync/CloseAsync) -- an external Visible=false here would
            // otherwise close the popup out from under the in-flight task. Not recorded for the same
            // reason as the Disabled branch above: ConfirmAsync's own SetOpenAsync(false) once the
            // task resolves raises VisibleChanged and re-syncs _lastVisibleParam correctly on its own.
            return;
        }

        _lastVisibleParam = Visible;
        if (Visible == _open) return; // already in the requested state
        await SetOpenAsync(Visible);
    }

    // After the panel opens, nudge it to stay within the viewport (flip/shift). Degrades to the
    // default CSS placement when JS isn't available (server prerender, unit tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mirror the popup ARIA onto the real trigger element (aria-expanded tracks _open; the popup
        // ARIA drops off and the child is marked aria-disabled while Disabled). syncTrigger re-resolves
        // the child on every call, so we only invoke it on the first render or when (_open, Disabled)
        // changes — skipping the interop otherwise keeps a per-row Popconfirm cheap on re-render.
        var pair = (_open, Disabled);
        if (firstRender || _lastSyncedTrigger != pair)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", JsModuleUrl.Resolve(FormDefaults, "wss-overlay.js"));
                if (_disposed)
                {
                    // Disposed while the import was in flight — DisposeAsync already ran with a null
                    // module, so this reference is ours to clean up.
                    try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
                    _module = null;
                    return;
                }
                await _module.InvokeVoidAsync("syncTrigger", _triggerRef, _open, Disabled);
                _lastSyncedTrigger = pair; // cache only on success, so a no-JS render retries next time
            }
            catch { /* no JS — a button child still toggles via its bubbled click; plain content is mouse-only */ }
        }

        if (_open && !_positioned)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", JsModuleUrl.Resolve(FormDefaults, "wss-overlay.js"));
                if (_disposed)
                {
                    try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
                    _module = null;
                    return;
                }
                _resolvedPlacement = await _module.InvokeAsync<string>("place", _triggerRef, _panelRef, "wss-popconfirm", PlacementName, 10, 8);
            }
            catch
            {
                // No JS runtime / module — keep the CSS default placement.
            }
            _positioned = true;
            _pendingFocus = true;
            StateHasChanged(); // reveal the panel now that it's positioned (drops wss-measuring)
        }
        else if (_open && _pendingFocus)
        {
            // Focus the primary action so keyboard / screen-reader users land inside the dialog.
            _pendingFocus = false;
            try { await _okButtonRef.FocusAsync(); } catch { /* not focusable yet (prerender/tests) */ }
        }
        else if (!_open && _positioned)
        {
            _positioned = false;
            _resolvedPlacement = null; // re-measure on the next open
            // Restore focus to the real trigger (the interactive child, or the promoted wrapper).
            try
            {
                if (_module is not null) await _module.InvokeVoidAsync("focusTrigger", _triggerRef);
                else await _triggerRef.FocusAsync();
            }
            catch { /* no JS / element gone */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
            _module = null;
        }
    }
}
