@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

<span class="wss-popconfirm-wrap">
    @* The consumer's ChildContent normally holds the interactive trigger (e.g. a <button>): its
       native activation bubbles here as a click, so this wrapper carries no button semantics of its
       own (it used to be role="button", nesting a button inside a button — two tab stops, invalid
       ARIA). wss-overlay.js mirrors the popup ARIA onto that child (skipped while Disabled), or
       promotes this span to the button role when the content has nothing focusable. *@
    <span class="wss-popconfirm-trigger" @ref="_triggerRef"
          @onclick="Toggle" @onkeydown="OnTriggerKeyDown" @onkeydown:stopPropagation="@_open">@ChildContent</span>
    @if (_open)
    {
        <div class="wss-popconfirm-backdrop" @onclick="Close"></div>
        <div class="wss-popconfirm wss-popconfirm-@(_resolvedPlacement ?? PlacementName) @(_positioned ? null : "wss-measuring")"
             @ref="_panelRef" role="dialog" aria-labelledby="@(HasTitle ? $"{_id}-title" : null)"
             aria-label="@(HasTitle ? null : AriaLabel)"
             @onkeydown="OnPanelKeyDown"
             @onkeydown:stopPropagation="true"
             @onclick:stopPropagation="true">
            <div class="wss-popconfirm-inner">
                <div class="wss-popconfirm-message">
                    <span class="wss-popconfirm-icon">
                        <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48.01 48.01 0 010-96 48.01 48.01 0 010 96z"/></svg>
                    </span>
                    @if (HasTitle)
                    {
                        <div class="wss-popconfirm-title" id="@($"{_id}-title")">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                    }
                </div>
                <div class="wss-popconfirm-buttons">
                    <button type="button" class="wss-dialog-btn wss-dialog-btn-sm" @onclick="CancelAsync">@CancelText</button>
                    <button type="button" @ref="_okButtonRef" class="wss-dialog-btn wss-dialog-btn-sm wss-dialog-btn-primary" @onclick="ConfirmAsync">@OkText</button>
                </div>
            </div>
            <span class="wss-popconfirm-arrow"></span>
        </div>
    }
</span>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string OkText { get; set; } = "OK";
    [Parameter] public string CancelText { get; set; } = "Cancel";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public PopupPlacement Placement { get; set; } = PopupPlacement.Top;
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    ElementReference _triggerRef;
    ElementReference _panelRef;
    ElementReference _okButtonRef;
    IJSObjectReference? _module;
    bool _open;
    bool _positioned;
    bool _pendingFocus;
    // Side the panel actually rendered on after the viewport flip. Null until measured (falls back to
    // the preferred PlacementName). Owned by C# so the re-render that drops `wss-measuring` keeps it.
    string? _resolvedPlacement;
    readonly string _id = $"wss-popconfirm-{Guid.NewGuid():N}";

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    void Toggle()
    {
        if (Disabled) return;
        _open = !_open;
    }

    void Close() => _open = false;

    // Escape only: Enter/Space activation comes from the child's native click (or the JS fallback
    // synthesizing one for plain content) bubbling into @onclick — handling the keys here as well
    // would double-toggle when a button child's keystroke both clicks and bubbles.
    void OnTriggerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    // Escape from inside the panel cancels — the panel is a sibling of the trigger, so its keydown
    // never bubbles to the trigger's handler.
    async Task OnPanelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CancelAsync();
    }

    async Task ConfirmAsync()
    {
        _open = false;
        if (OnConfirm.HasDelegate) await OnConfirm.InvokeAsync();
    }

    async Task CancelAsync()
    {
        _open = false;
        if (OnCancel.HasDelegate) await OnCancel.InvokeAsync();
    }

    // After the panel opens, nudge it to stay within the viewport (flip/shift). Degrades to the
    // default CSS placement when JS isn't available (server prerender, unit tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Every render, not just the first: aria-expanded on the real trigger element must track
        // _open, and the popup ARIA drops off entirely while Disabled.
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
            await _module.InvokeVoidAsync("syncTrigger", _triggerRef, _open, Disabled);
        }
        catch { /* no JS — a button child still toggles via its bubbled click; plain content is mouse-only */ }

        if (_open && !_positioned)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                _resolvedPlacement = await _module.InvokeAsync<string>("place", _triggerRef, _panelRef, "wss-popconfirm", PlacementName, 10, 8);
            }
            catch
            {
                // No JS runtime / module — keep the CSS default placement.
            }
            _positioned = true;
            _pendingFocus = true;
            StateHasChanged(); // reveal the panel now that it's positioned (drops wss-measuring)
        }
        else if (_open && _pendingFocus)
        {
            // Focus the primary action so keyboard / screen-reader users land inside the dialog.
            _pendingFocus = false;
            try { await _okButtonRef.FocusAsync(); } catch { /* not focusable yet (prerender/tests) */ }
        }
        else if (!_open && _positioned)
        {
            _positioned = false;
            _resolvedPlacement = null; // re-measure on the next open
            // Restore focus to the real trigger (the interactive child, or the promoted wrapper).
            try
            {
                if (_module is not null) await _module.InvokeVoidAsync("focusTrigger", _triggerRef);
                else await _triggerRef.FocusAsync();
            }
            catch { /* no JS / element gone */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
            _module = null;
        }
    }
}
