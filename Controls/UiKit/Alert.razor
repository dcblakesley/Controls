@namespace Controls

@if (!_closed)
{
<div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
     class="wss-alert wss-alert-@TypeName @(HasDescription ? "wss-alert-with-description" : null) @(Banner ? "wss-alert-banner" : null) @AttributeSplat.ConsumerClass(AdditionalAttributes)"
     style="@AttributeSplat.MergeStyle(null, AdditionalAttributes)"
     role="@(EffectiveType == AlertType.Error ? "alert" : "status")"
     aria-live="@(EffectiveType == AlertType.Error ? "assertive" : "polite")">
    @if (ShowIcon)
    {
        <span class="wss-alert-icon">@Icon</span>
    }
    <div class="wss-alert-content">
        <div class="wss-alert-message">@(MessageContent ?? (RenderFragment)(b => b.AddContent(0, Message)))</div>
        @if (HasDescription)
        {
            <div class="wss-alert-description">@Description</div>
        }
    </div>
    @if (Action is not null)
    {
        <div class="wss-alert-actions">
            <span class="wss-alert-action">@Action</span>
            @if (Closable)
            {
                <button type="button" class="wss-alert-close" aria-label="Close" @onclick="OnCloseClicked">
                    <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
                </button>
            }
        </div>
    }
    else if (Closable)
    {
        <button type="button" class="wss-alert-close" aria-label="Close" @onclick="OnCloseClicked">
            <svg viewBox="64 64 896 896" width="1em" height="1em" fill="currentColor" aria-hidden="true"><path d="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.8 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 00203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z"/></svg>
        </button>
    }
</div>
}

@code {
    /// <summary>
    /// Severity of the alert (colors, icon, and screen-reader politeness — <see cref="AlertType.Error"/>
    /// announces assertively). Defaults to <see cref="AlertType.Info"/> — except in <see cref="Banner"/>
    /// mode, where a Type left unset resolves to <see cref="AlertType.Warning"/> instead (see
    /// <see cref="EffectiveType"/>), matching AntD's banner default; a Type set explicitly (even to
    /// <see cref="AlertType.Info"/>) is always honored.
    /// </summary>
    [Parameter] public AlertType Type { get; set; } = AlertType.Info;
    /// <summary>Plain-text message line.</summary>
    [Parameter] public string? Message { get; set; }
    /// <summary>Optional rich message content; overrides <see cref="Message"/> when set.</summary>
    [Parameter] public RenderFragment? MessageContent { get; set; }
    /// <summary>Optional detail text rendered below the message (switches to the larger "with description" layout).</summary>
    [Parameter] public string? Description { get; set; }
    /// <summary>Shows the severity icon. Defaults to true.</summary>
    [Parameter] public bool ShowIcon { get; set; } = true;
    /// <summary>Shows a close button that hides the alert.</summary>
    [Parameter] public bool Closable { get; set; }
    /// <summary>Raised after the close button hides the alert (a notification — the alert hides itself regardless).</summary>
    [Parameter] public EventCallback OnClose { get; set; }
    /// <summary>Full-width, borderless/no-radius banner mode (AntD's <c>Alert banner</c>). See
    /// <see cref="Type"/> for how the default severity resolves while this is true.</summary>
    [Parameter] public bool Banner { get; set; }
    /// <summary>Optional trailing action slot rendered before the close button — grouped with it in a
    /// <c>wss-alert-actions</c> wrapper only when set (unset markup is unchanged).</summary>
    [Parameter] public RenderFragment? Action { get; set; }

    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the component's root element. <c>class</c> and <c>style</c> merge with the
    /// component's own; the rest are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    // Component parameters must stay plain auto-properties (BL0007), so the "was Type explicitly
    // passed" check lives here instead of in Type's own setter: SetParametersAsync sees the raw
    // incoming ParameterView (keyed by the consumer's actual markup) before base assigns Type, so
    // this is only true when the CURRENT render's parent markup includes Type="...".
    bool _typeSet;

    public override Task SetParametersAsync(ParameterView parameters)
    {
        _typeSet = parameters.TryGetValue<AlertType>(nameof(Type), out _);
        return base.SetParametersAsync(parameters);
    }

    /// <summary>The severity actually used for styling/icon/ARIA — see <see cref="Type"/>.</summary>
    AlertType EffectiveType => !_typeSet && Banner ? AlertType.Warning : Type;

    bool HasDescription => !string.IsNullOrEmpty(Description);
    string TypeName => EffectiveType.ToString().ToLowerInvariant();

    RenderFragment Icon => EffectiveType switch
    {
        AlertType.Success => Svg("M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm193.5 301.7l-210.6 292a31.8 31.8 0 01-51.7 0L318.5 484.9c-3.8-5.3 0-12.7 6.5-12.7h46.9c10.2 0 19.9 4.9 25.9 13.3l71.2 98.8 157.2-218c6-8.3 15.6-13.3 25.9-13.3H699c6.5 0 10.3 7.4 6.5 12.7z"),
        AlertType.Warning => Svg("M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48.01 48.01 0 010-96 48.01 48.01 0 010 96z"),
        AlertType.Error => Svg("M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm165.4 618.2l-66-.3L512 563.4l-99.3 118.4-66.1.3c-4.4 0-8-3.5-8-8 0-1.9.7-3.7 1.9-5.2l130.1-155L340.5 359a8.32 8.32 0 01-1.9-5.2c0-4.4 3.6-8 8-8l66.1.3L512 464.6l99.3-118.4 66-.3c4.4 0 8 3.5 8 8 0 1.9-.7 3.7-1.9 5.2L553.5 514l130 155c1.2 1.5 1.9 3.3 1.9 5.2 0 4.4-3.6 8-8 8z"),
        _ => Svg("M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm32 664c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V456c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272zm-32-344a48.01 48.01 0 010-96 48.01 48.01 0 010 96z"),
    };

    // `path` MUST stay a compile-time literal — AddMarkupContent emits it unencoded. Every caller
    // passes a constant icon path; never route a parameter or model value through here (XSS).
    static RenderFragment Svg(string path) => b =>
        b.AddMarkupContent(0, $"<svg viewBox=\"64 64 896 896\" width=\"1em\" height=\"1em\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"{path}\"/></svg>");

    bool _closed;

    // Closing hides the alert itself (matching AntD) — OnClose is a notification, not a
    // requirement, so a Closable alert without a handler no longer renders a dead button.
    async Task OnCloseClicked()
    {
        _closed = true;
        if (OnClose.HasDelegate) await OnClose.InvokeAsync();
    }
}
