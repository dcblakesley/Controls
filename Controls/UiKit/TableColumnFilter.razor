@namespace Controls
@typeparam TItem
@implements IAsyncDisposable
@inject IJSRuntime JS

@* Column filtering (Column.FilterOptions/OnFilter): a funnel-icon button in the header cell that
   opens a checkbox/radio dropdown. Outside-click-to-close is a full-screen invisible backdrop --
   the same JS-free pattern Popover/Select already use -- so open/close/apply/reset all work with
   no JS runtime at all (server prerender, unit tests). JS is opt-in and only ever used to escape a
   ScrollY wrapper's overflow clip (see OnAfterRenderAsync) and to move focus into/out of the panel. *@
@if (Column.CanFilter)
{
    <button type="button" @ref="_buttonRef"
            class="wss-table-filter-trigger @(Column.FilterApplied.Count > 0 ? "wss-table-filter-active" : null)"
            aria-label="@FilterAriaLabel" aria-expanded="@(Column.FilterOpen ? "true" : "false")"
            @onclick="ToggleOpen" @onclick:stopPropagation="true">
        @FilterIcon
    </button>
    @if (Column.FilterOpen)
    {
        @* tabindex="-1": see .wss-select-backdrop -- iOS-class WebKit only synthesizes a click from a
           tap on a focusable/interactive target chain, so a bare div would never receive the tap. *@
        <div class="wss-table-filter-backdrop" tabindex="-1" @onclick="Close"></div>
        <div class="wss-table-filter-dropdown" @ref="_panelRef" role="dialog" aria-label="@FilterAriaLabel"
             tabindex="-1" @onkeydown="OnKeyDown" @onkeydown:stopPropagation="true" @onclick:stopPropagation="true">
            <ul class="wss-table-filter-list">
                @foreach (var opt in Column.FilterOptions!)
                {
                    <li class="wss-table-filter-item">
                        <label class="wss-table-filter-option-label">
                            @if (Column.FilterMultiple)
                            {
                                <input type="checkbox" class="wss-table-filter-checkbox"
                                       checked="@Column.FilterPending.Contains(opt.Value)"
                                       @onchange="@(e => ToggleValue(opt.Value, e.Value is true))" />
                            }
                            else
                            {
                                <input type="radio" class="wss-table-filter-radio" name="@_radioGroupName"
                                       checked="@Column.FilterPending.Contains(opt.Value)"
                                       @onchange="@(() => SelectSingle(opt.Value))" />
                            }
                            <span>@opt.Text</span>
                        </label>
                    </li>
                }
            </ul>
            <div class="wss-table-filter-footer">
                <button type="button" class="wss-table-filter-reset" @onclick="Reset">@ResetLabel</button>
                <button type="button" class="wss-table-filter-ok" @onclick="Apply">@OkLabel</button>
            </div>
        </div>
    }
}

@code {
    /// <summary>The column this control filters. Required.</summary>
    [Parameter, EditorRequired] public Column<TItem> Column { get; set; } = default!;

    /// <summary>Accessible-name format for the filter button; <c>{0}</c> is the column's header
    /// text. Forwarded from <see cref="Table{TItem}.FilterButtonLabelFormat"/>.</summary>
    [Parameter] public string FilterButtonLabelFormat { get; set; } = "Filter {0}";

    /// <summary>Label of the dropdown's clear-this-column button. Forwarded from
    /// <see cref="Table{TItem}.FilterResetLabel"/>.</summary>
    [Parameter] public string ResetLabel { get; set; } = "Reset";

    /// <summary>Label of the dropdown's apply button. Forwarded from
    /// <see cref="Table{TItem}.FilterOkLabel"/>.</summary>
    [Parameter] public string OkLabel { get; set; } = "OK";

    // Explicit parameter, not [CascadingParameter]: Table's own `<CascadingValue Value="this">`
    // wraps only its ChildContent (where Column<TItem> instances self-register) -- the <thead>
    // markup that instantiates this component is a sibling of that CascadingValue in Table's render
    // tree, not a descendant of it, so it would never resolve here.
    [Parameter, EditorRequired] public Table<TItem> Table { get; set; } = default!;

    [CascadingParameter] FormDefaults? FormDefaults { get; set; }

    ElementReference _buttonRef;
    ElementReference _panelRef;
    IJSObjectReference? _module;
    bool _pendingFocus;
    bool _wasOpen;
    bool _fixedPositioned;
    bool _disposed;
    readonly string _radioGroupName = $"wss-table-filter-{Guid.NewGuid():N}";

    // AntD "FilterFilled" -- a solid funnel. Recolored (not reshaped) for the active state, the same
    // technique the sort carets already use (.wss-table-sorter-up/-down + wss-table-sorter-active).
    static readonly MarkupString FilterIcon = new(
        "<svg viewBox=\"64 64 896 896\" width=\"1em\" height=\"1em\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M880.1 154H143.9c-24.5 0-39.8 26.7-27.5 48L349 597.4V838c0 17.7 14.2 32 31.8 32h262.4c17.6 0 31.8-14.3 31.8-32V597.4L907.7 202c12.2-21.3-3.1-48-27.6-48z\"/></svg>");

    // Mirrors Column.SortButtonLabel's title-less fallback -- a headerless column's filter button
    // still needs an accessible name.
    string FilterAriaLabel =>
        string.IsNullOrEmpty(Column.HeaderText) ? "Filter" : string.Format(FilterButtonLabelFormat, Column.HeaderText);

    void ToggleOpen()
    {
        if (Column.FilterOpen)
        {
            Close();
            return;
        }
        Table.OpenColumnFilter(Column);
        _pendingFocus = true;
    }

    void Close() => Table.CloseColumnFilter(Column);

    void ToggleValue(string value, bool on)
    {
        if (on) Column.FilterPending.Add(value);
        else Column.FilterPending.Remove(value);
    }

    void SelectSingle(string value)
    {
        Column.FilterPending.Clear();
        Column.FilterPending.Add(value);
    }

    async Task Apply() => await Table.ApplyColumnFilterAsync(Column);

    async Task Reset() => await Table.ResetColumnFilterAsync(Column);

    void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    // Focus management (mirrors Popover): move focus into the panel once it opens, and back to the
    // trigger once it closes. The fixed-positioning escape only runs under Table.ScrollY -- the
    // default (unset) case never touches JS, matching the "JS-free by default" contract above.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;

        if (Column.FilterOpen)
        {
            _wasOpen = true;
            if (_pendingFocus)
            {
                _pendingFocus = false;
                try { await _panelRef.FocusAsync(); } catch { /* not focusable yet (prerender/tests) */ }
            }

            if (Table.ScrollY is not null && !_fixedPositioned)
            {
                try
                {
                    _module ??= await JS.InvokeAsync<IJSObjectReference>(
                        "import", JsModuleUrl.Resolve(FormDefaults, "wss-overlay.js"));
                    if (_disposed)
                    {
                        try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
                        _module = null;
                        return;
                    }
                    await _module.InvokeVoidAsync("placeFixedBelow", _buttonRef, _panelRef, 4);
                    _fixedPositioned = true;
                }
                catch
                {
                    // No JS runtime / module -- the CSS-anchored absolute position stays (may clip
                    // under a ScrollY wrapper's overflow; this is the documented no-JS fallback).
                }
            }
        }
        else if (_wasOpen)
        {
            _wasOpen = false;
            _fixedPositioned = false; // the dropdown node is destroyed on close; a fresh one re-measures next open
            try { await _buttonRef.FocusAsync(); } catch { /* not focusable / gone */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
            _module = null;
        }
    }
}
