@namespace Controls
@typeparam TItem
@implements IAsyncDisposable
@inject IJSRuntime JS

@* Reset the per-render column buffer before the columns below register into it (they do so in
   document order during their OnParametersSet); OnAfterRender then promotes the buffer to the
   rendered set. This is what lets a conditionally-rendered column drop / reappear in its declared
   position instead of leaving a zombie or a duplicate. *@
@{ StartCollectingColumns(); }
<CascadingValue Value="this" IsFixed="true">
    @ChildContent
</CascadingValue>

@* Single root block so the table + pager don't pick up extra spacing from a parent's
   flex/grid gap stacking on top of the pager's own margin. It's also the positioning context for
   the Loading mask below (see .wss-table-root in wss-controls.css) so the mask covers the pagers
   too, not just the body -- AntD's Spin wraps the whole table+pagination area, not just the rows. *@
<div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
     class="wss-table-root @AttributeSplat.ConsumerClass(AdditionalAttributes)"
     style="@AttributeSplat.MergeStyle(null, AdditionalAttributes)"
     aria-busy="@(Loading ? "true" : null)">
@if (Loading)
{
    @* inset:0 against .wss-table-root (not .wss-table-wrapper) so this spans both pagers plus the
       body -- a click anywhere in that area hits this element (it renders on top via z-index),
       never the pager/body controls beneath it. *@
    <div class="wss-table-loading-mask" aria-hidden="true">
        <span class="wss-table-loading-spinner">@LoadingIcon</span>
    </div>
}
@if (ShowTopPager)
{
    <div class="wss-table-pagination wss-table-pagination-top wss-table-pagination-@PagerAlignName">
        <Pagination Total="_filtered.Count" PageSize="_pageSize" Current="_page" CurrentChanged="OnPageChange"
                    ShowTotal="ShowTotal" PageSizeOptions="PageSizeOptions" PageSizeChanged="OnPageSizeChange"
                    AriaLabel="@(PagerPosition == PagerPosition.Both ? "Pagination (top)" : "Pagination")" />
    </div>
}
<div class="wss-table-wrapper @(ScrollY is not null ? "wss-table-wrapper-scroll-y" : null)"
     style="@(ScrollY is not null ? $"max-height:{ScrollY};" : null)">
    <table class="wss-table @(Bordered ? "wss-table-bordered" : null) wss-table-@SizeName @(AnyColumnEllipsis ? "wss-table-fixed" : null)">
        @if (!string.IsNullOrEmpty(Caption))
        {
            <caption class="wss-table-caption">@Caption</caption>
        }
        <thead class="wss-table-thead">
            <tr>
                @if (HasRowDetail)
                {
                    @* Header slot above the expand-chevron column (first, per the Clark spec). *@
                    <th scope="col" class="wss-table-cell wss-table-expand-cell"></th>
                }
                @if (Selectable)
                {
                    @* Single mode has no "select all" concept for an exclusive choice -- the empty
                       cell just keeps column alignment with the body's radio cells. *@
                    <th scope="col" class="wss-table-cell wss-table-selection-cell">
                        @if (SelectionMode == SelectionMode.Multiple)
                        {
                            @* The label matches the actual scope: ToggleAll only affects the current page. *@
                            @if (EffectiveUseStyledCheckbox)
                            {
                                <span class="wss-table-checkbox-wrap">
                                    <input type="checkbox" class="wss-table-checkbox wss-table-checkbox-input-styled"
                                           aria-label="@(IsPaged ? "Select all rows on this page" : "Select all rows")"
                                           checked="@_allSelected" disabled="@_headerSelectAllDisabled"
                                           @ref="_selectAllRef" @onchange="@(e => ToggleAll(e.Value is true))" />
                                    <span class="wss-table-checkbox-box" aria-hidden="true"></span>
                                </span>
                            }
                            else
                            {
                                <input type="checkbox" class="wss-table-checkbox"
                                       aria-label="@(IsPaged ? "Select all rows on this page" : "Select all rows")"
                                       checked="@_allSelected" disabled="@_headerSelectAllDisabled"
                                       @ref="_selectAllRef" @onchange="@(e => ToggleAll(e.Value is true))" />
                            }
                        }
                    </th>
                }
                @* @key="col" (on every branch's <th> below): without it, Blazor's diff matches this
                   loop's output POSITIONALLY across renders -- reordering/removing a column could
                   reassign one column's rendered <th> (and its live TableColumnFilter/open-dropdown
                   state) onto a DIFFERENT column instead of moving with its own column. *@
                @foreach (var col in _columns)
                {
                    @if (col.CanSort)
                    {
                        <th scope="col" @key="col" class="wss-table-cell wss-table-cell-sortable @(IsSortActive(col) ? "wss-table-cell-sort-active" : null) @(col.FilterOpen ? "wss-table-cell-filter-open" : null)" aria-sort="@AriaSortFor(col)">
                            @if (col.TitleContent is null)
                            {
                                @* col.CanFilter forks into its own branch (rather than always wrapping in
                                   wss-table-header-inner) so the overwhelmingly common non-filterable case keeps
                                   the exact original single-<button> DOM -- an existing bUnit test pins that shape. *@
                                @if (col.CanFilter)
                                {
                                    <div class="wss-table-header-inner">
                                        <button type="button" class="wss-table-sort-trigger" aria-label="@SortButtonLabel(col)" @onclick="@(() => ToggleSort(col))">
                                            <span class="wss-table-sort-label">@col.HeaderFor()</span>
                                            <span class="wss-table-sorter" aria-hidden="true">
                                                <span class="wss-table-sorter-up @(IsActive(col, SortDirection.Ascending) ? "wss-table-sorter-active" : null)"></span>
                                                <span class="wss-table-sorter-down @(IsActive(col, SortDirection.Descending) ? "wss-table-sorter-active" : null)"></span>
                                            </span>
                                        </button>
                                        <TableColumnFilter TItem="TItem" Column="col" Table="this"
                                                            FilterButtonLabelFormat="@FilterButtonLabelFormat"
                                                            ResetLabel="@FilterResetLabel" OkLabel="@FilterOkLabel" />
                                    </div>
                                }
                                else
                                {
                                    <button type="button" class="wss-table-sort-trigger" aria-label="@SortButtonLabel(col)" @onclick="@(() => ToggleSort(col))">
                                        <span class="wss-table-sort-label">@col.HeaderFor()</span>
                                        <span class="wss-table-sorter" aria-hidden="true">
                                            <span class="wss-table-sorter-up @(IsActive(col, SortDirection.Ascending) ? "wss-table-sorter-active" : null)"></span>
                                            <span class="wss-table-sorter-down @(IsActive(col, SortDirection.Descending) ? "wss-table-sorter-active" : null)"></span>
                                        </span>
                                    </button>
                                }
                            }
                            else
                            {
                                @* A templated header may contain its own interactive content (e.g. a LabelTooltip's
                                   <button>), so it can't render inside the sort <button> — nested buttons are invalid
                                   HTML, and the template's clicks would bubble into ToggleSort. Split into a flex row
                                   instead: a plain (non-focusable) clickable content area preserves "click the header
                                   to sort", and the button carries only the caret glyphs plus its own accessible name
                                   (the button has no visible content of its own here). This div already renders
                                   unconditionally here, so the filter control just joins it as one more child --
                                   no CanFilter fork needed in this branch. *@
                                <div class="wss-table-sort-header">
                                    <div class="wss-table-sort-content" @onclick="@(() => ToggleSort(col))">@col.HeaderFor()</div>
                                    <button type="button" class="wss-table-sort-trigger wss-table-sort-trigger-icon" aria-label="@SortButtonLabel(col)" @onclick="@(() => ToggleSort(col))">
                                        <span class="wss-table-sorter" aria-hidden="true">
                                            <span class="wss-table-sorter-up @(IsActive(col, SortDirection.Ascending) ? "wss-table-sorter-active" : null)"></span>
                                            <span class="wss-table-sorter-down @(IsActive(col, SortDirection.Descending) ? "wss-table-sorter-active" : null)"></span>
                                        </span>
                                    </button>
                                    @if (col.CanFilter)
                                    {
                                        <TableColumnFilter TItem="TItem" Column="col" Table="this"
                                                            FilterButtonLabelFormat="@FilterButtonLabelFormat"
                                                            ResetLabel="@FilterResetLabel" OkLabel="@FilterOkLabel" />
                                    }
                                </div>
                            }
                        </th>
                    }
                    else
                    {
                        @if (col.CanFilter)
                        {
                            <th scope="col" @key="col" class="wss-table-cell @(col.FilterOpen ? "wss-table-cell-filter-open" : null)">
                                <div class="wss-table-header-inner">
                                    <span class="wss-table-header-text">@col.HeaderFor()</span>
                                    <TableColumnFilter TItem="TItem" Column="col" Table="this"
                                                        FilterButtonLabelFormat="@FilterButtonLabelFormat"
                                                        ResetLabel="@FilterResetLabel" OkLabel="@FilterOkLabel" />
                                </div>
                            </th>
                        }
                        else
                        {
                            <th scope="col" @key="col" class="wss-table-cell">@col.HeaderFor()</th>
                        }
                    }
                }
            </tr>
        </thead>
        <tbody class="wss-table-tbody">
            @if (_pageItems.Count == 0)
            {
                @* Not "_items.Count == 0": the placeholder must also show once a column filter
                   narrows every row out of view, not just when the DataSource itself is empty. Safe
                   against "a valid page that happens to be empty" -- the IsPaged clamp below keys off
                   _filtered.Count, so _pageItems is only ever empty when _filtered truly is. *@
                <tr class="wss-table-row wss-table-placeholder">
                    <td class="wss-table-cell" colspan="@TotalColumnCount">
                        @if (EmptyContent is not null) { @EmptyContent } else { @EmptyText }
                    </td>
                </tr>
            }
            else
            {
                @for (var rowIdx = 0; rowIdx < _pageItems.Count; rowIdx++)
                {
                    var item = _pageItems[rowIdx];
                    <tr class="wss-table-row @(IsSelected(item) ? "wss-table-row-selected" : null) @(RowIsClickable ? "wss-table-row-clickable" : null)"
                        @key="_pageKeys[rowIdx]" @onclick="@(() => OnRowClickedAsync(item))">
                        @if (HasRowDetail)
                        {
                            <td class="wss-table-cell wss-table-expand-cell" @onclick:stopPropagation="true">
                                <button type="button"
                                        class="wss-table-expand-btn @(IsExpanded(item) ? "wss-table-expand-btn-expanded" : null)"
                                        aria-expanded="@(IsExpanded(item) ? "true" : "false")"
                                        aria-label="@(IsExpanded(item) ? CollapseRowLabel : ExpandRowLabel)"
                                        @onclick="@(() => ToggleExpandAsync(item))">
                                    @ExpandChevron
                                </button>
                            </td>
                        }
                        @if (Selectable)
                        {
                            <td class="wss-table-cell wss-table-selection-cell" @onclick:stopPropagation="true">
                                @if (SelectionMode == SelectionMode.Multiple)
                                {
                                    @if (EffectiveUseStyledCheckbox)
                                    {
                                        <span class="wss-table-checkbox-wrap">
                                            <input type="checkbox" class="wss-table-checkbox wss-table-checkbox-input-styled" aria-label="Select row" checked="@IsSelected(item)"
                                                   disabled="@(!IsRowSelectableFor(item))"
                                                   @onchange="@(e => ToggleRow(item, e.Value is true))" />
                                            <span class="wss-table-checkbox-box" aria-hidden="true"></span>
                                        </span>
                                    }
                                    else
                                    {
                                        <input type="checkbox" class="wss-table-checkbox" aria-label="Select row" checked="@IsSelected(item)"
                                               disabled="@(!IsRowSelectableFor(item))"
                                               @onchange="@(e => ToggleRow(item, e.Value is true))" />
                                    }
                                }
                                else
                                {
                                    <input type="radio" class="wss-table-radio" name="@_radioGroupName" aria-label="Select row" checked="@IsSelected(item)"
                                           disabled="@(!IsRowSelectableFor(item))"
                                           @onchange="@(() => SelectSingleAsync(item))" />
                                }
                            </td>
                        }
                        @foreach (var col in _columns)
                        {
                            <td @key="col" class="wss-table-cell @(IsSortActive(col) ? "wss-table-cell-sort-active" : null) @(col.Ellipsis ? "wss-table-cell-ellipsis" : null)">@col.CellFor(item)</td>
                        }
                    </tr>
                    @if (HasRowDetail && IsExpanded(item))
                    {
                        @* Keyed alongside its parent row (same identity + a discriminator) so
                           re-orders keep each detail row glued to its row. *@
                        <tr class="wss-table-expanded-row" @key="@(("wss-detail", _pageKeys[rowIdx]))">
                            <td class="wss-table-cell wss-table-expanded-cell" colspan="@TotalColumnCount">@RowDetail!(item)</td>
                        </tr>
                    }
                }
            }
        </tbody>
        @if (FooterContent is not null)
        {
            <tfoot class="wss-table-tfoot">
                @FooterContent
            </tfoot>
        }
    </table>
</div>

@if (ShowBottomPager)
{
    <div class="wss-table-pagination wss-table-pagination-bottom wss-table-pagination-@PagerAlignName">
        <Pagination Total="_filtered.Count" PageSize="_pageSize" Current="_page" CurrentChanged="OnPageChange"
                    ShowTotal="ShowTotal" PageSizeOptions="PageSizeOptions" PageSizeChanged="OnPageSizeChange"
                    AriaLabel="@(PagerPosition == PagerPosition.Both ? "Pagination (bottom)" : "Pagination")" />
    </div>
}
</div>

@code {
    /// <summary>The rows to render. Treated as an immutable parameter: reassign a new collection to refresh — the Table only re-reads on a reference change, so mutating in place is not seen.</summary>
    [Parameter] public IEnumerable<TItem>? DataSource { get; set; }
    /// <summary>The column definitions: <see cref="Column{TItem}"/> / <c>PropertyColumn</c> / <c>ActionColumn</c> children (declarative metadata — they emit no markup of their own and may be conditionally rendered).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Draws borders around every cell (AntD "bordered" look) instead of row separators only.</summary>
    [Parameter] public bool Bordered { get; set; }
    /// <summary>Row density (cell padding). Defaults to <see cref="TableSize.Default"/>.</summary>
    [Parameter] public TableSize Size { get; set; } = TableSize.Default;
    /// <summary>Placeholder text shown when there are no rows. Defaults to "No data".</summary>
    [Parameter] public string EmptyText { get; set; } = "No data";

    /// <summary>
    /// Richer alternative to <see cref="EmptyText"/> for the no-rows placeholder; wins over
    /// <see cref="EmptyText"/> when set. Null (default) keeps the plain text.
    /// </summary>
    [Parameter] public RenderFragment? EmptyContent { get; set; }

    /// <summary>
    /// Shows a translucent mask + spinner over the whole component -- both pagers plus the table
    /// body -- while true (AntD's <c>Spin</c>-wrapped table) — rows stay rendered beneath it, the
    /// pagers become click-inert (the mask sits on top of them too), and <c>aria-busy="true"</c> is
    /// set on the <c>wss-table-root</c> element. Pure CSS/markup, no JS. Default false (no overlay —
    /// current DOM unchanged).
    /// </summary>
    [Parameter] public bool Loading { get; set; }

    /// <summary>
    /// Summary/footer row(s), rendered in a <c>&lt;tfoot&gt;</c> after the body — unaffected by
    /// paging/sorting (it isn't part of <c>DataSource</c>). The consumer supplies the full
    /// <c>&lt;tr&gt;</c>/<c>&lt;td&gt;</c> structure (and is responsible for its own <c>colspan</c> —
    /// the Table does not inject one). Null (default) renders no <c>&lt;tfoot&gt;</c>.
    /// </summary>
    [Parameter] public RenderFragment? FooterContent { get; set; }

    /// <summary>Optional accessible caption rendered above the table (also names it for screen readers).</summary>
    [Parameter] public string? Caption { get; set; }

    /// <summary>
    /// Rows per page; 0 (default) shows all rows without pagination. This is the INITIAL effective
    /// page size only when <see cref="PageSizeOptions"/>'s size-changer is in play — picking a
    /// different size there updates the table's own internal page size (see <see cref="_pageSize"/>)
    /// without requiring this parameter itself to be two-way bound; an explicit change to this
    /// parameter still always wins, discarding any prior size-changer pick.
    /// </summary>
    [Parameter] public int PageSize { get; set; }

    /// <summary>
    /// AntD's total-text ("1-10 of 200 items"), forwarded to the embedded <see cref="Pagination"/>
    /// (both pagers under <see cref="PagerPosition.Both"/>). Null (default) renders nothing.
    /// </summary>
    [Parameter] public Func<(int Start, int End, int Total), string>? ShowTotal { get; set; }

    /// <summary>
    /// Page-size options, forwarded to the embedded <see cref="Pagination"/>'s size-changer (both
    /// pagers under <see cref="PagerPosition.Both"/> share one selection). Null/empty (default)
    /// renders no size-changer. Picking a size re-slices the table (see <see cref="PageSize"/>) and
    /// re-clamps the current page the same way the standalone <see cref="Pagination"/> does; the
    /// selection (<see cref="_selected"/>) is keyed by <see cref="RowKey"/> identity, so it survives
    /// the re-slice untouched regardless of which page a selected row ends up on.
    /// </summary>
    [Parameter] public int[]? PageSizeOptions { get; set; }

    /// <summary>Horizontal alignment of the pager. Defaults to <see cref="PagerAlign.Right"/> (AntD default).</summary>
    [Parameter] public PagerAlign PagerAlign { get; set; } = PagerAlign.Right;

    /// <summary>Whether the pager renders above, below, or both above and below the table. Defaults to <see cref="PagerPosition.Bottom"/>.</summary>
    [Parameter] public PagerPosition PagerPosition { get; set; } = PagerPosition.Bottom;

    /// <summary>Adds a checkbox column for row selection, plus a header checkbox that toggles the current page.</summary>
    [Parameter] public bool Selectable { get; set; }

    /// <summary>
    /// Per-row selection predicate; null (default) means every row is selectable. A row for which
    /// this returns false renders its selection checkbox/radio <c>disabled</c> and is excluded from
    /// the header "select all" — both which rows it toggles and the indeterminate/all-selected math
    /// count only selectable rows on the page.
    /// </summary>
    [Parameter] public Func<TItem, bool>? IsRowSelectable { get; set; }

    /// <summary>
    /// <see cref="Controls.SelectionMode.Multiple"/> (default) renders the existing checkbox column
    /// (header select-all + per-row checkboxes, 0-or-more <see cref="SelectedItems"/>).
    /// <see cref="Controls.SelectionMode.Single"/> renders radio-semantics selection instead (one
    /// native <c>&lt;input type="radio"&gt;</c> per row, sharing one group so picking a row
    /// deselects any other; at most one item in <see cref="SelectedItems"/>) and the header cell
    /// renders empty — no select-all makes sense for an exclusive choice — kept only to preserve
    /// column alignment. <see cref="SelectedItems"/>/<see cref="SelectedItemsChanged"/> are unchanged
    /// either way.
    /// </summary>
    [Parameter] public SelectionMode SelectionMode { get; set; } = SelectionMode.Multiple;

    /// <summary>
    /// Expandable rows: when set, every row gets a leading expand-chevron column that toggles this
    /// detail template, rendered as a full-width row directly beneath it (e.g. a nested child
    /// <see cref="Table{TItem}"/>). Expansion state is keyed by <see cref="RowKey"/> identity, so
    /// it survives paging and sorting; rows that leave the data are forgotten.
    /// </summary>
    [Parameter] public RenderFragment<TItem>? RowDetail { get; set; }

    /// <summary>
    /// Optionally-controlled expansion, layered over the internal (uncontrolled-by-default)
    /// expansion set: keys (per <see cref="RowKey"/>, or the item itself when unset) of the rows
    /// that should render expanded. Reassign a new collection to drive expansion from the parent —
    /// like <see cref="SelectedItems"/>, the Table only re-syncs on a reference change, and every
    /// toggle (chevron click or <see cref="ExpandRowByClick"/>) still raises
    /// <see cref="ExpandedRowKeysChanged"/> even when this is left null (uncontrolled).
    /// </summary>
    [Parameter] public IEnumerable<object>? ExpandedRowKeys { get; set; }

    /// <summary>Raised with the full current set of expanded row keys after every toggle. Supports <c>@@bind-ExpandedRowKeys</c>.</summary>
    [Parameter] public EventCallback<IEnumerable<object>> ExpandedRowKeysChanged { get; set; }

    /// <summary>Raised with the toggled row and its new expanded state after every expand/collapse.</summary>
    [Parameter] public EventCallback<(TItem Item, bool Expanded)> OnExpand { get; set; }

    /// <summary>
    /// When true (and <see cref="RowDetail"/> is set), clicking anywhere on a row — other than the
    /// selection checkbox/radio, the expand chevron, or inside an <see cref="ActionColumn{TItem}"/>
    /// cell, all of which stop propagation — toggles that row's expansion, the same toggle the
    /// chevron button performs. Composes with <see cref="OnRowClick"/>: both fire from the same click.
    /// </summary>
    [Parameter] public bool ExpandRowByClick { get; set; }

    /// <summary>
    /// Raised when a row is clicked (same propagation guards as <see cref="ExpandRowByClick"/> —
    /// excludes the selection checkbox/radio, the expand chevron, and <see cref="ActionColumn{TItem}"/>
    /// cells). Always raised regardless of <see cref="ExpandRowByClick"/>; when both are set, a click
    /// also toggles that row's expansion.
    /// </summary>
    [Parameter] public EventCallback<TItem> OnRowClick { get; set; }

    /// <summary>Accessible name of a collapsed row's expand button. Override to localize.</summary>
    [Parameter] public string ExpandRowLabel { get; set; } = "Expand row";

    /// <summary>Accessible name of an expanded row's collapse button. Override to localize.</summary>
    [Parameter] public string CollapseRowLabel { get; set; } = "Collapse row";

    /// <summary>
    /// When true, the header and row selection checkboxes render with a custom-drawn box (hidden
    /// native input + a sibling element that draws the visual state, including the indeterminate
    /// "mixed" glyph) instead of the bare native checkbox — the UI-kit analogue of
    /// <c>EditBool.UseStyledCheckbox</c>. Null (default) falls through to any enclosing
    /// <see cref="Controls.FormDefaults"/> (set this once for a whole app or MFE), then
    /// <see cref="FormOptions.DefaultUseStyledCheckbox"/>. Table has no <see cref="FormOptions"/> of
    /// its own, so that tier of the Edit* controls' resolution chain doesn't apply here.
    /// </summary>
    [Parameter] public bool? UseStyledCheckbox { get; set; }

    [CascadingParameter] FormDefaults? FormDefaults { get; set; }

    bool EffectiveUseStyledCheckbox => UseStyledCheckbox ?? FormDefaults?.EffectiveUseStyledCheckbox ?? FormOptions.DefaultUseStyledCheckbox;

    /// <summary>
    /// Controlled selection. Treated as an immutable parameter: reassign a new collection to
    /// change the selection from the parent — the Table only re-syncs on a reference change, so
    /// re-passing the same instance cannot veto a user toggle.
    /// </summary>
    [Parameter] public IEnumerable<TItem>? SelectedItems { get; set; }
    /// <summary>Raised with the full current selection after each row or select-all toggle.</summary>
    [Parameter] public EventCallback<IEnumerable<TItem>> SelectedItemsChanged { get; set; }

    /// <summary>
    /// Optional per-row identity selector (e.g. <c>x =&gt; x.Id</c>). Row identity defaults to the
    /// item itself, which breaks on duplicate-equal rows (records or strings with equal values):
    /// Blazor rejects duplicate sibling <c>@key</c>s and selection can't tell equal rows apart.
    /// </summary>
    [Parameter] public Func<TItem, object>? RowKey { get; set; }

    /// <summary>
    /// Bounds the table body to a fixed height with its own vertical scrollbar and a sticky header
    /// (AntD's <c>scroll.y</c> equivalent) — any CSS length (e.g. <c>"320px"</c>). Null (default)
    /// renders the existing unconstrained wrapper with no scroll container of its own. This is
    /// deliberately scoped to the table's own wrapper only — a header that stays fixed while the
    /// whole PAGE scrolls (viewport-level sticky) is out of scope.
    /// </summary>
    [Parameter] public string? ScrollY { get; set; }

    /// <summary>
    /// Raised with the column and its new selected values (empty when cleared) on any of three
    /// triggers: a column's filter is applied (OK), cleared (Reset), or a column that was actively
    /// narrowing rows drops out of the rendered set (e.g. an <c>@@if</c> hiding it) — its filter is
    /// force-cleared along with it, so the same "now empty" payload fires rather than leaving a
    /// consumer's own filter summary silently stale. The uncontrolled equivalent of AntD's
    /// <c>onFilter</c>/<c>filteredValue</c> callback pair; there is no fully-controlled
    /// <c>filteredValue</c> parameter (see <see cref="Column{TItem}.FilterOptions"/>). Not raised
    /// while a dropdown is merely open, on an outside-click/Escape discard, or on a no-op OK/Reset
    /// (the applied selection is unchanged — e.g. clicking OK with nothing ticked).
    /// </summary>
    [Parameter] public EventCallback<(Column<TItem> Column, IReadOnlyList<string> SelectedValues)> OnFilterChanged { get; set; }

    /// <summary>Accessible-name format for a column's filter button; <c>{0}</c> is the column's
    /// header text (falls back to plain "Filter" for a headerless column). Override to localize.</summary>
    [Parameter] public string FilterButtonLabelFormat { get; set; } = "Filter {0}";

    /// <summary>Label of a filter dropdown's clear-this-column button. Override to localize.</summary>
    [Parameter] public string FilterResetLabel { get; set; } = "Reset";

    /// <summary>Label of a filter dropdown's apply button. Override to localize.</summary>
    [Parameter] public string FilterOkLabel { get; set; } = "OK";

    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the root <c>div.wss-table-root</c> element. <c>class</c> and <c>style</c> merge
    /// with the component's own; the rest are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    List<Column<TItem>> _columns = new();        // promoted, ordered column set the body renders
    List<Column<TItem>>? _collecting;            // buffer the current pass collects into (promoted next pass)
    readonly List<Column<TItem>> _liveColumns = new(); // registered and not yet disposed (see StartCollectingColumns)
    readonly Dictionary<object, TItem> _selected = new(); // row key -> item
    static readonly object NullKey = new();

    object KeyFor(TItem item) => RowKey?.Invoke(item) ?? (object?)item ?? NullKey;
    List<TItem> _items = new();      // original DataSource order — the source of truth
    List<TItem> _filtered = new();   // _items narrowed by every filterable column's applied selection (or _items itself when none)
    List<TItem> _sorted = new();     // _filtered reordered by the active sort (or _filtered itself when unsorted)
    List<TItem> _pageItems = new();
    IEnumerable<TItem>? _lastDataSource;
    IEnumerable<TItem>? _lastSelectedItems;
    int _page = 1;

    // Mirrors the PageSize parameter so the embedded Pagination's size-changer (PageSizeOptions) can
    // override the effective page size without PageSize itself needing to be two-way bound. Resyncs
    // whenever the *parameter* changes (see OnParametersSet) -- an explicit consumer change to
    // PageSize always wins, discarding any earlier size-changer pick.
    int _pageSize;
    int _lastPageSizeParam = -1; // sentinel so the very first OnParametersSet always syncs

    Column<TItem>? _sortColumn;
    SortDirection _sortDirection = SortDirection.None;
    ElementReference _selectAllRef;
    IJSObjectReference? _jsModule;

    string SizeName => Size.ToString().ToLowerInvariant();

    // ----- Expandable rows ---------------------------------------------------

    // AntD RightOutlined; the CSS rotates it 90° while the row is expanded.
    static readonly MarkupString ExpandChevron = new(
        "<svg viewBox=\"64 64 896 896\" width=\"1em\" height=\"1em\" fill=\"currentColor\" aria-hidden=\"true\"><path d=\"M765.7 486.8L314.9 134.7A7.97 7.97 0 00302 141v77.3c0 4.9 2.3 9.6 6.1 12.6l360 281.1-360 281.1c-3.9 3-6.1 7.7-6.1 12.6V883c0 6.7 7.7 10.4 12.9 6.1l450.8-352.1a31.96 31.96 0 000-50.2z\"/></svg>");

    // Loading overlay spinner: EditIcons.LoadingSpinner ships with no animation baked in (a static
    // glyph, by design) -- wss-icon-spin (wss-controls.css, the shared wss-msg-spin keyframe) is what
    // actually rotates it, same technique as SearchInput.Loading.
    static readonly MarkupString LoadingIcon = new($"<span class=\"wss-icon-spin\">{EditIcons.LoadingSpinner}</span>");

    bool HasRowDetail => RowDetail is not null;
    readonly HashSet<object> _expanded = new(); // row key -> expanded
    IEnumerable<object>? _lastExpandedRowKeys;

    bool IsExpanded(TItem item) => _expanded.Contains(KeyFor(item));

    // Uncontrolled by default (ExpandedRowKeys null): _expanded is mutated directly and stays the
    // source of truth for rendering, same relationship SelectedItems/_selected already has.
    // OnExpand/ExpandedRowKeysChanged always raise regardless, so a parent can observe every toggle
    // even without opting into full control.
    async Task ToggleExpandAsync(TItem item)
    {
        var key = KeyFor(item);
        bool nowExpanded;
        if (_expanded.Add(key)) nowExpanded = true;
        else { _expanded.Remove(key); nowExpanded = false; }

        if (OnExpand.HasDelegate) await OnExpand.InvokeAsync((item, nowExpanded));
        if (ExpandedRowKeysChanged.HasDelegate) await ExpandedRowKeysChanged.InvokeAsync(_expanded.ToList());
    }

    // Every leading fixed column plus the data columns — the colspan of the placeholder and
    // expanded-detail rows.
    int TotalColumnCount => _columns.Count + (Selectable ? 1 : 0) + (HasRowDetail ? 1 : 0);

    string PagerAlignName => PagerAlign.ToString().ToLowerInvariant();

    bool IsPaged => _pageSize > 0;

    bool HasPager => IsPaged && _items.Count > 0;
    bool ShowTopPager => HasPager && PagerPosition is PagerPosition.Top or PagerPosition.Both;
    bool ShowBottomPager => HasPager && PagerPosition is PagerPosition.Bottom or PagerPosition.Both;

    // Narrows _items to _filtered by every filterable column's currently-APPLIED selection (AntD
    // ORs within a column, ANDs across columns — see Column.PassesFilter). Runs BEFORE ApplySort
    // (AntD filters, then sorts) and only from the explicit mutation points that also call
    // ApplySort/RebuildPageItems together (ApplyColumnFilterAsync/ResetColumnFilterAsync, a
    // DataSource swap, and a filtered column's removal) — never from a bare parent re-render, the
    // same discipline ToggleSort already follows for _sortColumn/_sortDirection.
    // Always assigns a fresh reference when any filter is active (.Where().ToList() allocates a new
    // list every call) — that's what lets RebuildPageItems's existing _sorted reference-equality
    // guard (below) catch a real filter change with no separate tracked field: see the guard's own
    // comment for why.
    void ApplyFilters()
    {
        _filtered = _columns.Any(c => c.CanFilter && c.FilterApplied.Count > 0)
            ? _items.Where(item => _columns.All(c => c.PassesFilter(item))).ToList()
            : _items;
    }

    // Reorders _filtered into _sorted by the active column/direction (stable: ties keep their
    // original order via the index tie-break). Unsorted falls back to _filtered with no copy.
    void ApplySort()
    {
        if (_sortColumn is null || _sortDirection == SortDirection.None)
        {
            _sorted = _filtered;
            return;
        }

        var col = _sortColumn;
        var sign = _sortDirection == SortDirection.Ascending ? 1 : -1;
        _sorted = _filtered
            .Select((item, index) => (item, index))
            .OrderBy(x => x, Comparer<(TItem item, int index)>.Create((a, b) =>
            {
                // Math.Sign first: negating a raw comparison overflows on int.MinValue (the classic
                // a.X - b.X subtraction comparator), silently mis-sorting descending.
                var c = sign * Math.Sign(col.Compare(a.item, b.item));
                return c != 0 ? c : a.index - b.index;
            }))
            .Select(x => x.item)
            .ToList();
    }

    // Rebuilt only when the page / data / page-size / sort change, so the row loop and the header
    // checkbox don't each re-materialize the page on every render. ChildContent defeats Blazor's
    // parameter-change skip, so OnParametersSet (and therefore this) runs on every parent
    // re-render — the guard below is what keeps that O(1) for unchanged inputs.
    void RebuildPageItems()
    {
        // ApplySort always assigns a fresh list reference when the view can change: its sorted
        // branch builds a new list, and its unsorted branch assigns _items, itself a fresh list per
        // DataSource swap — so comparing the _sorted reference covers both data and sort changes.
        // RowKey is deliberately NOT tracked: an inline lambda parameter is a new delegate every
        // render, and the documented contract is a pure, stable key selector — tracking it would
        // defeat this skip for the most common usage.
        // IsRowSelectable/SelectionMode ARE tracked despite neither touching page/sort/data: both
        // feed RecomputeSelectionFlags (disabled rows excluded from the select-all math, and Single
        // mode's header cell renders no select-all at all), so a runtime change to either must not
        // let this guard skip the recompute below -- otherwise _headerSelectAllDisabled/_allSelected/
        // _someSelected (and the JS indeterminate re-sync that reads _someSelected) go stale. Calling
        // RecomputeSelectionFlags unconditionally instead would restore correctness for free, but it's
        // O(page size) when paged and O(all rows) when not (see IsPaged) -- re-walking every row on
        // every parent re-render defeats the whole point of this guard (see
        // Parent_rerender_with_unchanged_data_does_not_rewalk_rows), so the two extra fields are
        // cheaper than losing that contract.
        // Column filter state (Column.FilterApplied) deliberately does NOT get its own tracked field
        // here, unlike IsRowSelectable/SelectionMode above -- and that's a considered choice, not an
        // oversight (this exact staleness class -- a new kind of state the guard doesn't know about
        // -- has bitten twice already). IsRowSelectable/SelectionMode are plain Parameters: a parent
        // can change them on any re-render, entirely independent of _sorted, so RebuildPageItems
        // (called unconditionally at the end of every OnParametersSet) needed its own way to notice.
        // Filtering instead only ever changes through ApplyColumnFilterAsync/ResetColumnFilterAsync
        // (below), which -- like ToggleSort for sorting -- always call ApplyFilters() then
        // ApplySort() before RebuildPageItems(), and ApplyFilters() always assigns _filtered a fresh
        // reference whenever a filter is actually turning on, off, or changing (its active branch is
        // `.Where().ToList()`, a new List<T> instance on every call; its inactive branch aliases
        // _items, which is itself only ever a fresh reference across a real DataSource swap). That
        // freshness flows straight into _sorted via ApplySort, so a real filter change is already
        // guaranteed to fail the _sorted reference check below -- exactly the same mechanism a
        // DataSource swap or a sort change already rely on, with no separate field needed. (A
        // no-op Reset/OK click, where filtering was inactive before and after, correctly leaves
        // _sorted unchanged and correctly skips: nothing to recompute.)
        if (ReferenceEquals(_sorted, _keyedSorted) && _page == _keyedPage && _pageSize == _keyedPageSize
            && ReferenceEquals(IsRowSelectable, _keyedIsRowSelectable) && SelectionMode == _keyedSelectionMode)
            return;

        _pageItems = IsPaged ? _sorted.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList() : _sorted;

        // Row @key values, disambiguated: fully-equal rows (equal records/strings, or RowKey
        // collisions) would be duplicate sibling @keys, which Blazor rejects with an exception that
        // kills the render. The nth duplicate gets a composite key — it degrades to positional
        // diffing for just those rows instead of crashing the whole table.
        _pageKeys.Clear();
        var seen = new Dictionary<object, int>();
        foreach (var item in _pageItems)
        {
            var key = KeyFor(item);
            if (seen.TryGetValue(key, out var n))
            {
                seen[key] = n + 1;
                _pageKeys.Add((key, n + 1));
            }
            else
            {
                seen[key] = 0;
                _pageKeys.Add(key);
            }
        }

        _keyedSorted = _sorted;
        _keyedPage = _page;
        _keyedPageSize = _pageSize;
        _keyedIsRowSelectable = IsRowSelectable;
        _keyedSelectionMode = SelectionMode;

        // Page membership (or IsRowSelectable/SelectionMode) changed, so the header-checkbox state
        // may have too.
        RecomputeSelectionFlags();
    }

    readonly List<object> _pageKeys = new();

    // Inputs of the last real rebuild (see the guard at the top of RebuildPageItems).
    List<TItem>? _keyedSorted;
    int _keyedPage;
    int _keyedPageSize;
    Func<TItem, bool>? _keyedIsRowSelectable;
    SelectionMode _keyedSelectionMode;

    bool IsActive(Column<TItem> col, SortDirection direction) =>
        ReferenceEquals(_sortColumn, col) && _sortDirection == direction;

    // The column currently driving the sort (used to tint its header + body cells).
    bool IsSortActive(Column<TItem> col) =>
        ReferenceEquals(_sortColumn, col) && _sortDirection != SortDirection.None;

    // A title-less sortable column would render a sort <button> with no accessible name (its visible
    // label span is empty and the caret stack is aria-hidden). Fall back to "Sort" so screen readers
    // announce something; when the column has plain header text, the visible content names it (no
    // aria-label). A TitleContent template renders outside the button (see the th markup above), so
    // the button never has visible content of its own there — it always needs an aria-label, from
    // Title/HeaderText when set, "Sort" otherwise.
    string? SortButtonLabel(Column<TItem> col) =>
        col.TitleContent is not null
            ? (col.HeaderText is { Length: > 0 } h ? h : "Sort")
            : (string.IsNullOrEmpty(col.HeaderText) ? "Sort" : null);

    // aria-sort per WAI-ARIA: the active column reports its direction, other sortable columns "none".
    string AriaSortFor(Column<TItem> col) =>
        ReferenceEquals(_sortColumn, col) && _sortDirection != SortDirection.None
            ? (_sortDirection == SortDirection.Ascending ? "ascending" : "descending")
            : "none";

    // Header click cycles a column ascending -> descending -> unsorted, and resets to page 1 so the
    // newly ordered rows are shown from the top. EventCallback re-renders, so no StateHasChanged.
    void ToggleSort(Column<TItem> col)
    {
        if (!ReferenceEquals(_sortColumn, col))
        {
            _sortColumn = col;
            _sortDirection = SortDirection.Ascending;
        }
        else
        {
            _sortDirection = _sortDirection switch
            {
                SortDirection.Ascending => SortDirection.Descending,
                SortDirection.Descending => SortDirection.None,
                _ => SortDirection.Ascending,
            };
            if (_sortDirection == SortDirection.None) _sortColumn = null;
        }

        _page = 1;
        ApplySort();
        RebuildPageItems();
    }

    protected override void OnParametersSet()
    {
        // See _pageSize's remarks: resync only when the PARAMETER itself changed, so a size-changer
        // pick (OnPageSizeChange, below) survives an unrelated parent re-render.
        if (PageSize != _lastPageSizeParam)
        {
            _pageSize = PageSize;
            _lastPageSizeParam = PageSize;
        }

        // Treat the collections as immutable parameters (the Blazor-idiomatic contract) and only
        // re-copy when the reference changes, mirroring Select's Options guard. Reassign DataSource /
        // SelectedItems (rather than mutating in place) to refresh.
        if (!ReferenceEquals(DataSource, _lastDataSource))
        {
            _items = DataSource?.ToList() ?? new List<TItem>();
            _lastDataSource = DataSource;

            // Drop selected rows that no longer exist in the new data, so an uncontrolled table
            // doesn't keep ghost references and emit them in the next SelectedItemsChanged payload
            // (controlled mode re-syncs from SelectedItems below, so only prune when uncontrolled) —
            // and forget expansion state for departed rows the same way.
            var pruneSelection = Selectable && SelectedItems is null && _selected.Count > 0;
            if (pruneSelection || _expanded.Count > 0)
            {
                var present = new HashSet<object>(_items.Select(KeyFor));
                if (pruneSelection)
                {
                    foreach (var gone in _selected.Keys.Where(k => !present.Contains(k)).ToList())
                        _selected.Remove(gone);
                    // No RecomputeSelectionFlags here: this branch just made _items (and via
                    // ApplyFilters/ApplySort below, _sorted) a fresh reference, so the
                    // RebuildPageItems at the end of OnParametersSet cannot skip and recomputes the
                    // flags against the new page.
                }
                _expanded.RemoveWhere(k => !present.Contains(k));
            }

            // Re-derive the filtered/sorted view from the new data (column references are stable,
            // so both the active filter selections and the active sort persist across a DataSource
            // swap, same treatment).
            ApplyFilters();
            ApplySort();
        }

        if (IsPaged)
        {
            // _filtered, not _items: clamp against the currently-visible (post-filter) row count, so
            // an active filter that narrows the data can't strand _page beyond its own last page --
            // RecomputeAfterFilterChangeAsync already resets to page 1 on every filter change, so
            // this clamp only matters for a DataSource swap while a filter from before it stays applied.
            var pageCount = Math.Max(1, (int)Math.Ceiling((double)_filtered.Count / _pageSize));
            if (_page > pageCount) _page = pageCount;
            if (_page < 1) _page = 1;
        }

        if (SelectedItems is not null && !ReferenceEquals(SelectedItems, _lastSelectedItems))
        {
            _selected.Clear();
            foreach (var s in SelectedItems) _selected[KeyFor(s)] = s;
            _lastSelectedItems = SelectedItems;
            // The selection can change without the page changing (RebuildPageItems below may then
            // legitimately skip), so refresh the header-checkbox flags here. If the page *is* also
            // changing this pass, the real rebuild below recomputes again with the new page.
            RecomputeSelectionFlags();
        }

        // SelectionMode.Single is an exclusive choice: no matter how more than one item ended up in
        // _selected -- a controlled SelectedItems handing in 2+ items (just above), or a runtime
        // Multiple -> Single mode switch with several rows already checked from before the switch --
        // at most one may remain. Keep the first (insertion-order) item: for the SelectedItems resync
        // above that's the first item of SelectedItems itself (Dictionary preserves insertion order
        // in practice, same assumption _selected.Values.ToList() already relies on elsewhere in this
        // file); for an uncontrolled mode switch it's whichever row ToggleRow/ToggleAll inserted
        // first. Only the user-driven SelectSingleAsync enforced this before -- these two parameter-
        // driven entry points didn't, leaving multiple checked radios in one native name group.
        var selectionClamped = false;
        if (SelectionMode == SelectionMode.Single && _selected.Count > 1)
        {
            var first = _selected.Values.First();
            _selected.Clear();
            _selected[KeyFor(first)] = first;
            selectionClamped = true;
            RecomputeSelectionFlags();
        }

        // Controlled expansion (layered over the uncontrolled _expanded set, same relationship as
        // SelectedItems/_selected above): only resyncs on a reference change, so re-passing the same
        // instance can't veto a toggle the Table just made and is about to raise back via
        // ExpandedRowKeysChanged.
        if (ExpandedRowKeys is not null && !ReferenceEquals(ExpandedRowKeys, _lastExpandedRowKeys))
        {
            _expanded.Clear();
            foreach (var k in ExpandedRowKeys) _expanded.Add(k);
            _lastExpandedRowKeys = ExpandedRowKeys;
        }

        if (!Selectable) _lastIndeterminate = null; // the header checkbox is recreated when re-enabled

        // The styled/unstyled header-checkbox branches (see EffectiveUseStyledCheckbox) render
        // different DOM shapes, so a runtime change of the resolved value swaps in a freshly-created
        // <input> with indeterminate == false. Forget the mirror the same way as the Selectable
        // toggle above, so OnAfterRenderAsync re-applies the mixed state instead of short-circuiting
        // against a stale value from the checkbox the old branch tore down.
        var effectiveUseStyledCheckbox = EffectiveUseStyledCheckbox;
        if (effectiveUseStyledCheckbox != _lastUseStyledCheckbox)
        {
            _lastIndeterminate = null;
            _lastUseStyledCheckbox = effectiveUseStyledCheckbox;
        }

        RebuildPageItems();

        // The clamp above pruned real entries out of _selected -- the parent's own SelectedItems (if
        // bound) must be told, so its list reflects reality instead of silently disagreeing with what
        // the radios now show. Fire-and-forget: OnParametersSet is synchronous (Blazor's own
        // lifecycle contract), and EventCallback.InvokeAsync is safe to not await here the same way
        // Register/Unregister already fire StateHasChanged without awaiting anything.
        if (selectionClamped) _ = SelectedItemsChanged.InvokeAsync(_selected.Values.ToList());
    }

    // Child columns register themselves (in document order) during their OnParametersSet, into a
    // buffer that this resets at the top of every render. Before the body renders, the buffer the
    // *previous* pass collected is promoted to the rendered set — so a hidden column drops out and a
    // re-shown one returns to its declared position, with no zombie or duplicate. Promotion is driven
    // by a re-render queued from Register (a column appeared) or Column.Dispose (one was removed),
    // which works under static SSR too (StateHasChanged during render is honored there; OnAfterRender
    // is not), matching the original collect-then-re-render behaviour.
    void StartCollectingColumns()
    {
        if (_collecting is not null)
        {
            // A column whose parameters are all Blazor-"immutable" and unchanged (e.g. a title-only
            // spacer with no template) is skipped by the diff entirely — its OnParametersSet never
            // runs, so it never re-registers into the buffer. Merge still-live stragglers back in
            // at their previous position rather than silently dropping them from the table.
            var promoted = _collecting;
            if (promoted.Count != _liveColumns.Count)
            {
                foreach (var straggler in _liveColumns)
                {
                    if (!promoted.Contains(straggler))
                    {
                        var prevIdx = _columns.IndexOf(straggler);
                        promoted.Insert(Math.Min(prevIdx < 0 ? promoted.Count : prevIdx, promoted.Count), straggler);
                    }
                }
            }

            if (!_columns.SequenceEqual(promoted))
            {
                var previousColumns = _columns;
                _columns = promoted;

                // A column that dropped out of the rendered set (@if false, or genuinely disposed)
                // must not keep narrowing the row set for a filter the user can no longer see or
                // clear -- clear its state (same treatment the active-sort-column-removed case
                // below already gets) and fall into the recompute. A column that was actively
                // NARROWING rows (FilterApplied non-empty) also needs OnFilterChanged raised with an
                // empty payload once it's gone -- this is the third way a consumer's applied filter
                // can go away (alongside OK and Reset, see RecomputeAfterFilterChangeAsync), and
                // skipping it used to leave a consumer's own filter-summary display showing a value
                // that no longer narrows anything.
                var filterCleared = new List<Column<TItem>>();
                foreach (var gone in previousColumns)
                {
                    if (_columns.Contains(gone)) continue;
                    if (gone.FilterApplied.Count == 0 && gone.FilterPending.Count == 0 && !gone.FilterOpen) continue;
                    var hadAppliedFilter = gone.FilterApplied.Count > 0;
                    gone.FilterApplied.Clear();
                    gone.FilterPending.Clear();
                    gone.FilterOpen = false;
                    if (hadAppliedFilter) filterCleared.Add(gone);
                }

                // If the column driving the active sort is gone, drop the sort so the indicator and
                // the row order can't disagree.
                var sortColumnRemoved = _sortColumn is not null && !_columns.Contains(_sortColumn);
                if (sortColumnRemoved)
                {
                    _sortColumn = null;
                    _sortDirection = SortDirection.None;
                }

                // Re-derive the view before the body renders whenever either of the above actually
                // changed something it depends on.
                if (filterCleared.Count > 0 || sortColumnRemoved)
                {
                    if (filterCleared.Count > 0) ApplyFilters();
                    ApplySort();
                    RebuildPageItems();
                }

                // Fire-and-forget, same reasoning as the selection-clamp notification in
                // OnParametersSet below: StartCollectingColumns runs synchronously mid-render (from
                // the @{ } block at the top of this file), so there's no `await` point available
                // here -- EventCallback.InvokeAsync is safe to not await.
                if (filterCleared.Count > 0 && OnFilterChanged.HasDelegate)
                    foreach (var col in filterCleared)
                        _ = OnFilterChanged.InvokeAsync((col, (IReadOnlyList<string>)Array.Empty<string>()));
            }
        }
        _collecting = new List<Column<TItem>>();
    }

    internal void Register(Column<TItem> column)
    {
        if (!_liveColumns.Contains(column)) _liveColumns.Add(column);
        if (_collecting is null || _collecting.Contains(column)) return;
        _collecting.Add(column);
        // A column not already in the rendered set means it changed — re-render so the freshly
        // collected, ordered buffer is promoted on the next pass.
        if (!_columns.Contains(column)) StateHasChanged();
    }

    internal void Unregister(Column<TItem> column)
    {
        _liveColumns.Remove(column);
        // A rendered column was disposed (e.g. conditionally removed). Re-render so the next pass
        // promotes the reduced set — the column simply won't re-register into the buffer.
        if (_columns.Contains(column)) StateHasChanged();
    }

    // Pagination.CurrentChanged is an EventCallback, so Blazor re-renders this component
    // automatically once this handler returns — no explicit StateHasChanged needed.
    void OnPageChange(int page) { _page = page; RebuildPageItems(); }

    // The embedded Pagination's size-changer (PageSizeOptions) picked a new size: re-slice at that
    // size. Pagination itself separately raises CurrentChanged (its own re-clamp rule) when the
    // current page needs to move, which OnPageChange above then applies -- so the two calls together
    // land on the correct final page/size before the next render, same as the documented
    // compose-with-a-standalone-Pagination server-paging pattern.
    void OnPageSizeChange(int newSize)
    {
        if (newSize <= 0 || newSize == _pageSize) return;
        _pageSize = newSize;
        RebuildPageItems();
    }

    bool IsSelected(TItem item) => _selected.ContainsKey(KeyFor(item));

    // Null (the default) means every row is selectable, matching the pre-IsRowSelectable behavior
    // exactly (the check below is always true, so RecomputeSelectionFlags/ToggleAll never skip a row).
    bool IsRowSelectableFor(TItem item) => IsRowSelectable is null || IsRowSelectable(item);

    // Header-checkbox state, cached so rendering doesn't rescan the page (formerly computed
    // properties re-evaluated up to three times per render — O(page) each, with a KeyFor boxing
    // per probe). _someSelected means some but not all of the current page is selected: the header
    // checkbox then renders unchecked and we drive it to the native "mixed" state via JS so screen
    // readers announce the partial selection (WCAG 4.1.2) instead of "not checked".
    bool _allSelected;
    bool _someSelected;

    // Disables the header "select all" when IsRowSelectable is in play and no row on the page can be
    // selected (including an empty page). Stays false whenever IsRowSelectable is null (the default),
    // regardless of how many rows are on the page -- an empty/all-selectable page must not gain a
    // disabled attribute it never had before this feature existed.
    bool _headerSelectAllDisabled;

    // Single pass with early exit: once both a selected and an unselected SELECTABLE row have been
    // seen, the outcome (mixed) is decided. Called from every point where the page membership or the
    // selection changes: a real RebuildPageItems rebuild, ToggleRow, ToggleAll, and the controlled
    // SelectedItems re-sync in OnParametersSet.
    void RecomputeSelectionFlags()
    {
        var anySelected = false;
        var anyUnselected = false;
        var anySelectable = false;
        foreach (var item in _pageItems)
        {
            if (!IsRowSelectableFor(item)) continue;
            anySelectable = true;
            if (IsSelected(item)) anySelected = true; else anyUnselected = true;
            if (anySelected && anyUnselected) break;
        }

        _allSelected = anySelected && !anyUnselected; // an empty page reports neither flag
        _someSelected = anySelected && anyUnselected;
        _headerSelectAllDisabled = IsRowSelectable is not null && !anySelectable;
    }

    bool? _lastIndeterminate;
    bool? _lastUseStyledCheckbox;
    bool _disposed;

    // indeterminate is a DOM property with no HTML attribute, so it can only be set from JS. Runs
    // after a render only when the mixed state actually changed (skipping a JS round-trip per
    // render); degrades to a plain checkbox when there's no JS runtime (server prerender, tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed) return;
        if (!Selectable)
        {
            // The select-all <input> lives inside @if (Selectable), so toggling Selectable off
            // destroys it — a fresh element comes back with indeterminate == false. Forget the
            // mirror so re-enabling re-applies the mixed state instead of short-circuiting.
            _lastIndeterminate = null;
            return;
        }
        var some = _someSelected;
        if (_lastIndeterminate == some) return;
        try
        {
            _jsModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", JsModuleUrl.Resolve(FormDefaults, "wss-table.js"));
            if (_disposed)
            {
                // Disposed while the import was in flight — DisposeAsync already ran with a null
                // module, so this reference is ours to clean up.
                try { await _jsModule.DisposeAsync(); } catch { }
                _jsModule = null;
                return;
            }
            await _jsModule.InvokeVoidAsync("setIndeterminate", _selectAllRef, some);
            _lastIndeterminate = some;
        }
        catch
        {
            // No JS runtime / module — the header checkbox just shows checked/unchecked.
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.DisposeAsync();
            }
            catch
            {
                // Circuit may already be gone; nothing to clean up.
            }
            _jsModule = null;
        }
    }

    async Task ToggleRow(TItem item, bool on)
    {
        if (on) _selected[KeyFor(item)] = item; else _selected.Remove(KeyFor(item));
        RecomputeSelectionFlags();
        await SelectedItemsChanged.InvokeAsync(_selected.Values.ToList());
    }

    // Select-all toggles the current page's SELECTABLE rows only (matching Ant Design behaviour); a
    // row IsRowSelectable rejects is left exactly as it was, in or out of the selection.
    async Task ToggleAll(bool on)
    {
        foreach (var i in _pageItems)
        {
            if (!IsRowSelectableFor(i)) continue;
            if (on) _selected[KeyFor(i)] = i; else _selected.Remove(KeyFor(i));
        }
        RecomputeSelectionFlags();
        await SelectedItemsChanged.InvokeAsync(_selected.Values.ToList());
    }

    // ----- SelectionMode.Single (radio-semantics selection) -----

    // A per-instance native <input type="radio"> group name so this table's rows form one exclusive
    // choice without colliding with any other Table on the page (e.g. a nested RowDetail child table).
    readonly string _radioGroupName = $"wss-table-radio-{Guid.NewGuid():N}";

    async Task SelectSingleAsync(TItem item)
    {
        if (!IsRowSelectableFor(item)) return;
        _selected.Clear();
        _selected[KeyFor(item)] = item;
        RecomputeSelectionFlags();
        await SelectedItemsChanged.InvokeAsync(_selected.Values.ToList());
    }

    // ----- Row click / expand-by-click -----

    // Whether a row should look/behave clickable -- only when a consumer actually wired something,
    // so an untouched Table gets no pointer cursor / clickable styling by default.
    bool RowIsClickable => ExpandRowByClick || OnRowClick.HasDelegate;

    async Task OnRowClickedAsync(TItem item)
    {
        if (ExpandRowByClick && HasRowDetail) await ToggleExpandAsync(item);
        await OnRowClick.InvokeAsync(item);
    }

    // Any column requesting Ellipsis truncation needs table-layout: fixed for max-width: 0 +
    // overflow: hidden to actually clip (auto layout sizes columns from content and ignores it) --
    // see the wss-table-fixed CSS rule. Untouched (no column sets Ellipsis) keeps the table's
    // existing auto layout exactly as before.
    bool AnyColumnEllipsis => _columns.Any(c => c.Ellipsis);

    // ----- Column filtering (TableColumnFilter calls these -- only one dropdown open at a time,
    // matching AntD: opening a column's filter closes any other column's still-open one). -----

    internal void OpenColumnFilter(Column<TItem> column)
    {
        foreach (var c in _columns)
            if (!ReferenceEquals(c, column)) c.FilterOpen = false;

        // Stage the dropdown from the last APPLIED selection, not whatever was left over in
        // FilterPending from a previous open-then-discard (outside click/Escape never copies
        // Pending back into Applied, so a stale Pending would otherwise resurface here).
        column.FilterPending.Clear();
        foreach (var v in column.FilterApplied) column.FilterPending.Add(v);
        column.FilterOpen = true;

        // TableColumnFilter is a child component: mutating Column fields directly doesn't cause
        // Table's own <thead> render (a sibling of every OTHER column's TableColumnFilter instance)
        // to refresh on its own -- this closes those siblings' dropdowns visibly, not just in state.
        StateHasChanged();
    }

    internal void CloseColumnFilter(Column<TItem> column)
    {
        column.FilterOpen = false;
        StateHasChanged();
    }

    // OK: commit the dropdown's staged selection and re-run the filter/sort/page pipeline. "changed"
    // compares the about-to-be-overwritten Applied set against Pending BEFORE overwriting it -- a
    // no-op OK (e.g. clicking it with nothing ticked, or re-ticking back to the exact set that was
    // already applied) must not reset the page or fire a spurious "it changed" notification.
    internal async Task ApplyColumnFilterAsync(Column<TItem> column)
    {
        var changed = !column.FilterApplied.SetEquals(column.FilterPending);
        column.FilterApplied.Clear();
        foreach (var v in column.FilterPending) column.FilterApplied.Add(v);
        column.FilterOpen = false;
        await RecomputeAfterFilterChangeAsync(column, changed);
    }

    // Reset: clear both the staged and applied selection immediately (no OK needed) and re-run the
    // pipeline the same way. A Reset on a column with no applied filter (nothing to clear) is a
    // no-op by the same "changed" measure as OK above.
    internal async Task ResetColumnFilterAsync(Column<TItem> column)
    {
        var changed = column.FilterApplied.Count > 0;
        column.FilterPending.Clear();
        column.FilterApplied.Clear();
        column.FilterOpen = false;
        await RecomputeAfterFilterChangeAsync(column, changed);
    }

    // Shared tail of OK/Reset (and, with an already-computed `changed`, the filtered-column-removal
    // path in StartCollectingColumns below): AntD resets to page 1 only when the applied selection
    // actually changed (mirrors ToggleSort's own reset) -- a no-op OK/Reset must not strand the user
    // off whatever page they were reading. Re-derives filtered -> sorted -> paged either way (this is
    // what keeps RebuildPageItems's guard correct with no separate tracked field for filter state --
    // see that guard's own comment) and raises OnFilterChanged only when something actually changed,
    // so a consumer's own filter-summary state never gets a spurious "it changed" notification.
    async Task RecomputeAfterFilterChangeAsync(Column<TItem> column, bool changed)
    {
        if (changed) _page = 1;
        ApplyFilters();
        ApplySort();
        RebuildPageItems();
        StateHasChanged();
        if (changed && OnFilterChanged.HasDelegate)
            await OnFilterChanged.InvokeAsync((column, column.AppliedFilterValues));
    }
}
