@namespace Controls
@implements IDisposable

@* WASM-only host: reads the static WasmMessageService. For Blazor Server use MessageContainer. *@
<MessageListView Items="WasmMessageService.Items" />

@code {
    protected override void OnInitialized() => WasmMessageService.OnChange += HandleChange;

    void HandleChange() => InvokeAsync(StateHasChanged);

    public void Dispose() => WasmMessageService.OnChange -= HandleChange;
}
