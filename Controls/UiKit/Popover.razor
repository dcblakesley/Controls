@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

<span @attributes="AttributeSplat.Rest(AdditionalAttributes)"
      class="wss-popover-wrap @AttributeSplat.ConsumerClass(AdditionalAttributes)"
      style="@AttributeSplat.MergeStyle(null, AdditionalAttributes)">
    @* The consumer's ChildContent normally holds the interactive trigger (e.g. a <button>): its
       native activation bubbles here as a click, so this wrapper carries no button semantics of its
       own (it used to be role="button", nesting a button inside a button — two tab stops, invalid
       ARIA). wss-overlay.js mirrors the popup ARIA onto that child, or promotes this span to the
       button role when the content has nothing focusable. While open, keydown must not bubble
       further (an Escape meant for this popover would also close an enclosing Modal/Drawer);
       while closed it bubbles normally. *@
    <span class="wss-popover-trigger" @ref="_triggerRef"
          @onclick="Toggle" @onkeydown="OnTriggerKeyDown" @onkeydown:stopPropagation="@_open">@ChildContent</span>
    @if (_open)
    {
        @* tabindex="-1": iOS-class WebKit only synthesizes a click from a tap on a focusable/
           interactive target chain — without it a backdrop tap never reaches @onclick on touch. *@
        <div class="wss-popover-backdrop" tabindex="-1" @onclick="Close"></div>
        <div class="wss-popover wss-popover-@(_resolvedPlacement ?? PlacementName) @(_positioned ? null : "wss-measuring")"
             @ref="_panelRef" role="dialog" tabindex="-1"
             aria-labelledby="@(HasTitle ? $"{_id}-title" : null)"
             aria-label="@(HasTitle ? null : AriaLabel)"
             aria-describedby="@($"{_id}-content")"
             @onkeydown="OnPanelKeyDown"
             @onkeydown:stopPropagation="true"
             @onclick:stopPropagation="true">
            <div class="wss-popover-inner">
                @if (HasTitle)
                {
                    <div class="wss-popover-title" id="@($"{_id}-title")">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                }
                <div class="wss-popover-content" id="@($"{_id}-content")">@Content</div>
            </div>
            <span class="wss-popover-arrow"></span>
        </div>
    }
</span>

@code {
    /// <summary>Plain-text popover title.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Rich popover title; overrides <see cref="Title"/> when set.</summary>
    [Parameter] public RenderFragment? TitleContent { get; set; }
    /// <summary>The popover body.</summary>
    [Parameter] public RenderFragment? Content { get; set; }
    /// <summary>The trigger element.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Preferred side of the trigger for the panel; flips/shifts to stay within the viewport. Defaults to <see cref="PopupPlacement.Top"/>.</summary>
    [Parameter] public PopupPlacement Placement { get; set; } = PopupPlacement.Top;
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>
    /// Unmatched attributes (e.g. a consumer's <c>class</c>, <c>style</c>, or <c>data-*</c>),
    /// applied to the outer wrapper (<c>.wss-popover-wrap</c>) — never the floating panel, whose
    /// inline placement (z-index, <c>--wss-shift</c>) is JS-owned. <c>class</c> and <c>style</c>
    /// merge with the component's own; the rest are splatted verbatim.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    ElementReference _triggerRef;
    ElementReference _panelRef;
    IJSObjectReference? _module;
    bool _open;
    bool _positioned;
    bool _pendingFocus;
    bool _disposed;
    // Last (open, disabled) pair pushed to syncTrigger. syncTrigger re-resolves the trigger child on
    // every call, so we only re-invoke it when this pair changes (plus the first render) — otherwise
    // every ancestor re-render would cost one interop round trip per instance (e.g. a Popconfirm per
    // Table row). Popover has no Disabled parameter, so the pair is always (_open, false).
    (bool Open, bool Disabled)? _lastSyncedTrigger;
    // Side the panel actually rendered on after the viewport flip. Null until measured (falls back to
    // the preferred PlacementName). Owned by C# so the re-render that drops `wss-measuring` keeps it.
    string? _resolvedPlacement;
    readonly string _id = $"wss-popover-{Guid.NewGuid():N}";

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    void Toggle() => _open = !_open;
    void Close() => _open = false;

    // Escape only: Enter/Space activation comes from the child's native click (or the JS fallback
    // synthesizing one for plain content) bubbling into @onclick — handling the keys here as well
    // would double-toggle when a button child's keystroke both clicks and bubbles.
    void OnTriggerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    // Escape must also work once focus has moved into the panel — the panel is a sibling of the
    // trigger, so a keydown there never bubbles to the trigger's handler.
    void OnPanelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    // After the panel opens, nudge it to stay within the viewport (flip/shift). Degrades to the
    // default CSS placement when JS isn't available (server prerender, unit tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Mirror the popup ARIA onto the real trigger element. syncTrigger re-resolves the child on
        // every call, so we only need to invoke it on the first render or when (_open, false) changes
        // — skipping the interop otherwise keeps a per-row Popover cheap on every ancestor re-render.
        var pair = (_open, false);
        if (firstRender || _lastSyncedTrigger != pair)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                if (_disposed)
                {
                    // Disposed while the import was in flight — DisposeAsync already ran with a null
                    // module, so this reference is ours to clean up.
                    try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
                    _module = null;
                    return;
                }
                await _module.InvokeVoidAsync("syncTrigger", _triggerRef, _open, false);
                _lastSyncedTrigger = pair; // cache only on success, so a no-JS render retries next time
            }
            catch { /* no JS — a button child still toggles via its bubbled click; plain content is mouse-only */ }
        }

        if (_open && !_positioned)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                if (_disposed)
                {
                    try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
                    _module = null;
                    return;
                }
                _resolvedPlacement = await _module.InvokeAsync<string>("place", _triggerRef, _panelRef, "wss-popover", PlacementName, 10, 8);
            }
            catch
            {
                // No JS runtime / module — keep the CSS default placement.
            }
            _positioned = true;
            _pendingFocus = true;
            StateHasChanged(); // reveal the panel now that it's positioned (drops wss-measuring)
        }
        else if (_open && _pendingFocus)
        {
            // Move focus into the (now visible) dialog so keyboard / screen-reader users land on it.
            _pendingFocus = false;
            try { await _panelRef.FocusAsync(); } catch { /* not focusable yet (prerender/tests) */ }
        }
        else if (!_open && _positioned)
        {
            _positioned = false;
            _resolvedPlacement = null; // re-measure on the next open
            // Restore focus to the real trigger (the interactive child, or the promoted wrapper).
            try
            {
                if (_module is not null) await _module.InvokeVoidAsync("focusTrigger", _triggerRef);
                else await _triggerRef.FocusAsync();
            }
            catch { /* no JS / element gone */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
            _module = null;
        }
    }
}
