@namespace Controls
@implements IAsyncDisposable
@inject IJSRuntime JS

<span class="wss-popover-wrap">
    @* While open, keydown must not bubble further (an Escape meant for this popover would also
       close an enclosing Modal/Drawer); while closed it bubbles normally. *@
    <span class="wss-popover-trigger" @ref="_triggerRef" tabindex="0" role="button"
          aria-haspopup="dialog" aria-expanded=@(_open ? "true" : "false")
          @onclick="Toggle" @onkeydown="OnTriggerKeyDown" @onkeydown:stopPropagation="@_open">@ChildContent</span>
    @if (_open)
    {
        <div class="wss-popover-backdrop" @onclick="Close"></div>
        <div class="wss-popover wss-popover-@(_resolvedPlacement ?? PlacementName) @(_positioned ? null : "wss-measuring")"
             @ref="_panelRef" role="dialog" tabindex="-1"
             aria-labelledby="@(HasTitle ? $"{_id}-title" : null)"
             aria-label="@(HasTitle ? null : AriaLabel)"
             aria-describedby="@($"{_id}-content")"
             @onkeydown="OnPanelKeyDown"
             @onkeydown:stopPropagation="true"
             @onclick:stopPropagation="true">
            <div class="wss-popover-inner">
                @if (HasTitle)
                {
                    <div class="wss-popover-title" id="@($"{_id}-title")">@(TitleContent ?? (RenderFragment)(b => b.AddContent(0, Title)))</div>
                }
                <div class="wss-popover-content" id="@($"{_id}-content")">@Content</div>
            </div>
            <span class="wss-popover-arrow"></span>
        </div>
    }
</span>

@code {
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? TitleContent { get; set; }
    /// <summary>The popover body.</summary>
    [Parameter] public RenderFragment? Content { get; set; }
    /// <summary>The trigger element.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public PopupPlacement Placement { get; set; } = PopupPlacement.Top;
    /// <summary>Accessible name used when no <see cref="Title"/>/<see cref="TitleContent"/> is supplied.</summary>
    [Parameter] public string? AriaLabel { get; set; }

    ElementReference _triggerRef;
    ElementReference _panelRef;
    IJSObjectReference? _module;
    bool _open;
    bool _positioned;
    bool _pendingFocus;
    // Side the panel actually rendered on after the viewport flip. Null until measured (falls back to
    // the preferred PlacementName). Owned by C# so the re-render that drops `wss-measuring` keeps it.
    string? _resolvedPlacement;
    readonly string _id = $"wss-popover-{Guid.NewGuid():N}";

    string PlacementName => Placement.ToString().ToLowerInvariant();

    bool HasTitle => TitleContent != null || !string.IsNullOrEmpty(Title);

    void Toggle() => _open = !_open;
    void Close() => _open = false;

    void OnTriggerKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") Toggle();
        else if (e.Key == "Escape") Close();
    }

    // Escape must also work once focus has moved into the panel — the panel is a sibling of the
    // trigger, so a keydown there never bubbles to the trigger's handler.
    void OnPanelKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
    }

    // After the panel opens, nudge it to stay within the viewport (flip/shift). Degrades to the
    // default CSS placement when JS isn't available (server prerender, unit tests).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                await _module.InvokeVoidAsync("initTrigger", _triggerRef);
            }
            catch { /* no JS — Space may also scroll the page; everything else still works */ }
        }

        if (_open && !_positioned)
        {
            try
            {
                _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/WssBlazorControls/wss-overlay.js");
                _resolvedPlacement = await _module.InvokeAsync<string>("place", _triggerRef, _panelRef, "wss-popover", PlacementName, 10, 8);
            }
            catch
            {
                // No JS runtime / module — keep the CSS default placement.
            }
            _positioned = true;
            _pendingFocus = true;
            StateHasChanged(); // reveal the panel now that it's positioned (drops wss-measuring)
        }
        else if (_open && _pendingFocus)
        {
            // Move focus into the (now visible) dialog so keyboard / screen-reader users land on it.
            _pendingFocus = false;
            try { await _panelRef.FocusAsync(); } catch { /* not focusable yet (prerender/tests) */ }
        }
        else if (!_open && _positioned)
        {
            _positioned = false;
            _resolvedPlacement = null; // re-measure on the next open
            try { await _triggerRef.FocusAsync(); } catch { /* restore focus to the trigger */ }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { /* circuit may be gone */ }
            _module = null;
        }
    }
}
