@namespace Controls

@* Backdrop: closes the dropdown on any outside click without needing JS interop. Rendered as the
   wrapper's previous sibling so placePanel can stack it just under the raised wrapper (the same
   contract as DateRangePicker/Select). tabindex="-1": iOS-class WebKit only synthesizes a click
   from a tap when the target chain contains a focusable element; -1 keeps it out of the Tab order. *@
@if (_open)
{
    <div class="wss-picker-backdrop" tabindex="-1" @onclick="CloseAsync"></div>
}

<div @attributes="AttributeSplat.Rest(AdditionalAttributes)"
     class="@WrapperClass @AttributeSplat.ConsumerClass(AdditionalAttributes)"
     style="@AttributeSplat.MergeStyle(WrapperStyle, AdditionalAttributes)"
     @ref="_wrapperRef"
     @onkeydown="OnWrapperKeyDownAsync" @onkeydown:stopPropagation="@_open">

    @* tabindex="-1": a click on the field's non-input chrome then focuses the field itself instead
       of <body>, so Escape still bubbles through the wrapper's keydown and the focus-out close
       wiring sees focus as inside. (Same pattern as DateRangePicker.) *@
    <div class="wss-picker-input" tabindex="-1" @onclick="OnFieldClickAsync">
        <span class="wss-picker-input-slot">
            <input @ref="_inputRef"
                   class="wss-picker-input-date"
                   id="@Id"
                   data-test-id="@Id"
                   type="text"
                   autocomplete="off"
                   aria-label="@InputLabel"
                   aria-haspopup="dialog"
                   aria-expanded="@(_open ? "true" : "false")"
                   aria-required="@AriaRequired"
                   aria-invalid="@(AriaInvalid ? "true" : null)"
                   aria-describedby="@AriaDescribedBy"
                   aria-errormessage="@AriaErrorMessage"
                   placeholder="@EffectivePlaceholder"
                   disabled="@Disabled"
                   value="@Display"
                   @oninput="@(e => _edit = e.Value?.ToString() ?? string.Empty)"
                   @onchange="@(() => CommitTextAsync())"
                   @onfocus="OnInputFocus" />
        </span>
        <span class="wss-picker-suffix">@CalendarIcon</span>
        @if (ShowClear)
        {
            <button type="button" class="wss-picker-clear" aria-label="@ClearLabel"
                    @onclick="ClearAsync" @onclick:stopPropagation>@CloseCross</button>
        }
    </div>

    @if (_open)
    {
        <div class="wss-picker-dropdown wss-picker-dropdown-single @(_positioned ? null : "wss-measuring")" @ref="_panelRef"
             role="dialog" aria-label="@DialogLabel" tabindex="-1">
            @if (Mode == DatePickerMode.Month)
            {
                <div class="wss-picker-month">
                    @YearHeaderFragment
                    <div class="wss-picker-month-grid" @ref="_gridRef" @onkeydown="OnMonthGridKeyDown">
                        @for (var m = 1; m <= 12; m++)
                        {
                            var month = new DateTime(_viewMonth.Year, m, 1);
                            <button type="button" class="wss-picker-month-btn"
                                    disabled="@IsMonthDisabled(month)"
                                    tabindex="@(IsMonthFocusStop(month) ? "0" : "-1")"
                                    data-date="@month.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                    aria-label="@month.ToString("MMMM yyyy", PickerCulture)"
                                    aria-pressed="@(IsSelectedMonth(month) ? "true" : "false")"
                                    aria-current="@(IsCurrentMonth(month) ? "date" : null)"
                                    @onclick="@(() => OnMonthClickAsync(month))">@MonthName(m)</button>
                        }
                    </div>
                </div>
            }
            else if (Mode == DatePickerMode.Year)
            {
                <div class="wss-picker-month">
                    <div class="wss-picker-month-header">
                        <button type="button" class="wss-picker-nav" aria-label="@PrevDecadeLabel"
                                disabled="@PrevDecadeDisabled" @onclick="PrevDecade">@PrevIcon</button>
                        <div class="wss-picker-month-selects">
                            <span class="wss-picker-decade-label">@DecadeLabel</span>
                        </div>
                        <button type="button" class="wss-picker-nav" aria-label="@NextDecadeLabel"
                                disabled="@NextDecadeDisabled" @onclick="NextDecade">@NextIcon</button>
                    </div>
                    <div class="wss-picker-month-grid" @ref="_gridRef" @onkeydown="OnYearGridKeyDown">
                        @for (var i = -1; i <= 10; i++)
                        {
                            var year = DecadeStart + i;
                            var yearStart = new DateTime(year, 1, 1);
                            <button type="button" class="@YearButtonClass(year)"
                                    disabled="@IsYearDisabled(yearStart)"
                                    tabindex="@(IsYearFocusStop(year) ? "0" : "-1")"
                                    data-date="@yearStart.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                    aria-label="@year.ToString(PickerCulture)"
                                    aria-pressed="@(IsSelectedYear(year) ? "true" : "false")"
                                    aria-current="@(IsCurrentYear(year) ? "date" : null)"
                                    @onclick="@(() => OnYearClickAsync(year))">@year.ToString(PickerCulture)</button>
                        }
                    </div>
                </div>
            }
            else if (Mode == DatePickerMode.Quarter)
            {
                <div class="wss-picker-month">
                    @YearHeaderFragment
                    <div class="wss-picker-quarter-grid" @ref="_gridRef" @onkeydown="OnQuarterGridKeyDown">
                        @for (var q = 1; q <= 4; q++)
                        {
                            var quarter = q;
                            var quarterStart = QuarterStart(_viewMonth.Year, quarter);
                            <button type="button" class="wss-picker-month-btn"
                                    disabled="@IsQuarterDisabled(quarterStart)"
                                    tabindex="@(IsQuarterFocusStop(_viewMonth.Year, quarter) ? "0" : "-1")"
                                    data-date="@quarterStart.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                    aria-label="@($"Q{quarter.ToString(PickerCulture)} {_viewMonth.Year.ToString(PickerCulture)}")"
                                    aria-pressed="@(IsSelectedQuarter(_viewMonth.Year, quarter) ? "true" : "false")"
                                    aria-current="@(IsCurrentQuarter(_viewMonth.Year, quarter) ? "date" : null)"
                                    @onclick="@(() => OnQuarterClickAsync(_viewMonth.Year, quarter))">Q@(quarter.ToString(PickerCulture))</button>
                        }
                    </div>
                </div>
            }
            else if (Mode == DatePickerMode.Time)
            {
                <div class="wss-picker-month">
                    @TimeRowFragment
                    <div class="wss-picker-footer">
                        <button type="button" class="wss-picker-ok" @onclick="OnPickerOkAsync">@OkText</button>
                    </div>
                </div>
            }
            else
            {
                <div class="wss-picker-month">
                    <div class="wss-picker-month-header">
                        <button type="button" class="wss-picker-nav" aria-label="@PrevMonthLabel"
                                disabled="@PrevMonthDisabled" @onclick="PrevMonth">@PrevIcon</button>
                        <div class="wss-picker-month-selects">
                            <span class="wss-picker-select">
                                <select aria-label="@MonthSelectLabel" value="@_viewMonth.Month"
                                        @onchange="OnMonthSelectChanged">
                                    @for (var m = 1; m <= 12; m++)
                                    {
                                        <option value="@m" selected="@(m == _viewMonth.Month)">@MonthName(m)</option>
                                    }
                                </select>
                                @DownIcon
                            </span>
                            <span class="wss-picker-select">
                                <select aria-label="@YearSelectLabel" value="@_viewMonth.Year"
                                        @onchange="OnYearSelectChanged">
                                    @{ var (fromYear, toYear) = YearRange(_viewMonth.Year); }
                                    @for (var y = fromYear; y <= toYear; y++)
                                    {
                                        <option value="@y" selected="@(y == _viewMonth.Year)">@y.ToString(PickerCulture)</option>
                                    }
                                </select>
                                @DownIcon
                            </span>
                        </div>
                        <button type="button" class="wss-picker-nav" aria-label="@NextMonthLabel"
                                disabled="@NextMonthDisabled" @onclick="NextMonth">@NextIcon</button>
                    </div>
                    <div class="wss-picker-week-header" aria-hidden="true">
                        @foreach (var name in WeekdayHeaders)
                        {
                            <div class="wss-picker-week-day">@name</div>
                        }
                    </div>
                    <div class="wss-picker-grid" @ref="_gridRef" @onkeydown="OnGridKeyDown">
                        @foreach (var day in GridDays(_viewMonth))
                        {
                            var d = day;
                            <div class="wss-picker-cell">
                                <button type="button" class="@DayClass(d)"
                                        disabled="@IsDayDisabled(d)"
                                        tabindex="@(IsFocusStop(d) ? "0" : "-1")"
                                        data-date="@d.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)"
                                        aria-label="@d.ToString("D", PickerCulture)"
                                        aria-pressed="@(d == Value?.Date ? "true" : "false")"
                                        @onclick="@(() => OnDayClickAsync(d))">@d.Day.ToString("00", CultureInfo.CurrentCulture)</button>
                            </div>
                        }
                    </div>
                    @* DateTime mode appends the same time row + OK footer below the calendar --
                       Mode="Time" (above) renders it alone, this is the only other place it's used. *@
                    @if (Mode == DatePickerMode.DateTime)
                    {
                        @TimeRowFragment
                        <div class="wss-picker-footer">
                            <button type="button" class="wss-picker-ok" @onclick="OnPickerOkAsync">@OkText</button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    // Month mode's header (prev-year nav / year select / next-year nav), shared verbatim with
    // Quarter mode -- the 4-quarter grid still needs to know which year it's showing, and that's
    // exactly what this header already picks. See DatePicker.razor.cs's "Month mode: grid + year
    // navigation" section for PrevYear/NextYear/YearRange/OnYearSelectChanged.
    RenderFragment YearHeaderFragment => @<div class="wss-picker-month-header">
        <button type="button" class="wss-picker-nav" aria-label="@PrevYearLabel"
                disabled="@PrevYearDisabled" @onclick="PrevYear">@PrevIcon</button>
        <div class="wss-picker-month-selects">
            <span class="wss-picker-select">
                <select aria-label="@YearSelectLabel" value="@_viewMonth.Year"
                        @onchange="OnYearSelectChanged">
                    @{ var (fromYear, toYear) = YearRange(_viewMonth.Year); }
                    @for (var y = fromYear; y <= toYear; y++)
                    {
                        <option value="@y" selected="@(y == _viewMonth.Year)">@y.ToString(PickerCulture)</option>
                    }
                </select>
                @DownIcon
            </span>
        </div>
        <button type="button" class="wss-picker-nav" aria-label="@NextYearLabel"
                disabled="@NextYearDisabled" @onclick="NextYear">@NextIcon</button>
    </div>;

    // The three hour/minute/second selects, shared verbatim between Mode.Time (the whole panel) and
    // Mode.DateTime (appended below the day calendar) so the ~20 lines of near-identical <select>
    // blocks aren't duplicated in the markup above (mirrors EditBool's Checkbox/StyledCheckboxFragment
    // split). Each select's own @onchange commits immediately via ApplyTimePartAsync -- see
    // DatePicker.razor.cs's "Time/DateTime mode" section.
    RenderFragment TimeRowFragment => @<div class="wss-picker-time-row">
        <span class="wss-picker-select">
            <select aria-label="@HourSelectLabel" value="@DisplayHour" @onchange="OnHourSelectChangedAsync">
                @for (var h = 0; h <= 23; h++)
                {
                    <option value="@h" selected="@(h == DisplayHour)">@h.ToString("00", CultureInfo.InvariantCulture)</option>
                }
            </select>
            @DownIcon
        </span>
        <span class="wss-picker-select">
            <select aria-label="@MinuteSelectLabel" value="@DisplayMinute" @onchange="OnMinuteSelectChangedAsync">
                @for (var m = 0; m <= 59; m++)
                {
                    <option value="@m" selected="@(m == DisplayMinute)">@m.ToString("00", CultureInfo.InvariantCulture)</option>
                }
            </select>
            @DownIcon
        </span>
        <span class="wss-picker-select">
            <select aria-label="@SecondSelectLabel" value="@DisplaySecond" @onchange="OnSecondSelectChangedAsync">
                @for (var s = 0; s <= 59; s++)
                {
                    <option value="@s" selected="@(s == DisplaySecond)">@s.ToString("00", CultureInfo.InvariantCulture)</option>
                }
            </select>
            @DownIcon
        </span>
    </div>;
}
