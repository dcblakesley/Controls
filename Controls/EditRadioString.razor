@inherits EditControlBase<string?>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">

        <fieldset class="edit-radio-fieldset"
                  id=@(ShowEditor ? _id : null)
                  data-test-id=@(ShowEditor ? _id : null)
                  role=@(ShowEditor ? "radiogroup" : null)
                  aria-labelledby=@(ShowEditor && !ShouldHideLabel ? $"lbl-{_id}" : null)
                  aria-required=@(ShowEditor ? _isRequired : null)
                  aria-invalid=@(ShowEditor && IsInvalid ? "true" : null)
                  aria-describedby=@(ShowEditor ? _describedBy : null)
                  aria-errormessage=@(ShowEditor && IsInvalid ? _errorMsgId : null)>
            <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequiredResolved Description=@Description Tooltip=@Tooltip IsLegend=true IsLabelHidden=@ShouldHideLabel />

            @if (ShowEditor)
            {
                @* ValueExpression forwarded so the inner group notifies/styles the real model field;
                   `disabled` would be a no-op here (InputRadioGroup renders no element) — each
                   InputRadio below carries it individually. *@
                <InputRadioGroup Value=@SelectedOption ValueChanged=@((string? v) => SelectedOption = v) ValueExpression=@ValueExpression>

                    @if (OptionType == RadioOptionType.Button)
                    {
                        @* Button mode is inherently horizontal (AntD's segmented look) -- IsHorizontal
                           is ignored here rather than composed with it. Same InputRadio/keyboard
                           semantics as default mode, just styled as a visually-hidden input + sibling
                           label button (the established styled-checkbox technique). *@
                        <div class=@ButtonGroupClass>
                            @foreach (var option in Options)
                            {
                                var isOptionDisabled = IsDisabled || IsOptionDisabled?.Invoke(option) == true;
                                var optionId = $"rb-{_id}-{option.ToId()}";
                                <span class="edit-radio-button-wrap">
                                    <InputRadio Value=@option
                                                disabled=@isOptionDisabled
                                                id=@optionId
                                                data-test-id=@optionId
                                                class=@($"edit-radio-button-input {CssClass}") />
                                    <label class=@($"edit-radio-button {LabelClass}") for=@optionId>@option</label>
                                </span>
                            }
                            @if (HasOther)
                            {
                                var otherId = $"rb-{_id}-other";
                                <span class="edit-radio-button-wrap">
                                    <InputRadio Value=@_otherName
                                                id=@otherId
                                                disabled=@IsDisabled
                                                data-test-id=@otherId
                                                class=@($"edit-radio-button-input {CssClass}") />
                                    <label class=@($"edit-radio-button {LabelClass}") for=@otherId>Other</label>
                                </span>
                            }
                        </div>
                        @if (HasOther)
                        {
                            <div class="edit-radio-other-option-container">
                                <input disabled="@(_selectedOption != _otherName || IsDisabled)"
                                       type="text"
                                       id=@($"txt-{_id}-custom-value")
                                       aria-label="Custom text value input"
                                       class="edit-input edit-string-input"
                                       @bind:get=@_otherText
                                       @bind:set=SetOtherText
                                       @bind:event="oninput"/>
                            </div>
                        }
                    }
                    else
                    {
                        <div class=@(IsHorizontal
                                       ? "edit-radio-buttons-container-horizontal"
                                       : "edit-radio-buttons-container-vertical")>

                            @foreach (var option in Options)
                            {
                                var isOptionDisabled = IsDisabled || IsOptionDisabled?.Invoke(option) == true;
                                <label class=@($"{LabelClass} edit-radio-label")>
                                    <InputRadio Value=@option
                                                disabled=@isOptionDisabled
                                                id=@($"rb-{_id}-{option.ToId()}")
                                                data-test-id=@($"rb-{_id}-{option.ToId()}")
                                                class=@($"edit-radio-input {CssClass}") />

                                    @option
                                </label>
                            }

                            <!-- Other -->
                            @if (HasOther)
                            {
                                <div class="edit-radio-other-option-container">

                                        <label class=@($"edit-radio-label {LabelClass}")>
                                            <InputRadio Value=@_otherName
                                                        id=@($"rb-{_id}-other")
                                                        disabled=@IsDisabled
                                                        data-test-id=@($"rb-{_id}-other")
                                                        class=@($"edit-radio-input {CssClass}") />
                                            Other
                                        </label>
                                    <input disabled="@(_selectedOption != _otherName || IsDisabled)"
                                           type="text"
                                           id=@($"txt-{_id}-custom-value")
                                           aria-label="Custom text value input"
                                           class="edit-input edit-string-input"
                                           @bind:get=@_otherText
                                           @bind:set=SetOtherText
                                           @bind:event="oninput"/>
                                </div>
                            }
                        </div>
                    }

                </InputRadioGroup>
            }
            else
            {
                <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel CssClass=@CssClass Text=@Value />
            }

            <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
            @if (FormOptions != null && FormOptions.ShowBoundValues)
            {
                <div class="bound-value">@CurrentValueAsString</div>
            }
        </fieldset>
    </div>   
}
