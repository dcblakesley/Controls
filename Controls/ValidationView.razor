@using Microsoft.AspNetCore.Components.Forms
@implements IDisposable

<section @attributes="AdditionalAttributes" class="validation-summary" aria-label="Validation errors">
    @if (FormOptions is not null)
    {
        @foreach (var v in FormOptions.FieldIdentifiers)
        {
            @foreach (var z in CurrentEditContext.GetValidationMessages(v))
            {
                <a class="validation-summary-message" href="#@AttributesHelper.GetId(null, FormGroupOptions, null, v)">@z</a>
            }
        }
    }
</section>
        

@code
{
    [CascadingParameter] public FormOptions? FormOptions { get; set; }
    [CascadingParameter] public FormGroupOptions? FormGroupOptions { get; set; }

    EditContext? _previousEditContext;
    EventHandler<ValidationStateChangedEventArgs> _validationStateChangedHandler = default!;

    /// <summary> 
    /// Gets or sets the model to produce the list of validation messages for.
    /// When specified, this lists all errors that are associated with the model instance.
    /// </summary>
    [Parameter] public object? Model { get; set; }

    /// <summary> 
    /// Gets or sets a collection of additional attributes that will be applied to the rendered <c>section</c> element.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter] EditContext CurrentEditContext { get; set; } = default!;

    protected override Task OnInitializedAsync()
    {
        _validationStateChangedHandler = (sender, eventArgs) => StateHasChanged();
        return base.OnInitializedAsync();
    }

    protected override void OnParametersSet()
    {
        if (CurrentEditContext == null)
        {
            throw new InvalidOperationException($"{nameof(ValidationView)} requires a cascading parameter " +
                                                $"of type {nameof(EditContext)}. For example, you can use {nameof(ValidationView)} inside " +
                                                $"an {nameof(EditForm)}.");
        }

        if (CurrentEditContext != _previousEditContext)
        {
            DetachValidationStateChangedListener();
            CurrentEditContext.OnValidationStateChanged += _validationStateChangedHandler;
            _previousEditContext = CurrentEditContext;
        }
    }

    public void Dispose()
    {
        DetachValidationStateChangedListener();
    }

    void DetachValidationStateChangedListener()
    {
        if (_previousEditContext != null)
        {
            _previousEditContext.OnValidationStateChanged -= _validationStateChangedHandler;
        }
    }
}
