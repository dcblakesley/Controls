<!-- Screen readers -->
<div class="edit-validation-message edit-sr-only"
     id="error-msg-@Id"
     data-test-id="error-msg-@Id"
     aria-live="polite"
     aria-atomic="true">
    @* Enumerate this field's messages directly — the empty case renders nothing, so no guard is
       needed, and the no-arg GetValidationMessages() (a whole-form scan) is avoided. A null
       EditContext (control used outside an EditForm) simply has no messages. *@
    @* One element per message — adjacent text nodes ran together ("RequiredMust be between…"). *@
    @foreach (var x in EditContext?.GetValidationMessages(FieldIdentifier) ?? [])
    {
        <div>@GetValidationMessage(x, true)</div>
    }
</div>

<!-- non-screen readers -->
<div class="edit-validation-message">
    @foreach (var x in EditContext?.GetValidationMessages(FieldIdentifier) ?? [])
    {
        <div>@GetValidationMessage(x)</div>
    }
</div>
