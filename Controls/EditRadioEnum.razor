@typeparam TEnum
@inherits EditControlBase<TEnum?>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        <fieldset class="edit-radio-fieldset"
                  id=@(ShowEditor ? _id : null)
                  data-test-id=@(ShowEditor ? _id : null)
                  role=@(ShowEditor ? "radiogroup" : null)
                  aria-labelledby=@(ShowEditor && !ShouldHideLabel ? $"lbl-{_id}" : null)
                  aria-required=@(ShowEditor ? _isRequired : null)
                  aria-invalid=@(ShowEditor && IsInvalid ? "true" : null)
                  aria-describedby=@(ShowEditor ? _describedBy : null)
                  aria-errormessage=@(ShowEditor && IsInvalid ? _errorMsgId : null)>
            <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequired Description=@Description Tooltip=@Tooltip IsLegend=true IsLabelHidden=@ShouldHideLabel />

            @if (ShowEditor)
            {
                @* ValueExpression forwarded so the inner group notifies/styles the real model field;
                   `disabled` would be a no-op here (InputRadioGroup renders no element) — each
                   InputRadio below carries it individually. *@
                <InputRadioGroup Value=@CurrentValue ValueChanged=@((TEnum? v) => CurrentValue = v) ValueExpression=@ValueExpression>

                    <div class=@(IsHorizontal
                                          ? "edit-radio-buttons-container-horizontal"
                                          : "edit-radio-buttons-container-vertical")>
                @{
                            var options = GetOptions();
                            for (var i = 0; i < options.Count; i++)
                            {
                                var option = options[i];
                                var isLastOption = i == options.Count - 1;
                                var showOtherInput = HasOtherOption && isLastOption;

                                <div class="edit-radio-option">
                                    <label class=@($"edit-radio-label {LabelClass}")>
                                        <InputRadio Value=@option
                                                    disabled=@IsDisabled
                                                    class=@($"edit-radio-input {CssClass}")
                                                    id=@($"rb-{_id}-{option.ToId()}")
                                                    data-test-id=@($"rb-{_id}-{option.ToId()}") />

                                        @option.GetName()
                                    </label>

                                    @if (showOtherInput)
                                    {
                                        <input type="text"
                                               value="@OtherValue"
                                               @oninput="@(OnOtherValueChanged)"
                                               disabled="@(!EqualityComparer<TEnum?>.Default.Equals(CurrentValue, option) || IsDisabled)"
                                               class="edit-input edit-radio-other-input"
                                               aria-label="Custom text value input"
                                               placeholder=@OtherPlaceholder
                                               id=@($"other-{_id}")
                                               data-test-id=@($"other-{_id}") />
                                    }
                                </div>
                            }
                        }
                    </div>
                </InputRadioGroup>
            }
            else
            {
                <ReadOnlyValue Id=@_id
                               IsLabelHidden=@ShouldHideLabel
                               CssClass=@CssClass
                               Text=@(IsOtherSelected ? $"{Value?.GetName()}: {OtherValue}" : Value?.GetName()) />
                }

            <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
            @if (FormOptions != null && FormOptions.ShowBoundValues)
            {
                <div class="bound-value">@CurrentValueAsString</div>
            }
        </fieldset>
    </div>
}
