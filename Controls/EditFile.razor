@inherits EditControlListBase<IBrowserFile>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequired Description=@Description Tooltip=@Tooltip IsLabelHidden=@ShouldHideLabel />

        @if (ShowEditor)
        {
            @if (MaxFiles <= 0 || Value is null || Value.Count < MaxFiles)
            {
                <div class="edit-file-drop-zone @_hoverClass @(_hasError ? "error" : "")"
                     @ondragenter="OnDragEnter"
                     @ondragleave="OnDragLeave"
                     @ondragover="OnDragEnter"
                     aria-label="File upload area">
                    <i class="edit-icon-upload@(_uploadError != null ? "-error" : "")" aria-hidden="true"></i>
                    <div class="edit-file-drop-text">
                        <div>Click or drag files to this area to upload</div>
                        @if (AllowedExtensions.Length > 0)
                        {
                            <div class="edit-file-formats">Supported formats: @string.Join(", ", AllowedExtensions)</div>
                        }
                    </div>
                    <InputFile OnChange="LoadFiles"
                               id=@_id
                               accept="@string.Join(",", AllowedExtensions)"
                               multiple
                               aria-label="Choose files"
                               aria-describedby=@_describedBy
                               aria-invalid=@(_hasError ? "true" : null)
                               aria-required=@_isRequired />
                </div>
            }

            @if (Value?.Count > 0)
            {
                <ul class="edit-file-list" aria-label="Selected files">
                    @foreach (var file in Value)
                    {
                        var f = file;
                        <li class="edit-file-item">
                            <i class="edit-icon-paperclip" aria-hidden="true"></i>
                            <span class="edit-file-name">@f.Name</span>
                            <button type="button"
                                    class="edit-file-delete-btn"
                                    title="Remove @f.Name"
                                    aria-label="Remove @f.Name"
                                    @onclick="() => RemoveFile(f)"
                                    @onclick:stopPropagation>
                                <i class="edit-icon-delete" aria-hidden="true"></i>
                            </button>
                        </li>
                    }
                </ul>
            }

            @if (_uploadError != null)
            {
                <div class="edit-validation-message" role="alert">@_uploadError</div>
            }
        }
        else
        {
            @if (Value is null || Value.Count == 0)
            {
                <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel Text="" />
            }
            else
            {
                <ul class="edit-file-list edit-file-list--readonly">
                    @foreach (var file in Value)
                    {
                        <li class="edit-file-item">
                            <i class="edit-icon-paperclip" aria-hidden="true"></i>
                            <span>@file.Name</span>
                        </li>
                    }
                </ul>
            }
        }

        <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
        @if (FormOptions != null && FormOptions.ShowBoundValues)
        {
            <div class="bound-value">@(Value?.Count == 0 ? "(none)" : string.Join(", ", (Value ?? []).Select(f => f.Name)))</div>
        }
    </div>
}
