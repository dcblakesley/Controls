@inherits EditControlListBase<IBrowserFile>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        @* IsForLabelable gates on CanAddMoreFiles too — at the MaxFiles cap the <InputFile> carrying
           _id unmounts, and a label pointing at a missing id is invalid (and clicks dead). *@
        <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequiredResolved Description=@Description Tooltip=@Tooltip IsLabelHidden=@ShouldHideLabel IsForLabelable=@(ShowEditor && CanAddMoreFiles) />

        @if (ShowEditor)
        {
            @if (CanAddMoreFiles)
            {
                <div class="edit-file-drop-zone @_hoverClass @(_hasError ? "error" : "") @(IsDisabled ? "disabled" : "") @FieldCssClass"
                     @ondragenter="OnDragEnter"
                     @ondragleave="OnDragLeave"
                     @ondragover="OnDragEnter"
                     aria-label="File upload area">
                    <i class="edit-icon-upload@(_hasError ? "-error" : "")" aria-hidden="true"></i>
                    <div class="edit-file-drop-text">
                        <div>Click or drag files to this area to upload</div>
                        @if (AllowedExtensions.Length > 0)
                        {
                            <div class="edit-file-formats">Supported formats: @string.Join(", ", AllowedExtensions)</div>
                        }
                    </div>
                    <InputFile OnChange="LoadFiles"
                               id=@_id
                               accept="@string.Join(",", NormalizedExtensions)"
                               multiple
                               disabled=@IsDisabled
                               aria-label="Choose files"
                               aria-describedby=@_describedBy
                               aria-invalid=@(_hasError ? "true" : null)
                               aria-required=@_isRequired />
                </div>
            }

            @if (Value?.Count > 0)
            {
                <ul class="edit-file-list" aria-label="Selected files">
                    @for (var i = 0; i < Value.Count; i++)
                    {
                        var f = Value[i];
                        <li class="edit-file-item">
                            <i class="edit-icon-paperclip" aria-hidden="true"></i>
                            <span class="edit-file-name">@f.Name</span>
                            <button type="button"
                                    id=@($"del-{_id}-{i}")
                                    class="edit-file-delete-btn"
                                    title="Remove @f.Name"
                                    aria-label="Remove @f.Name"
                                    disabled=@IsDisabled
                                    @onclick="() => RemoveFile(f)"
                                    @onclick:stopPropagation>
                                <i class="edit-icon-delete" aria-hidden="true"></i>
                            </button>
                        </li>
                    }
                </ul>
            }

            @if (_uploadErrors.Count > 0)
            {
                @* One element per rejected file — several rejections used to overwrite each other,
                   leaving only the last visible. *@
                <div class="edit-validation-message" role="alert">
                    @foreach (var error in _uploadErrors)
                    {
                        <div>@error</div>
                    }
                </div>
            }
        }
        else
        {
            @if (Value is null || Value.Count == 0)
            {
                <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel CssClass=@FieldCssClass Text="" />
            }
            else
            {
                @* aria-labelledby ties the read-only list back to the field label ("lbl-{_id}" also
                   exists when the label is visually hidden — FormLabel renders an sr-only label);
                   the edit-mode list above names itself the same way via aria-label. *@
                <ul class="edit-file-list edit-file-list--readonly @FieldCssClass"
                    id=@_id
                    data-test-id=@_id
                    aria-labelledby=@(ShouldHideLabel ? null : $"lbl-{_id}")
                    aria-label=@(ShouldHideLabel ? "Selected files" : null)>
                    @foreach (var file in Value)
                    {
                        <li class="edit-file-item">
                            <i class="edit-icon-paperclip" aria-hidden="true"></i>
                            <span>@file.Name</span>
                        </li>
                    }
                </ul>
            }
        }

        <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
        @if (FormOptions != null && FormOptions.ShowBoundValues)
        {
            <div class="bound-value">@(Value?.Count == 0 ? "(none)" : string.Join(", ", (Value ?? []).Select(f => f.Name)))</div>
        }
    </div>
}
