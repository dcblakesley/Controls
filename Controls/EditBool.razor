@inherits EditControlBase<bool>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">

        @if (ShowEditor || RenderAsCheckboxWhenReadOnly)
        {
            @* Editable (or opt-in legacy read-only) — render the checkbox *@
            @if (!ShouldHideLabel)
            {
                <label class="edit-checkbox-label" for=@_id>
                    @CheckboxFragment
                    @DisplayLabel()
                    <LabelTooltip Id=@_id Tooltip=@Tooltip Attributes=@_attributes/>
                </label>
                @if (DisplayDescription() != null)
                {
                    <p class="edit-label-description" id="desc-@_id">
                        @DisplayDescription()
                    </p>
                }
            }
            else
            {
                @* A hidden label still needs an accessible name — associate a visually-hidden label
                   with the checkbox (mirrors FormLabel's IsLabelHidden path) instead of shipping an
                   unnamed control that a screen reader announces as just "checkbox". *@
                <label class="edit-sr-only" for=@_id>@DisplayLabel()</label>
                @CheckboxFragment
            }
        }
        else
        {
            @* Read-only — use the same FormLabel + ReadOnlyValue pattern as the other controls *@
            <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequiredResolved Description=@Description Tooltip=@Tooltip IsLabelHidden=@ShouldHideLabel IsForLabelable="false" />
            <ReadOnlyValue Id=@_id IsLabelHidden=@ShouldHideLabel CssClass=@CssClass Text=@(CurrentValue ? TrueText : FalseText) />
        }

        <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
        @if (FormOptions != null && FormOptions.ShowBoundValues)
        {
            <div class="bound-value">@CurrentValueAsString</div>
        }
    </div>
}

@code {
    RenderFragment CheckboxFragment => @<input type="checkbox"
                                                value="@CurrentValue"
                                                @onchange="HandleCheckboxChange"
                                                @onclick:preventDefault="(!ShowEditor || IsDisabled) && AllowFocusWhenDisabled"
                                                class="edit-input @CssClass"
                                                id=@_id
                                                data-test-id=@_id
                                                checked=@CurrentValue
                                                tabindex="0"
                                                aria-disabled=@((!ShowEditor || IsDisabled) ? "true" : null)
                                                disabled=@((!ShowEditor || IsDisabled) && !AllowFocusWhenDisabled)
                                                aria-required=@_isRequired
                                                aria-invalid=@(IsInvalid ? "true" : null)
                                                aria-describedby=@_describedBy
                                                aria-errormessage=@(IsInvalid ? _errorMsgId : null) />;
}
