@namespace Controls
@typeparam TValue

@* Backdrop: closes the dropdown on any outside click without needing JS interop.
   tabindex="-1" (here and on the wrapper below): iOS-class WebKit only synthesizes a click from a
   tap when the target chain contains a focusable/interactive element — a plain div/span gets touch
   and pointer events but never the click that drives @onclick. -1 keeps both out of the Tab order. *@
@if (_open)
{
    <div class="wss-select-backdrop" tabindex="-1" @onclick="CloseAsync"></div>
}

<div class="@WrapperClass" style="@WidthStyle" tabindex="-1" @ref="_wrapperRef" @onclick="OnWrapperClickAsync" @onclick:stopPropagation>

    <div class="wss-select-selector">

        @if (Mode == SelectMode.Single)
        {
            <span class="wss-select-selection-search">
                <input @ref="_inputRef"
                       class="wss-select-selection-search-input"
                       id="@Id"
                       data-test-id="@Id"
                       type="search"
                       autocomplete="off"
                       role="combobox"
                       aria-haspopup="listbox"
                       aria-autocomplete="list"
                       aria-expanded=@(_open ? "true" : "false")
                       aria-controls="@(_open ? $"{BaseId}-listbox" : null)"
                       aria-activedescendant="@(_open && ActiveOption != null ? $"{BaseId}-active" : null)"
                       aria-required="@AriaRequired"
                       aria-invalid="@(AriaInvalid ? "true" : null)"
                       aria-describedby="@AriaDescribedBy"
                       readonly="@(!ShowSearch)"
                       disabled="@Disabled"
                       value="@_searchText"
                       @oninput="OnInputAsync"
                       @onkeydown="OnKeyDownAsync"
                       @onkeydown:stopPropagation="@_open" />
            </span>

            @if (_showPlaceholder)
            {
                <span class="wss-select-selection-placeholder">@Placeholder</span>
            }
            else if (!(_open && !string.IsNullOrEmpty(_searchText)))
            {
                <span class="wss-select-selection-item" title="@SelectedLabel">@SelectedLabel</span>
            }
        }
        else
        {
            @* Multiple / Tags: render each selected value as a removable tag. *@
            @foreach (var (option, index) in VisibleTags())
            {
                <span class="wss-select-selection-item">
                    <span class="wss-select-selection-item-content">@option.Label</span>
                    @* No remove button when disabled — RemoveAsync no-ops anyway, so rendering it
                       leaves a focusable, active-looking control that does nothing (the clear
                       button is already suppressed the same way via ShowClear). *@
                    @if (!Disabled)
                    {
                        <button type="button"
                                class="wss-select-selection-item-remove"
                                aria-label="@(string.Format(CultureInfo.CurrentCulture, RemoveItemLabelFormat, option.Label))"
                                @onclick="@(e => RemoveAsync(option.Value))"
                                @onclick:stopPropagation>
                            @CloseCross
                        </button>
                    }
                </span>
            }

            @if (_hiddenTagCount > 0)
            {
                <span class="wss-select-selection-item wss-select-selection-item-rest">
                    <span class="wss-select-selection-item-content">+ @_hiddenTagCount ...</span>
                </span>
            }

            <span class="wss-select-selection-search">
                <input @ref="_inputRef"
                       class="wss-select-selection-search-input"
                       id="@Id"
                       data-test-id="@Id"
                       type="search"
                       autocomplete="off"
                       role="combobox"
                       aria-haspopup="listbox"
                       aria-autocomplete="list"
                       aria-expanded=@(_open ? "true" : "false")
                       aria-controls="@(_open ? $"{BaseId}-listbox" : null)"
                       aria-activedescendant="@(_open && ActiveOption != null ? $"{BaseId}-active" : null)"
                       aria-required="@AriaRequired"
                       aria-invalid="@(AriaInvalid ? "true" : null)"
                       aria-describedby="@AriaDescribedBy"
                       readonly="@(!ShowSearch)"
                       disabled="@Disabled"
                       value="@_searchText"
                       @oninput="OnInputAsync"
                       @onkeydown="OnKeyDownAsync"
                       @onkeydown:stopPropagation="@_open" />
            </span>

            @if (_showPlaceholder)
            {
                <span class="wss-select-selection-placeholder">@Placeholder</span>
            }
        }
    </div>

    @* Clear button (only when there is a value and the pointer is over the control). *@
    @if (ShowClear)
    {
        <button type="button" class="wss-select-clear"
                aria-label="@(IsMultiple ? ClearSelectionsLabel : ClearSelectionLabel)"
                @onclick="ClearAsync" @onclick:stopPropagation>@CloseCross</button>
    }

    <span class="wss-select-arrow">@ArrowDown</span>

    @if (_open)
    {
        @* tabindex=-1: Chromium puts scrollable containers in the tab order by default, which made
           Tab land on the raw listbox. Per the ARIA combobox pattern the popup is driven from the
           input (arrow keys / type-ahead), never tabbed into. *@
        <div class="wss-select-dropdown @(_dropdownPositioned ? null : "wss-measuring")" tabindex="-1" @ref="_dropdownRef" role="listbox" aria-label="@ListboxLabel" aria-multiselectable="@(IsMultiple ? "true" : null)" id="@($"{BaseId}-listbox")">
            @if (_filtered.Count == 0)
            {
                <div class="wss-select-item-empty">@EmptyText</div>
            }
            else
            {
                @* Virtualized: only the rows in view are added to the DOM, so the
                   dropdown stays fast even with tens of thousands of options. *@
                <Virtualize Items="_filtered" Context="option" ItemSize="RowHeight" OverscanCount="4">
                    <div class="@OptionClass(option)"
                         @key="option"
                         role="option"
                         id="@(ReferenceEquals(option, ActiveOption) ? $"{BaseId}-active" : null)"
                         aria-selected="@(IsSelected(option.Value) ? "true" : "false")"
                         aria-disabled="@(option.Disabled ? "true" : null)"
                         @onclick="@(e => SelectAsync(option))"
                         @onclick:stopPropagation>
                        <span class="wss-select-item-option-content">@option.Label</span>
                        @if (IsSelected(option.Value))
                        {
                            <span class="wss-select-item-option-state">@CheckMark</span>
                        }
                    </div>
                </Virtualize>
            }
        </div>
    }
</div>

@code {
    // Localizable accessibility strings. Defaults match the previously hardcoded English, so
    // existing consumers/tests see identical markup. (This component's other members live in
    // Select.razor.cs; these sit here beside the markup that renders them.)

    /// <summary>
    /// <see cref="string.Format(IFormatProvider, string, object)"/> template for a tag's remove
    /// button accessible name; <c>{0}</c> is the option label. Override to localize (formatted
    /// with <see cref="CultureInfo.CurrentCulture"/>).
    /// </summary>
    [Parameter] public string RemoveItemLabelFormat { get; set; } = "Remove {0}";

    /// <summary>Accessible name of the clear button in single mode. Override to localize.</summary>
    [Parameter] public string ClearSelectionLabel { get; set; } = "Clear selection";

    /// <summary>Accessible name of the clear button in multiple/tags modes. Override to localize.</summary>
    [Parameter] public string ClearSelectionsLabel { get; set; } = "Clear all selections";

    /// <summary>Accessible name of the dropdown listbox. Override to localize.</summary>
    [Parameter] public string ListboxLabel { get; set; } = "Options";
}
