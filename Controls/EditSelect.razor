@typeparam TValue
@inherits EditControlBase<TValue>

@if (ShouldShowComponent())
{
    <div class="edit-control-wrapper @ContainerClass">
        <FormLabel Id=@_id FieldIdentifier=@_fieldIdentifier Attributes=@_attributes Label=@Label IsRequired=@IsRequired Description=@Description Tooltip=@Tooltip IsLabelHidden=@ShouldHideLabel />

        @if (ShowEditor)
        {
            <select @bind=@CurrentValueAsString
                    class=@($"edit-input edit-select-select {CssClass}")
                    disabled=@IsDisabled
                    id=@_id
                    data-test-id=@_id
                    aria-required=@_isRequired
                    aria-invalid=@(CssClass.Contains("invalid") ? "true" : null)
                    aria-describedby=@($"error-msg-{_id} desc-{_id} tooltip-{_id}")
                    aria-errormessage=@($"error-msg-{_id}")>

                @ChildContent
            </select>
        }
        else
        {
            <ReadOnlyValue Id=@_id IsRequired=@_isRequired CssClass=@CssClass Text=@CurrentValueAsString />
        }

        <FieldValidationDisplay Id=@_id FieldIdentifier=_fieldIdentifier Attributes=_attributes Label=@Label />
        @if (FormOptions != null && FormOptions.ShowBoundValues)
        {
            <div class="bound-value">@CurrentValueAsString</div>
        }
    </div>
}
