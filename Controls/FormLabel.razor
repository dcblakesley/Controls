@if (!IsLabelHidden)
{
    @if (IsLegend)
    {
        <!-- Wrap only the 'label' within the legend -->
		<legend class="edit-label-legend">
			@if ((_isRequired || IsRequired) && !(FormOptions?.IsRequiredStarHidden ?? FormOptions.DefaultIsRequiredStarHidden))
			{
				<span class="edit-label-required-star" aria-hidden="true">*</span>
			}
			@DisplayLabel()

            <LabelTooltip Id=@Id Tooltip=@Tooltip Attributes=@Attributes/>
        </legend>

        @if (DisplayDescription() != null)
        {
            <p class="edit-label-description" id="desc-@Id">
                @DisplayDescription()
            </p>
        }
    }
    else
    {
        <!-- Typical Label -->
		<label class="edit-label" for=@Id id="lbl-@Id">
			@if ((_isRequired || IsRequired) && !(FormOptions?.IsRequiredStarHidden ?? FormOptions.DefaultIsRequiredStarHidden))
			{
				<span class="edit-label-required-star" aria-hidden="true">*</span>
			}
            @DisplayLabel()

            <LabelTooltip Id=@Id Tooltip=@Tooltip Attributes=@Attributes />
        </label>

        @if (DisplayDescription() != null)
        {
            <p class="edit-label-description" id="desc-@Id">
                @DisplayDescription()
            </p>
        }
    }
}