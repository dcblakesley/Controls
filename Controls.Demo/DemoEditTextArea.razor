@using Microsoft.AspNetCore.Components.Forms

<h1>EditTextArea Demo</h1>

<EditForm Model="@_model" class="flex-row flex-wrap" @ref=_form >
    <ObjectGraphDataAnnotationsValidator/>
    
    <section class="demo-section">
        <EditTextArea @bind-Value="_model.BasicTextArea" />

        <EditTextArea @bind-Value="_model.BasicTextArea"
                      IsEditMode=false/>
        
        <h3>Markup</h3>
        <pre class="code-block"><code>@_basicExample</code></pre>
    </section>

    <section class="demo-section">
        <EditTextArea @bind-Value="_model.LargerTextArea"
                      Rows="5"/>
        
        <h3>Markup</h3>
        <pre class="code-block"><code>@_rowsExample</code></pre>
    </section>

    <section class="demo-section">
        <EditTextArea @bind-Value="_model.WithPlaceholder"
                      Placeholder="Enter your detailed comments here..."
                      Rows="4"/>
        
        <h3>Markup</h3>
        <pre class="code-block"><code>@_placeholderExample</code></pre>
    </section>

    <section class="demo-section">
        <EditTextArea @bind-Value="_model.MultilinePlaceholder"
                      Placeholder="Describe your experience, thoughts, or feedback. Feel free to be as detailed as you'd like."
                      Rows="3"/>
        
        <h3>Markup</h3>
        <pre class="code-block"><code>@_multilinePlaceholderExample</code></pre>
    </section>

    <section class="demo-section">
        <style>
            .my-custom-container { background-color:cyan; padding: 10px; border-radius: 40px; }
            .my-custom-textarea { background-color: magenta; border: 2px solid #0066cc; border-radius: 40px; padding: 8px; width: 100%; min-height: 100px; font-family: 'Courier New', monospace; }
        </style>

        <EditTextArea @bind-Value="_model.CustomStyling"
                      ContainerClass="my-custom-container"
                      class="my-custom-textarea"/>
        
        <h3>Markup</h3>
        <pre class="code-block"><code>@_customStyleExample</code></pre>
        
        <h3>CSS</h3>
        <pre class="code-block code-block-css"><code>@_customStyleCss</code></pre>
    </section>

    <section class="demo-section">
        <EditTextArea @bind-Value="_model.Disabled"
                      IsDisabled="true"/>

        <EditTextArea @bind-Value="_model.Required"/>

        <h3>Markup</h3>
        <pre class="code-block"><code>@_validationExample</code></pre>

        <h3>Model</h3>
        <pre class="code-block code-block-model"><code>@_validationModel</code></pre>
    </section>

    <section class="demo-section">
        <h3>AllowClear</h3>

        <EditTextArea @bind-Value="_model.Clearable" AllowClear="true"/>

        <h3>Markup</h3>
        <pre class="code-block"><code>@_allowClearExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>MaxLength + ShowCount</h3>

        <EditTextArea @bind-Value="_model.Counted" MaxLength="200" ShowCount="true"/>

        <h3>Markup</h3>
        <pre class="code-block"><code>@_maxLengthExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>AutoSize</h3>

        <EditTextArea @bind-Value="_model.AutoSized" AutoSize="true" MinRows="2" MaxRows="6"
                      Placeholder="Type several lines -- the box grows until it hits 6 rows, then scrolls."/>

        <h3>Markup</h3>
        <pre class="code-block"><code>@_autoSizeExample</code></pre>
    </section>
</EditForm>

@code {
    readonly DemoEditTextAreaModel _model = new();

    EditForm? _form;
    protected override void OnAfterRender(bool firstRender) => _form?.EditContext!.Validate();

    public class DemoEditTextAreaModel
    {
        [Description("Basic Description")]
        public string BasicTextArea { get; set; } = "";
        public string LargerTextArea { get; set; } = "Rows isn't being respected in the test project right now.";
        
        [Description("Example with placeholder text")]
        public string WithPlaceholder { get; set; } = "";
        
        [Description("Another placeholder example")]
        public string MultilinePlaceholder { get; set; } = "";
        
        public string CustomStyling { get; set; } = "I have custom styling";

        [Required] public string Required { get; set; } = "";

        public string Disabled { get; set; } = "This textarea is disabled";

        public string Clearable { get; set; } = "Clear me";
        public string Counted { get; set; } = "";
        public string AutoSized { get; set; } = "";
    }

    readonly string _basicExample = @"<EditTextArea @bind-Value=""_model.BasicTextArea"" />

<EditTextArea @bind-Value=""_model.BasicTextArea""
             IsEditMode=false/>";

    readonly string _rowsExample = @"<EditTextArea @bind-Value=""_model.LargerTextArea""
             Rows=""5""/>";

    readonly string _placeholderExample = @"<EditTextArea @bind-Value=""_model.WithPlaceholder""
             Placeholder=""Enter your detailed comments here...""
             Rows=""4""/>";

    readonly string _multilinePlaceholderExample = @"<EditTextArea @bind-Value=""_model.MultilinePlaceholder""
             Placeholder=""Describe your experience, thoughts, or feedback...""
             Rows=""3""/>";

    readonly string _customStyleExample = @"<EditTextArea @bind-Value=""_model.CustomStyling""
             ContainerClass=""my-custom-container""
             class=""my-custom-textarea""/>";

    readonly string _customStyleCss = @".my-custom-container { 
    background-color:cyan; 
    padding: 10px; 
    border-radius: 40px; 
}

.my-custom-textarea {
    background-color: magenta;
    border: 2px solid #0066cc;
    border-radius: 40px;
    padding: 8px;
    width: 100%;
    min-height: 100px;
    font-family: 'Courier New', monospace;
}";

    readonly string _validationExample = @"<EditTextArea @bind-Value=""_model.Disabled""
             IsDisabled=""true""/>

<EditTextArea @bind-Value=""_model.Required""/>";

    readonly string _validationModel = @"[Required]
public string Required { get; set; } = """";

public string Disabled { get; set; } = ""This textarea is disabled"";";

    readonly string _allowClearExample = @"<EditTextArea @bind-Value=""_model.Clearable""
             AllowClear=""true""/>";

    readonly string _maxLengthExample = @"<EditTextArea @bind-Value=""_model.Counted""
             MaxLength=""200""
             ShowCount=""true""/>";

    readonly string _autoSizeExample = @"<EditTextArea @bind-Value=""_model.AutoSized""
             AutoSize=""true""
             MinRows=""2""
             MaxRows=""6""
             Placeholder=""Type several lines...""/>";
}
