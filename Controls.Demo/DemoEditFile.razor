<h1>EditFile Demo</h1>

<EditForm Model="@_model" class="flex-column" @ref=_form>
    <ObjectGraphDataAnnotationsValidator />

    <section class="demo-section">
        <h3>Basic — all file types</h3>
        <EditFile @bind-Value="_model.BasicFiles" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_basicExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>Extension filter + max files</h3>
        <EditFile @bind-Value="_model.FilteredFiles"
                  AllowedExtensions="@([".pdf", ".xlsx"])"
                  MaxFiles="3" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_filterExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>Required validation</h3>
        <EditFile @bind-Value="_model.RequiredFiles" />

        <h3>Model</h3>
        <pre class="code-block code-block-model"><code>@_validationModel</code></pre>
    </section>

    <section class="demo-section">
        <h3>Accept: MIME wildcard (images only)</h3>
        <EditFile @bind-Value="_model.MimeFiles"
                  AllowedExtensions="@(["image/*"])" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_mimeExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>BeforeAdd hook</h3>
        <EditFile @bind-Value="_model.GatedFiles" BeforeAdd="RejectBlockedFiles" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_beforeAddExample</code></pre>
    </section>

    <section class="demo-section">
        <h3>Compact button (Variant="Button")</h3>
        <EditFile @bind-Value="_model.ButtonFiles" Variant="EditFileVariant.Button" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_buttonExample</code></pre>
    </section>

    <button type="submit">Submit</button>
</EditForm>

@code {
    readonly DemoEditFileModel _model = new();
    EditForm? _form;
    protected override void OnAfterRender(bool firstRender) => _form?.EditContext!.Validate();

    readonly string _basicExample = @"<EditFile @bind-Value=""_model.Files"" />";

    readonly string _filterExample = @"<EditFile @bind-Value=""_model.Files""
          AllowedExtensions=""@([&quot;.pdf&quot;, &quot;.xlsx&quot;])""
          MaxFiles=""3"" />";

    readonly string _validationModel =
        @"[Required]
[MinLength(1, ErrorMessage = ""At least one file is required."")]
public List<IBrowserFile> RequiredFiles { get; set; } = [];";

    readonly string _mimeExample = @"<EditFile @bind-Value=""_model.Files""
          AllowedExtensions=""@([&quot;image/*&quot;])"" />";

    readonly string _beforeAddExample = @"<EditFile @bind-Value=""_model.Files""
          BeforeAdd=""RejectBlockedFiles"" />

@code {
    Task<bool> RejectBlockedFiles(IBrowserFile file) =>
        Task.FromResult(!file.Name.Contains(""blocked""));
}";

    readonly string _buttonExample = @"<EditFile @bind-Value=""_model.Files""
          Variant=""EditFileVariant.Button"" />";

    // Demo-only stand-in for a real gate (server-side dedupe check, content sniffing): rejects any
    // file whose name contains "blocked", so renaming a file to include that word before picking it
    // demonstrates the rejection message without needing a backend.
    Task<bool> RejectBlockedFiles(IBrowserFile file) =>
        Task.FromResult(!file.Name.Contains("blocked"));

    public class DemoEditFileModel
    {
        public List<IBrowserFile> BasicFiles { get; set; } = [];
        public List<IBrowserFile> FilteredFiles { get; set; } = [];
        public List<IBrowserFile> MimeFiles { get; set; } = [];
        public List<IBrowserFile> GatedFiles { get; set; } = [];
        public List<IBrowserFile> ButtonFiles { get; set; } = [];

        [Required]
        [MinLength(1, ErrorMessage = "At least one file is required.")]
        public List<IBrowserFile> RequiredFiles { get; set; } = [];
    }
}
