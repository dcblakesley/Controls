@using Microsoft.AspNetCore.Components.Forms

<h1>EditSelectSearch Demo</h1>
<p>Searchable single-select (AntDesign-style) backed by the <code>Select</code> engine. Supports type-to-search, clear, keyboard navigation and a virtualized dropdown for large option sets.</p>

<EditForm Model="@_model" class="flex-row flex-wrap" @ref="_form" OnSubmit="@(() => _submitCount++)">
    <ObjectGraphDataAnnotationsValidator />

    <section class="demo-section">
        <h3>Basic (edit + read-only)</h3>
        <EditSelectSearch @bind-Value="_model.Country"
                          Options="_countries"
                          Placeholder="Search for a country..."
                          Width="260px" />

        <EditSelectSearch @bind-Value="_model.Country"
                          Options="_countries"
                          IsEditMode="false"
                          Width="260px" />
    </section>

    <section class="demo-section">
        <h3>Large option set (virtualized)</h3>
        <p>1,000 options — search filters and only visible rows hit the DOM.</p>
        <EditSelectSearch @bind-Value="_model.BigChoice"
                          Options="_bigOptions"
                          Width="260px" />
    </section>

    <section class="demo-section">
        <h3>Disabled &amp; required validation</h3>
        <EditSelectSearch @bind-Value="_model.DisabledCountry"
                          Options="_countries"
                          IsDisabled="true"
                          Width="260px" />

        <EditSelectSearch @bind-Value="_model.RequiredCountry"
                          Options="_countries"
                          Width="260px" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_example</code></pre>
    </section>

    <section class="demo-section">
        <h3>Pill variant + Prefix icon</h3>
        <p><code>Variant="SelectVariant.Pill"</code> restyles the trigger as a rounded filter button; <code>Prefix</code> renders leading content (typically an icon) inside the trigger in any variant.</p>
        <EditSelectSearch @bind-Value="_model.PillCountry"
                          Options="_countries"
                          Variant="SelectVariant.Pill"
                          Placeholder="Country"
                          Width="220px">
            <Prefix>
                <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
            </Prefix>
        </EditSelectSearch>
    </section>

    <section class="demo-section">
        <h3>Inside a submitting form</h3>
        <p>Enter picks the highlighted option without triggering the form's implicit submission.</p>
        <EditSelectSearch @bind-Value="_model.FormCountry"
                          Options="_countries"
                          Width="260px" />
        <button type="submit">Submit</button>
        <div class="submit-count">Submits: @_submitCount</div>
    </section>

    <section class="demo-section">
        <h3>Loading &amp; ShowArrow</h3>
        <p><code>Loading</code> shows a spinner in the arrow's slot (and marks the control <code>aria-busy</code>) even when <code>ShowArrow="false"</code>; otherwise <code>ShowArrow="false"</code> simply hides the chevron.</p>
        <EditSelectSearch @bind-Value="_model.LoadingCountry" Options="_countries" Loading="true" Width="220px" />
        <EditSelectSearch @bind-Value="_model.NoArrowCountry" Options="_countries" ShowArrow="false" Width="220px" />
    </section>

    <section class="demo-section">
        <h3>Option groups</h3>
        <p><code>SelectOption.Group</code> renders a non-interactive header before each contiguous run of a shared group name (Ant Design's <code>OptGroup</code>).</p>
        <EditSelectSearch @bind-Value="_model.GroupedCountry" Options="_groupedCountries" Width="260px" />
    </section>

    <section class="demo-section">
        <h3>Custom FilterOption</h3>
        <p>Matches the option's value (its ISO code) as well as its label — try typing "us" or "United".</p>
        <EditSelectSearch @bind-Value="_model.FilterCountry"
                          Options="_countries"
                          FilterOption="@((text, o) => (o.Label ?? "").Contains(text, StringComparison.OrdinalIgnoreCase) || (o.Value ?? "").Contains(text, StringComparison.OrdinalIgnoreCase))"
                          Width="260px" />
    </section>

    <section class="demo-section">
        <h3>EmptyContent &amp; DropdownFooter</h3>
        <p>Type a filter that matches nothing to see the richer <code>EmptyContent</code>; <code>DropdownFooter</code> renders a pinned affordance whose clicks don't select an option or close the dropdown.</p>
        <EditSelectSearch @bind-Value="_model.FooterCountry" Options="_countries" Width="260px">
            <EmptyContent><em>No matching country — try another search.</em></EmptyContent>
            <DropdownFooter>
                <button type="button" class="demo-dropdown-footer-btn" @onclick="() => _footerClicks++">+ Request a country</button>
            </DropdownFooter>
        </EditSelectSearch>
        <div class="footer-click-count">Footer clicks: @_footerClicks</div>
    </section>

    <section class="demo-section">
        <h3>Borderless variant</h3>
        <p><code>Variant="SelectVariant.Borderless"</code> shows no border/background until hover or focus.</p>
        <EditSelectSearch @bind-Value="_model.BorderlessCountry" Options="_countries" Variant="SelectVariant.Borderless" Width="220px" />
    </section>

    <section class="demo-section">
        <h3>Controlled Open</h3>
        <p><code>@@bind-Open</code> two-way binds the dropdown's open state — external code can open/close it and JS placement still runs.</p>
        <button type="button" @onclick="() => _controlledOpen = !_controlledOpen">@(_controlledOpen ? "Close" : "Open") externally</button>
        <EditSelectSearch @bind-Value="_model.ControlledCountry" Options="_countries" @bind-Open="_controlledOpen" Width="260px" />
        <div class="controlled-open-state">Open: @_controlledOpen</div>
    </section>

    <section class="demo-section">
        <h3>JS horizontal clamp</h3>
        <p>A narrow trigger with long option labels makes the dropdown wider than the trigger; positioned near the right edge of the viewport, it shifts to stay on-screen instead of running off it.</p>
        <EditSelectSearch @bind-Value="_model.ClampChoice" Options="_wideOptions" Width="90px" />
    </section>
</EditForm>

@code {
    readonly Model _model = new();
    EditForm? _form;
    int _submitCount;
    int _footerClicks;
    bool _controlledOpen;
    protected override void OnAfterRender(bool firstRender) => _form?.EditContext!.Validate();

    readonly List<SelectOption<string?>> _countries =
    [
        new("us", "United States"),
        new("ca", "Canada"),
        new("mx", "Mexico"),
        new("gb", "United Kingdom"),
        new("fr", "France"),
        new("de", "Germany"),
        new("jp", "Japan"),
        new("au", "Australia"),
        new("br", "Brazil"),
        new("in", "India")
    ];

    readonly List<SelectOption<int>> _bigOptions =
        Enumerable.Range(1, 1000).Select(i => new SelectOption<int>(i, $"Option {i}")).ToList();

    readonly List<SelectOption<string?>> _groupedCountries =
    [
        new("us", "United States") { Group = "North America" },
        new("ca", "Canada") { Group = "North America" },
        new("mx", "Mexico") { Group = "North America" },
        new("gb", "United Kingdom") { Group = "Europe" },
        new("fr", "France") { Group = "Europe" },
        new("de", "Germany") { Group = "Europe" },
        new("jp", "Japan") { Group = "Asia" },
        new("in", "India") { Group = "Asia" },
        new("au", "Australia") { Group = "Oceania" },
    ];

    readonly List<SelectOption<int>> _wideOptions =
    [
        new(1, "A very long option label that makes the dropdown much wider than its narrow trigger"),
        new(2, "Another lengthy option label to keep the dropdown's natural width wide"),
    ];

    public class Model
    {
        [Description("Pick your country")]
        public string? Country { get; set; } = "ca";

        public int BigChoice { get; set; }

        public string? DisabledCountry { get; set; } = "gb";

        [Required(ErrorMessage = "Please select a country")]
        public string? RequiredCountry { get; set; }

        public string? FormCountry { get; set; }

        public string? PillCountry { get; set; } = "us";

        public string? LoadingCountry { get; set; } = "us";

        public string? NoArrowCountry { get; set; } = "ca";

        public string? GroupedCountry { get; set; }

        public string? FilterCountry { get; set; }

        public string? FooterCountry { get; set; }

        public string? BorderlessCountry { get; set; } = "fr";

        public string? ControlledCountry { get; set; }

        public int ClampChoice { get; set; }
    }

    readonly string _example = @"<EditSelectSearch @bind-Value=""_model.Country""
                  Options=""_countries""
                  Placeholder=""Search for a country..."" />";
}
