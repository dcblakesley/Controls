@using Microsoft.AspNetCore.Components.Forms

<h1>EditMultiSelect Demo</h1>
<p>Multiple / tags select (AntDesign-style) backed by the <code>Select</code> engine. Binds to a <code>List&lt;T&gt;</code>; <code>Tags</code> mode lets users add values not in the option list.</p>

<EditForm Model="@_model" class="flex-row flex-wrap" @ref="_form">
    <ObjectGraphDataAnnotationsValidator />

    <section class="demo-section">
        <h3>Multiple (edit + read-only)</h3>
        <EditMultiSelect @bind-Value="_model.Colors"
                         Options="_colors"
                         Placeholder="Pick colors..."
                         Width="320px" />

        <EditMultiSelect @bind-Value="_model.Colors"
                         Options="_colors"
                         IsEditMode="false"
                         Width="320px" />
    </section>

    <section class="demo-section">
        <h3>Tags (free text) with MaxTagCount</h3>
        <EditMultiSelect @bind-Value="_model.Keywords"
                         Options="_keywordSuggestions"
                         Mode="SelectMode.Tags"
                         MaxTagCount="3"
                         Placeholder="Type and press Enter..."
                         Width="320px" />
    </section>

    <section class="demo-section">
        <h3>Prefix icon</h3>
        <p><code>Prefix</code> renders leading content (typically an icon) inside the trigger.</p>
        <EditMultiSelect @bind-Value="_model.PrefixColors"
                         Options="_colors"
                         Placeholder="Pick colors..."
                         Width="320px">
            <Prefix>
                <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="13.5" cy="6.5" r="2.5"></circle>
                    <circle cx="19" cy="13" r="2.5"></circle>
                    <circle cx="6" cy="12" r="2.5"></circle>
                    <circle cx="10" cy="20" r="2.5"></circle>
                </svg>
            </Prefix>
        </EditMultiSelect>
    </section>

    <section class="demo-section">
        <h3>Required (min 2) validation</h3>
        <EditMultiSelect @bind-Value="_model.RequiredColors"
                         Options="_colors"
                         Width="320px" />

        <h3>Markup</h3>
        <pre class="code-block"><code>@_example</code></pre>
    </section>
</EditForm>

@code {
    readonly Model _model = new();
    EditForm? _form;
    protected override void OnAfterRender(bool firstRender) => _form?.EditContext!.Validate();

    readonly List<SelectOption<string>> _colors =
    [
        new("red", "Red"),
        new("green", "Green"),
        new("blue", "Blue"),
        new("yellow", "Yellow"),
        new("purple", "Purple"),
        new("orange", "Orange")
    ];

    readonly List<SelectOption<string>> _keywordSuggestions =
    [
        new("blazor", "blazor"),
        new("dotnet", "dotnet"),
        new("csharp", "csharp")
    ];

    public class Model
    {
        public List<string> Colors { get; set; } = ["green"];

        public List<string> Keywords { get; set; } = [];

        public List<string> PrefixColors { get; set; } = ["blue"];

        [Required(ErrorMessage = "Pick at least two colors")]
        [MinLength(2, ErrorMessage = "Pick at least two colors")]
        public List<string> RequiredColors { get; set; } = [];
    }

    readonly string _example = @"<EditMultiSelect @bind-Value=""_model.Colors""
                 Options=""_colors""
                 Placeholder=""Pick colors..."" />";
}
