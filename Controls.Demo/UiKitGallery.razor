@using Microsoft.AspNetCore.Components.Web

<h1>UI Kit Gallery</h1>
<p>Dependency-free AntDesign-style controls ported into WssBlazorControls. These are general UI
   widgets (not form Edit* controls). Icon / Button / Checkbox / Tag are intentionally not included.</p>

<div class="gallery">

    <section class="demo-section">
        <h3>Alert</h3>
        <Alert Type="AlertType.Success" Message="Success — saved." />
        <Alert Type="AlertType.Info" Message="Info — heads up." />
        <Alert Type="AlertType.Warning" Message="Warning — check this." />
        <Alert Type="AlertType.Error" Message="Error — something failed." Closable="true" />
        <Alert Type="AlertType.Info" Message="With description" Description="A longer explanation under the message." />
    </section>

    <section class="demo-section">
        <h3>Skeleton</h3>
        <Skeleton Loading="_skeletonLoading" Rows="3">
            <p>Loaded content goes here.</p>
        </Skeleton>
        <button class="wss-dialog-btn" @onclick="@(() => _skeletonLoading = !_skeletonLoading)">
            Toggle loading (@(_skeletonLoading ? "on" : "off"))
        </button>
    </section>

    <section class="demo-section">
        <h3>Popover</h3>
        <Popover Title="Popover title">
            <ChildContent>
                <button class="wss-dialog-btn">Click me</button>
            </ChildContent>
            <Content>
                <div>Some popover content.</div>
            </Content>
        </Popover>
    </section>

    <section class="demo-section">
        <h3>Pagination</h3>
        <Pagination Total="95" PageSize="10" Current="_page" CurrentChanged="@(p => _page = p)" />
        <p>Current page: @_page</p>
    </section>

    <section class="demo-section">
        <h3>Modal &amp; Drawer</h3>
        <div style="display:flex; gap:1rem;">
            <button class="wss-dialog-btn wss-dialog-btn-primary" @onclick="@(() => _modalVisible = true)">Open Modal</button>
            <button class="wss-dialog-btn" @onclick="@(() => _drawerVisible = true)">Open Drawer</button>
        </div>

        <Modal @bind-Visible="_modalVisible" Title="A modal" OnOk="@(() => _modalVisible = false)">
            <p>Modal body content. Click OK or Cancel.</p>
        </Modal>

        <Drawer @bind-Visible="_drawerVisible" Title="A drawer" Placement="DrawerPlacement.Right">
            <p>Drawer body content.</p>
        </Drawer>
    </section>

    <section class="demo-section">
        <h3>Popconfirm</h3>
        <Popconfirm Title="Delete this item?" OnConfirm="@(() => _confirmResult = "confirmed")" OnCancel="@(() => _confirmResult = "cancelled")">
            <button class="wss-dialog-btn">Delete</button>
        </Popconfirm>
        <p>Last action: @_confirmResult</p>
    </section>

    <section class="demo-section">
        <h3>Table (selectable, sortable, paged, styled checkboxes)</h3>
        <p style="margin:0; color:#666;">
            Antd-style custom-drawn checkboxes for header/row selection (<code>UseStyledCheckbox</code>),
            including the indeterminate "mixed" glyph when only some rows on the page are selected
            (preselected below). Settable per-<code>Table</code> or globally via a cascaded
            <code>FormDefaults</code> (or the process-wide <code>FormOptions.DefaultUseStyledCheckbox</code>
            static).
        </p>
        <Table TItem="Row" DataSource="_rows" Selectable="true" UseStyledCheckbox="true" PageSize="5" PagerAlign="PagerAlign.Center"
               SelectedItems="_selectedRows" SelectedItemsChanged="@(s => _selectedRows = s.ToList())">
            <PropertyColumn TItem="Row" TProp="int" Title="Id" Property="@(r => r.Id)" Sortable="true" />
            <PropertyColumn TItem="Row" TProp="string" Title="Name" Property="@(r => r.Name)" Sortable="true" />
            <PropertyColumn TItem="Row" TProp="decimal" Title="Price" Property="@(r => r.Price)" Format="C2" Sortable="true" />
            <ActionColumn TItem="Row" Title="Action">
                <button class="wss-dialog-btn wss-dialog-btn-sm">Edit</button>
            </ActionColumn>
        </Table>
        <p>Selected: @_selectedRows.Count</p>
    </section>

    <section class="demo-section">
        <h3>Table — expandable rows + header info tooltip</h3>
        <p style="margin:0; color:#666;">
            <code>RowDetail</code> adds a leading chevron column; clicking it reveals the template
            as a full-width row (here a nested selectable child <code>Table</code>, the Vendor PO
            pattern). <code>Column.TitleContent</code> replaces the plain title — here composing a
            <code>LabelTooltip</code> info icon into the header.
        </p>
        <Table TItem="PoRow" DataSource="_poRows" RowKey="@(r => r.Number)">
            <ChildContent>
                <PropertyColumn TItem="PoRow" TProp="string" Title="PO #" Property="@(r => r.Number)" />
                <Column TItem="PoRow" Title="ESD">
                    <TitleContent>
                        ESD <LabelTooltip Id="esd-info" Tooltip="Estimated ship date for the full PO." />
                    </TitleContent>
                    <ChildContent Context="r">@(r.Esd?.ToString("MM/dd/yyyy") ?? "--")</ChildContent>
                </Column>
                <PropertyColumn TItem="PoRow" TProp="string" Title="Tracking Number" Property="@(r => r.Tracking)" />
            </ChildContent>
            <RowDetail Context="r">
                <Table TItem="SkuRow" DataSource="r.Skus" Selectable="true" UseStyledCheckbox="true">
                    <PropertyColumn TItem="SkuRow" TProp="string" Title="SKU" Property="@(s => s.Sku)" />
                    <PropertyColumn TItem="SkuRow" TProp="string" Title="Description" Property="@(s => s.Description)" />
                    <PropertyColumn TItem="SkuRow" TProp="int" Title="Quantity" Property="@(s => s.Quantity)" />
                </Table>
            </RowDetail>
        </Table>
    </section>

    <section class="demo-section">
        <h3>Table — server-side paging (compose pattern)</h3>
        <p style="margin:0; color:#666;">
            The Table renders only the current page (no built-in <code>PageSize</code>); a standalone
            <code>Pagination</code> you drive fetches each page. The 150&nbsp;ms delay below stands in
            for a server round-trip.
        </p>
        <Table TItem="Row" DataSource="_serverRows">
            <PropertyColumn TItem="Row" TProp="int" Title="Id" Property="@(r => r.Id)" />
            <PropertyColumn TItem="Row" TProp="string" Title="Name" Property="@(r => r.Name)" />
            <PropertyColumn TItem="Row" TProp="decimal" Title="Price" Property="@(r => r.Price)" Format="C2" />
        </Table>
        <div style="display:flex; justify-content:flex-end;">
            <Pagination Total="_serverTotal" PageSize="ServerPageSize" Current="_serverPage" CurrentChanged="LoadServerPageAsync" />
        </div>
        <p>Server has @_serverTotal rows; showing page @_serverPage.</p>
    </section>

    <section class="demo-section">
        <h3>Toasts (WASM only)</h3>
        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <button class="wss-dialog-btn" @onclick="@(() => WasmMessageService.Success("Saved!"))">Message</button>
            <button class="wss-dialog-btn" @onclick="@(() => WasmNotificationService.Info("Notification", "With a description."))">Notification</button>
        </div>
    </section>

    <section class="demo-section">
        <h3>Tabs + SearchInput (filter strip)</h3>
        <p style="margin:0; color:#666;">
            The Vendor PO Management subheader pattern: labeled pill search fields
            (<code>SearchInput</code> — Enter or the button raises <code>OnSearch</code>) above an
            underline <code>Tabs</code> strip whose tabs carry bordered count chips. These tabs are
            a bare filter strip (no pane content); give a <code>Tab</code> child content to render
            the active pane below the strip.
        </p>
        <div style="display:flex; gap:16px; flex-wrap:wrap; align-items:center;">
            <SearchInput @bind-Value="_poSearch" AddonLabel="POs" OnSearch="@(v => _lastSearch = $"POs: {v}")"
                         Id="demo-search-pos" Width="240px" />
            <SearchInput @bind-Value="_skuSearch" AddonLabel="SKUs" OnSearch="@(v => _lastSearch = $"SKUs: {v}")"
                         Id="demo-search-skus" Width="240px" Loading="@_skuSearchLoading" />
            <button class="wss-dialog-btn" type="button" data-test-id="toggle-sku-search-loading"
                    @onclick="@(() => _skuSearchLoading = !_skuSearchLoading)">
                Toggle SKU search Loading
            </button>
        </div>
        <Tabs @bind-ActiveKey="_activeTab" Id="demo-tabs" TablistLabel="Shipment filters">
            <Tab Key="overdue" Title="Overdue" Count="12" />
            <Tab Key="missing" Title="Missing Estimations" Count="12" />
            <Tab Key="other" Title="Other Active" Count="5" />
        </Tabs>
        <p data-test-id="tabs-result">Active: @_activeTab · Last search: @_lastSearch</p>
    </section>

    <section class="demo-section">
        <h3>Select — pill filter variant</h3>
        <p style="margin:0; color:#666;">
            <code>Variant="SelectVariant.Pill"</code> turns the Select trigger into a rounded
            filter button; <code>Prefix</code> supplies the leading icon. The section is themed via
            a scoped <code>--wss-select-pill-color</code> / <code>--wss-color-bg-selected</code>
            override — one knob recolors border, label, chevron, and focus ring.
        </p>
        <div class="pill-filters" style="display:flex; gap:12px; flex-wrap:wrap;">
            <Select TValue="string" @bind-Value="_shipmentFilter" Options="_shipmentOptions"
                    Variant="SelectVariant.Pill" ShowSearch="false" AllowClear="false"
                    Id="demo-pill-select">
                <Prefix>
                    <svg width="1.25em" height="1.25em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                </Prefix>
            </Select>
            <Select TValue="string" @bind-Value="_productFilter" Options="_productOptions"
                    Variant="SelectVariant.Pill" ShowSearch="false" AllowClear="false"
                    Placeholder="Products" Id="demo-pill-select-2">
                <Prefix>
                    <svg width="1.25em" height="1.25em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                </Prefix>
            </Select>
        </div>
        <p data-test-id="pill-result">Shipments filter: @_shipmentFilter</p>
    </section>

    <section class="demo-section">
        <h3>DateRangePicker</h3>
        <p style="margin:0; color:#666;">
            Composite start → end field opening a preset sidebar + dual-month calendar with
            month/year quick-select headers. Presets are page-supplied (nothing is built in) and
            resolve at click time. The initial value is pinned to Jan/Feb 2025 so the e2e visual
            baseline is deterministic; <code>FirstDayOfWeek</code> is pinned for the same reason.
        </p>
        <DateRangePicker @bind-Start="_rangeStart" @bind-End="_rangeEnd"
                         Presets="_rangePresets"
                         Min="@(new DateTime(2017, 1, 1))"
                         FirstDayOfWeek="DayOfWeek.Sunday"
                         Id="demo-range"
                         Width="300px" />
        <p data-test-id="range-result">
            Selected: @(_rangeStart?.ToString("yyyy-MM-dd") ?? "—") → @(_rangeEnd?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Mode</code> swaps what both linked panels select together -- the bound
            <code>Start</code>/<code>End</code> stay <code>DateTime?</code> in every mode.
            <code>Month</code> shows two consecutive years, each a 3x4 month grid; two clicks (one
            per endpoint) commit their first-of-month starts. Initial values are pinned for the same
            baseline-determinism reason as the single-date sibling's own Mode demos.
        </p>
        <DateRangePicker @bind-Start="_rangeMonthStart" @bind-End="_rangeMonthEnd"
                         Mode="DatePickerMode.Month"
                         Id="demo-range-month"
                         Width="280px" />
        <p data-test-id="range-month-result">
            Selected: @(_rangeMonthStart?.ToString("yyyy-MM") ?? "—") → @(_rangeMonthEnd?.ToString("yyyy-MM") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Year</code> shows two consecutive decades, each a 3x4 year grid (10 of the decade
            plus 2 dimmed adjacent-decade years).
        </p>
        <DateRangePicker @bind-Start="_rangeYearStart" @bind-End="_rangeYearEnd"
                         Mode="DatePickerMode.Year"
                         Id="demo-range-year"
                         Width="220px" />
        <p data-test-id="range-year-result">
            Selected: @(_rangeYearStart?.Year.ToString() ?? "—") → @(_rangeYearEnd?.Year.ToString() ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Week</code> renders the same dual one-month calendars as <code>Date</code> plus a
            leading week-number column in both -- always shown regardless of
            <code>ShowWeekNumbers</code>. The ROW, not the day, is the selection unit: clicking any
            day commits its week's start. <code>FirstDayOfWeek</code> is pinned for the same
            baseline-determinism reason as the single-date sibling's own Week demo.
        </p>
        <DateRangePicker @bind-Start="_rangeWeekStart" @bind-End="_rangeWeekEnd"
                         Mode="DatePickerMode.Week"
                         FirstDayOfWeek="DayOfWeek.Sunday"
                         Id="demo-range-week"
                         Width="280px" />
        <p data-test-id="range-week-result">
            Selected: @(_rangeWeekStart?.ToString("yyyy-MM-dd") ?? "—") → @(_rangeWeekEnd?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Quarter</code> shows two consecutive years, each a single row of 4 quarter buttons.
        </p>
        <DateRangePicker @bind-Start="_rangeQuarterStart" @bind-End="_rangeQuarterEnd"
                         Mode="DatePickerMode.Quarter"
                         Id="demo-range-quarter"
                         Width="240px" />
        <p data-test-id="range-quarter-result">
            Selected: @(_rangeQuarterStart?.ToString("yyyy-MM-dd") ?? "—") → @(_rangeQuarterEnd?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>DateTime</code>/<code>Time</code> abandon the dual-panel layout for a SINGLE panel
            per-endpoint pick session ending in an OK button: picking the active endpoint's day/time
            and clicking OK either advances to the other endpoint (the active underline moves,
            nothing is committed yet) or -- once both sides are resolved -- commits both and closes.
            <code>Use12Hours="false"</code> and seconds on for this one; both endpoints start empty
            (<code>DefaultViewDate</code> pins the panel's initial month) so the advance step is
            actually observable.
        </p>
        <DateRangePicker @bind-Start="_rangeDateTimeStart" @bind-End="_rangeDateTimeEnd"
                         Mode="DatePickerMode.DateTime"
                         Use12Hours="false"
                         ShowSeconds="true"
                         DefaultViewDate="@(new DateTime(2026, 2, 10))"
                         Id="demo-range-datetime"
                         Width="260px" />
        <p data-test-id="range-datetime-result">
            Selected: @(_rangeDateTimeStart?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—") → @(_rangeDateTimeEnd?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Time</code> drops the calendar entirely -- just the time row and OK, per endpoint.
            <code>Use12Hours</code> + <code>MinuteStep="15"</code> + <code>ShowSeconds="false"</code>
            together here.
        </p>
        <DateRangePicker @bind-Start="_rangeTimeStart" @bind-End="_rangeTimeEnd"
                         Mode="DatePickerMode.Time"
                         Use12Hours="true"
                         MinuteStep="15"
                         ShowSeconds="false"
                         Id="demo-range-time"
                         Width="220px" />
        <p data-test-id="range-time-result">
            Selected: @(_rangeTimeStart?.ToString("HH:mm") ?? "—") → @(_rangeTimeEnd?.ToString("HH:mm") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>DisabledDate</code> (weekends, here) rejects a cell/commit alongside
            <code>Min</code>/<code>Max</code>; <code>ExtraFooter</code> renders its own strip below
            the calendar in every mode (AntD's <code>renderExtraFooter</code>).
        </p>
        <DateRangePicker @bind-Start="_rangeDisabledStart" @bind-End="_rangeDisabledEnd"
                         DisabledDate="IsWeekend"
                         Id="demo-range-disabled"
                         Width="300px">
            <ExtraFooter>
                <span data-test-id="range-disabled-extra-footer">Weekdays only — weekends are disabled.</span>
            </ExtraFooter>
        </DateRangePicker>
        <p data-test-id="range-disabled-result">
            Selected: @(_rangeDisabledStart?.ToString("yyyy-MM-dd") ?? "—") → @(_rangeDisabledEnd?.ToString("yyyy-MM-dd") ?? "—")
        </p>
    </section>

    <section class="demo-section">
        <h3>DatePicker (single date)</h3>
        <p style="margin:0; color:#666;">
            The single-date sibling of the range picker: one field with a calendar suffix, one
            month panel with month/year quick-select headers. Picking a day (or typing a date and
            pressing Enter) commits and closes. The initial value is pinned to Feb 2026 so the e2e
            visual baseline is deterministic; <code>FirstDayOfWeek</code> is pinned for the same reason.
        </p>
        <DatePicker @bind-Value="_singleDate"
                    Min="@(new DateTime(2017, 1, 1))"
                    FirstDayOfWeek="DayOfWeek.Sunday"
                    Id="demo-date"
                    Width="300px" />
        <p data-test-id="date-result">
            Selected: @(_singleDate?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Mode</code> swaps what the panel offers — the bound <code>Value</code> stays
            <code>DateTime?</code> in every mode. <code>Month</code> replaces the day calendar with a
            year header + 3x4 month grid; <code>Time</code> drops the calendar for hour/minute/second
            selects over an OK button; <code>DateTime</code> keeps the day calendar and appends that
            same time row below it. Initial values are pinned for the same baseline-determinism reason.
        </p>
        <DatePicker @bind-Value="_monthValue"
                    Mode="DatePickerMode.Month"
                    Id="demo-month"
                    Width="200px" />
        <p data-test-id="month-result">
            Selected: @(_monthValue?.ToString("yyyy-MM") ?? "—")
        </p>

        <DatePicker @bind-Value="_timeValue"
                    Mode="DatePickerMode.Time"
                    Id="demo-time"
                    Width="200px" />
        <p data-test-id="time-result">
            Selected: @(_timeValue?.ToString("HH:mm:ss") ?? "—")
        </p>

        <DatePicker @bind-Value="_dateTimeValue"
                    Mode="DatePickerMode.DateTime"
                    Id="demo-datetime"
                    Width="260px" />
        <p data-test-id="datetime-result">
            Selected: @(_dateTimeValue?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Year</code>/<code>Quarter</code>/<code>Week</code> round out <code>Mode</code>'s
            remaining granularities — initial values stay in the Feb 2026 family for the same
            baseline-determinism reason as the demos above.
        </p>
        <DatePicker @bind-Value="_yearValue"
                    Mode="DatePickerMode.Year"
                    Id="demo-year"
                    Width="160px" />
        <p data-test-id="year-result">
            Selected: @(_yearValue?.Year.ToString() ?? "—")
        </p>

        <DatePicker @bind-Value="_quarterValue"
                    Mode="DatePickerMode.Quarter"
                    Id="demo-quarter"
                    Width="200px" />
        <p data-test-id="quarter-result">
            Selected: @(_quarterValue?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <DatePicker @bind-Value="_weekValue"
                    Mode="DatePickerMode.Week"
                    FirstDayOfWeek="DayOfWeek.Sunday"
                    Id="demo-week"
                    Width="220px" />
        <p data-test-id="week-result">
            Selected: @(_weekValue?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Presets</code> adds a shortcut sidebar (resolved at click time, same contract as
            <code>DateRangePicker.Presets</code> above) and <code>ShowToday</code> adds a footer
            link — both commit a value and close the panel.
        </p>
        <DatePicker @bind-Value="_presetsValue"
                    Presets="_datePresets"
                    ShowToday="true"
                    Id="demo-presets"
                    Width="300px" />
        <p data-test-id="presets-result">
            Selected: @(_presetsValue?.ToString("yyyy-MM-dd") ?? "—")
        </p>

        <p style="margin:0; color:#666;">
            <code>Use12Hours</code> + <code>MinuteStep</code> + <code>ShowSeconds="false"</code>
            together on a <code>Time</code> mode picker.
        </p>
        <DatePicker @bind-Value="_twelveHourValue"
                    Mode="DatePickerMode.Time"
                    Use12Hours="true"
                    MinuteStep="15"
                    ShowSeconds="false"
                    Id="demo-12h"
                    Width="200px" />
        <p data-test-id="twelve-hour-result">
            Selected: @(_twelveHourValue?.ToString("HH:mm") ?? "—")
        </p>
    </section>

    <section class="demo-section">
        <h3>Popover — swapped trigger child</h3>
        <p style="margin:0; color:#666;">
            The trigger child is re-created across renders (a common busy/idle swap). The popup ARIA
            must follow the live child, and a disabled Popconfirm's button child must be marked inert.
        </p>
        <button class="wss-dialog-btn" data-test-id="swap-toggle" @onclick="@(() => _triggerBusy = !_triggerBusy)">
            Toggle trigger (@(_triggerBusy ? "loading" : "ready"))
        </button>
        <Popover Title="Swapped trigger">
            <ChildContent>
                @if (_triggerBusy)
                {
                    <span data-test-id="swap-trigger-child">Loading…</span>
                }
                else
                {
                    <button type="button" class="wss-dialog-btn" data-test-id="swap-trigger-child">Open popover</button>
                }
            </ChildContent>
            <Content>
                <div data-test-id="swap-popover-content">Swapped-trigger popover content.</div>
            </Content>
        </Popover>

        <Popconfirm Title="Delete this item?" Disabled="true">
            <button type="button" class="wss-dialog-btn" data-test-id="disabled-popconfirm-child">Delete (disabled)</button>
        </Popconfirm>
    </section>

    <section class="demo-section">
        <h3>Hover Tooltip (<code>data-tooltip</code>)</h3>
        <p style="margin:0; color:#666;">
            Not a component — a <code>data-tooltip="..."</code> attribute on any element, styled by
            plain CSS rules in <code>wss-controls.css</code>. The optional <code>wss-tooltip.js</code>
            (linked in this demo's <code>App.razor</code>) auto-places the bubble based on the
            trigger's position in its container; an explicit placement class (like the second button
            below) opts out of auto-placement.
        </p>
        <div style="display:flex; gap:2rem; flex-wrap:wrap; padding: 2rem 0;">
            <button class="wss-dialog-btn" data-tooltip="Auto-placed — flips/shifts based on position" data-test-id="tooltip-auto">
                Hover me (auto)
            </button>
            <button class="wss-dialog-btn wss-tooltip-top" data-tooltip="Forced above via wss-tooltip-top" data-test-id="tooltip-forced-top">
                Hover me (forced top)
            </button>
        </div>
    </section>
</div>

@* WASM-only static-state toast hosts. *@
<WasmMessageContainer />
<WasmNotificationContainer />

<style>
    .gallery { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
    .gallery .demo-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1rem;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
    .gallery .demo-section > h3 { margin: 0; }
    /* Pill-select demo theme (the Clark Connect filter look): one scoped token recolors the whole
       trigger; the selected-row tint follows the same palette. */
    .gallery .pill-filters {
        --wss-select-pill-color: #1c4a3f;
        --wss-color-bg-selected: #d9e8e2;
    }
</style>

@code {
    bool _skeletonLoading = true;
    int _page = 1;
    bool _modalVisible;
    bool _drawerVisible;
    string _confirmResult = "(none)";
    // Swapped-trigger demo: flips the Popover's ChildContent between a non-focusable <span> and a
    // <button>, exercising syncTrigger's re-resolution / reversible-promotion / focusin repair.
    bool _triggerBusy;

    // --- Expandable-table demo (the Vendor PO Management pattern) ---
    record SkuRow(string Sku, string Description, int Quantity);
    record PoRow(string Number, DateTime? Esd, string Tracking, List<SkuRow> Skus);

    static readonly List<PoRow> _poRows =
    [
        new("8999000", null, "--",
        [
            new("150005", "Stainless lid to reduce boil-overs", 1),
            new("150006", "Heat-resistant, non-slip handle", 6),
        ]),
