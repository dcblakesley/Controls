@using Microsoft.AspNetCore.Components.Web

<h1>UI Kit Gallery</h1>
<p>Dependency-free AntDesign-style controls ported into WssBlazorControls. These are general UI
   widgets (not form Edit* controls). Icon / Button / Checkbox / Tag are intentionally not included.</p>

<div class="gallery">

    <section class="demo-section">
        <h3>Alert</h3>
        <Alert Type="AlertType.Success" Message="Success — saved." />
        <Alert Type="AlertType.Info" Message="Info — heads up." />
        <Alert Type="AlertType.Warning" Message="Warning — check this." />
        <Alert Type="AlertType.Error" Message="Error — something failed." Closable="true" />
        <Alert Type="AlertType.Info" Message="With description" Description="A longer explanation under the message." />
    </section>

    <section class="demo-section">
        <h3>Skeleton</h3>
        <Skeleton Loading="_skeletonLoading" Rows="3">
            <p>Loaded content goes here.</p>
        </Skeleton>
        <button class="wss-dialog-btn" @onclick="@(() => _skeletonLoading = !_skeletonLoading)">
            Toggle loading (@(_skeletonLoading ? "on" : "off"))
        </button>
    </section>

    <section class="demo-section">
        <h3>Popover</h3>
        <Popover Title="Popover title">
            <ChildContent>
                <button class="wss-dialog-btn">Click me</button>
            </ChildContent>
            <Content>
                <div>Some popover content.</div>
            </Content>
        </Popover>
    </section>

    <section class="demo-section">
        <h3>Pagination</h3>
        <Pagination Total="95" PageSize="10" Current="_page" CurrentChanged="@(p => _page = p)" />
        <p>Current page: @_page</p>
    </section>

    <section class="demo-section">
        <h3>Modal &amp; Drawer</h3>
        <div style="display:flex; gap:1rem;">
            <button class="wss-dialog-btn wss-dialog-btn-primary" @onclick="@(() => _modalVisible = true)">Open Modal</button>
            <button class="wss-dialog-btn" @onclick="@(() => _drawerVisible = true)">Open Drawer</button>
        </div>

        <Modal @bind-Visible="_modalVisible" Title="A modal" OnOk="@(() => _modalVisible = false)">
            <p>Modal body content. Click OK or Cancel.</p>
        </Modal>

        <Drawer @bind-Visible="_drawerVisible" Title="A drawer" Placement="DrawerPlacement.Right">
            <p>Drawer body content.</p>
        </Drawer>
    </section>

    <section class="demo-section">
        <h3>Popconfirm</h3>
        <Popconfirm Title="Delete this item?" OnConfirm="@(() => _confirmResult = "confirmed")" OnCancel="@(() => _confirmResult = "cancelled")">
            <button class="wss-dialog-btn">Delete</button>
        </Popconfirm>
        <p>Last action: @_confirmResult</p>
    </section>

    <section class="demo-section">
        <h3>Table (selectable, sortable, paged, styled checkboxes)</h3>
        <p style="margin:0; color:#666;">
            Antd-style custom-drawn checkboxes for header/row selection (<code>UseStyledCheckbox</code>),
            including the indeterminate "mixed" glyph when only some rows on the page are selected
            (preselected below). Settable per-<code>Table</code> or globally via a cascaded
            <code>FormDefaults</code> (or the process-wide <code>FormOptions.DefaultUseStyledCheckbox</code>
            static).
        </p>
        <Table TItem="Row" DataSource="_rows" Selectable="true" UseStyledCheckbox="true" PageSize="5" PagerAlign="PagerAlign.Center"
               SelectedItems="_selectedRows" SelectedItemsChanged="@(s => _selectedRows = s.ToList())">
            <PropertyColumn TItem="Row" TProp="int" Title="Id" Property="@(r => r.Id)" Sortable="true" />
            <PropertyColumn TItem="Row" TProp="string" Title="Name" Property="@(r => r.Name)" Sortable="true" />
            <PropertyColumn TItem="Row" TProp="decimal" Title="Price" Property="@(r => r.Price)" Format="C2" Sortable="true" />
            <ActionColumn TItem="Row" Title="Action">
                <button class="wss-dialog-btn wss-dialog-btn-sm">Edit</button>
            </ActionColumn>
        </Table>
        <p>Selected: @_selectedRows.Count</p>
    </section>

    <section class="demo-section">
        <h3>Table — server-side paging (compose pattern)</h3>
        <p style="margin:0; color:#666;">
            The Table renders only the current page (no built-in <code>PageSize</code>); a standalone
            <code>Pagination</code> you drive fetches each page. The 150&nbsp;ms delay below stands in
            for a server round-trip.
        </p>
        <Table TItem="Row" DataSource="_serverRows">
            <PropertyColumn TItem="Row" TProp="int" Title="Id" Property="@(r => r.Id)" />
            <PropertyColumn TItem="Row" TProp="string" Title="Name" Property="@(r => r.Name)" />
            <PropertyColumn TItem="Row" TProp="decimal" Title="Price" Property="@(r => r.Price)" Format="C2" />
        </Table>
        <div style="display:flex; justify-content:flex-end;">
            <Pagination Total="_serverTotal" PageSize="ServerPageSize" Current="_serverPage" CurrentChanged="LoadServerPageAsync" />
        </div>
        <p>Server has @_serverTotal rows; showing page @_serverPage.</p>
    </section>

    <section class="demo-section">
        <h3>Toasts (WASM only)</h3>
        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <button class="wss-dialog-btn" @onclick="@(() => WasmMessageService.Success("Saved!"))">Message</button>
            <button class="wss-dialog-btn" @onclick="@(() => WasmNotificationService.Info("Notification", "With a description."))">Notification</button>
        </div>
    </section>

    <section class="demo-section">
        <h3>Select — pill filter variant</h3>
        <p style="margin:0; color:#666;">
            <code>Variant="SelectVariant.Pill"</code> turns the Select trigger into a rounded
            filter button; <code>Prefix</code> supplies the leading icon. The section is themed via
            a scoped <code>--wss-select-pill-color</code> / <code>--wss-color-bg-selected</code>
            override — one knob recolors border, label, chevron, and focus ring.
        </p>
        <div class="pill-filters" style="display:flex; gap:12px; flex-wrap:wrap;">
            <Select TValue="string" @bind-Value="_shipmentFilter" Options="_shipmentOptions"
                    Variant="SelectVariant.Pill" ShowSearch="false" AllowClear="false"
                    Id="demo-pill-select">
                <Prefix>
                    <svg width="1.25em" height="1.25em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                </Prefix>
            </Select>
            <Select TValue="string" @bind-Value="_productFilter" Options="_productOptions"
                    Variant="SelectVariant.Pill" ShowSearch="false" AllowClear="false"
                    Placeholder="Products" Id="demo-pill-select-2">
                <Prefix>
                    <svg width="1.25em" height="1.25em" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                </Prefix>
            </Select>
        </div>
        <p data-test-id="pill-result">Shipments filter: @_shipmentFilter</p>
    </section>

    <section class="demo-section">
        <h3>DateRangePicker</h3>
        <p style="margin:0; color:#666;">
            Composite start → end field opening a preset sidebar + dual-month calendar with
            month/year quick-select headers. Presets are page-supplied (nothing is built in) and
            resolve at click time. The initial value is pinned to Jan/Feb 2025 so the e2e visual
            baseline is deterministic; <code>FirstDayOfWeek</code> is pinned for the same reason.
        </p>
        <DateRangePicker @bind-Start="_rangeStart" @bind-End="_rangeEnd"
                         Presets="_rangePresets"
                         Min="@(new DateTime(2017, 1, 1))"
                         FirstDayOfWeek="DayOfWeek.Sunday"
                         Id="demo-range"
                         Width="300px" />
        <p data-test-id="range-result">
            Selected: @(_rangeStart?.ToString("yyyy-MM-dd") ?? "—") → @(_rangeEnd?.ToString("yyyy-MM-dd") ?? "—")
        </p>
    </section>

    <section class="demo-section">
        <h3>DatePicker (single date)</h3>
        <p style="margin:0; color:#666;">
            The single-date sibling of the range picker: one field with a calendar suffix, one
            month panel with month/year quick-select headers. Picking a day (or typing a date and
            pressing Enter) commits and closes. The initial value is pinned to Feb 2026 so the e2e
            visual baseline is deterministic; <code>FirstDayOfWeek</code> is pinned for the same reason.
        </p>
        <DatePicker @bind-Value="_singleDate"
                    Min="@(new DateTime(2017, 1, 1))"
                    FirstDayOfWeek="DayOfWeek.Sunday"
                    Id="demo-date"
                    Width="300px" />
        <p data-test-id="date-result">
            Selected: @(_singleDate?.ToString("yyyy-MM-dd") ?? "—")
        </p>
    </section>

    <section class="demo-section">
        <h3>Popover — swapped trigger child</h3>
        <p style="margin:0; color:#666;">
            The trigger child is re-created across renders (a common busy/idle swap). The popup ARIA
            must follow the live child, and a disabled Popconfirm's button child must be marked inert.
        </p>
        <button class="wss-dialog-btn" data-test-id="swap-toggle" @onclick="@(() => _triggerBusy = !_triggerBusy)">
            Toggle trigger (@(_triggerBusy ? "loading" : "ready"))
        </button>
        <Popover Title="Swapped trigger">
            <ChildContent>
                @if (_triggerBusy)
                {
                    <span data-test-id="swap-trigger-child">Loading…</span>
                }
                else
                {
                    <button type="button" class="wss-dialog-btn" data-test-id="swap-trigger-child">Open popover</button>
                }
            </ChildContent>
            <Content>
                <div data-test-id="swap-popover-content">Swapped-trigger popover content.</div>
            </Content>
        </Popover>

        <Popconfirm Title="Delete this item?" Disabled="true">
            <button type="button" class="wss-dialog-btn" data-test-id="disabled-popconfirm-child">Delete (disabled)</button>
        </Popconfirm>
    </section>
</div>

@* WASM-only static-state toast hosts. *@
<WasmMessageContainer />
<WasmNotificationContainer />

<style>
    .gallery { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
    .gallery .demo-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1rem;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
    .gallery .demo-section > h3 { margin: 0; }
    /* Pill-select demo theme (the Clark Connect filter look): one scoped token recolors the whole
       trigger; the selected-row tint follows the same palette. */
    .gallery .pill-filters {
        --wss-select-pill-color: #1c4a3f;
        --wss-color-bg-selected: #d9e8e2;
    }
</style>

@code {
    bool _skeletonLoading = true;
    int _page = 1;
    bool _modalVisible;
    bool _drawerVisible;
    string _confirmResult = "(none)";
    // Swapped-trigger demo: flips the Popover's ChildContent between a non-focusable <span> and a
    // <button>, exercising syncTrigger's re-resolution / reversible-promotion / focusin repair.
    bool _triggerBusy;

    // --- Pill-select demo ---
    string _shipmentFilter = "all";
    string? _productFilter;

    static readonly List<SelectOption<string>> _shipmentOptions =
    [
        new("all", "All shipments"),
        new("drop", "Drop shipments"),
        new("warehouse", "Warehouse shipments"),
    ];

    static readonly List<SelectOption<string>> _productOptions =
    [
        new("all", "All products"),
        new("in-stock", "In stock"),
        new("special-order", "Special order"),
    ];

    // --- DateRangePicker demo ---
    // Pinned initial range: the e2e visual baseline screenshots the open panel, so the displayed
    // months must not depend on the test run's date.
    DateTime? _rangeStart = new DateTime(2025, 1, 15);
    DateTime? _rangeEnd = new DateTime(2025, 2, 3);

    // --- DatePicker demo --- (pinned for the same baseline-determinism reason)
    DateTime? _singleDate = new DateTime(2026, 2, 14);

    // The Sales-Report-style shortcuts. Resolved at click time (DateTime.Today), so they stay
    // correct however long the page lives.
    static readonly DateRangePreset[] _rangePresets =
    [
        new("This Week", static () =>
        {
            var today = DateTime.Today;
            return (today.AddDays(-(((int)today.DayOfWeek - (int)DayOfWeek.Sunday + 7) % 7)), today);
        }),
        new("This Month", static () =>
        {
            var today = DateTime.Today;
            return (new DateTime(today.Year, today.Month, 1), today);
        }),
        new("Last Month", static () =>
        {
            var first = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-1);
            return (first, first.AddMonths(1).AddDays(-1));
        }),
        new("This Quarter", static () =>
        {
            var today = DateTime.Today;
            return (new DateTime(today.Year, (today.Month - 1) / 3 * 3 + 1, 1), today);
        }),
        new("Last Quarter", static () =>
        {
            var today = DateTime.Today;
            var first = new DateTime(today.Year, (today.Month - 1) / 3 * 3 + 1, 1).AddMonths(-3);
            return (first, first.AddMonths(3).AddDays(-1));
        }),
        new("This Year", static () =>
        {
            var today = DateTime.Today;
            return (new DateTime(today.Year, 1, 1), today);
        }),
        new("Last Year", static () =>
        {
            var year = DateTime.Today.Year - 1;
            return (new DateTime(year, 1, 1), new DateTime(year, 12, 31));
        }),
    ];

    readonly List<Row> _rows = Enumerable.Range(1, 13)
        .Select(i => new Row(i, $"Item {i}", i * 4.5m))
        .ToList();

    // Preselected (below, in OnInitializedAsync) so the styled-checkbox Table demo starts in the
    // indeterminate ("mixed") state — a field initializer can't reference the _rows field above.
    List<Row> _selectedRows = new();

    // --- Server-side paging demo (compose pattern) ---
    // Stand-in for a server-side table; a real app would query a DB/API in LoadServerPageAsync.
    const int ServerPageSize = 10;
    readonly List<Row> _serverBackingStore = Enumerable.Range(1, 47)
        .Select(i => new Row(i, $"Row {i}", i * 2.5m))
        .ToList();

    List<Row> _serverRows = new();
    int _serverTotal;
    int _serverPage = 1;

    protected override Task OnInitializedAsync()
    {
        _selectedRows.Add(_rows[0]);
        return LoadServerPageAsync(1);
    }

    // Mimics a paged endpoint: returns just the requested page plus the overall row count.
    async Task LoadServerPageAsync(int page)
    {
        _serverPage = page;
        await Task.Delay(150); // simulate a server round-trip
        _serverRows = _serverBackingStore
            .Skip((page - 1) * ServerPageSize)
            .Take(ServerPageSize)
            .ToList(); // a new reference so the Table re-copies its DataSource
        _serverTotal = _serverBackingStore.Count;
    }

    public record Row(int Id, string Name, decimal Price);
}
