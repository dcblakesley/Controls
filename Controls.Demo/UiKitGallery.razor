    List<Row> _selectedRows = new();

    // --- Server-side paging demo (compose pattern) ---
    // Stand-in for a server-side table; a real app would query a DB/API in LoadServerPageAsync.
    const int ServerPageSize = 10;
    readonly List<Row> _serverBackingStore = Enumerable.Range(1, 47)
        .Select(i => new Row(i, $"Row {i}", i * 2.5m))
        .ToList();

    List<Row> _serverRows = new();
    int _serverTotal;
    int _serverPage = 1;

    protected override Task OnInitializedAsync()
    {
        _selectedRows.Add(_rows[0]);
        return LoadServerPageAsync(1);
    }

    // Mimics a paged endpoint: returns just the requested page plus the overall row count.
    async Task LoadServerPageAsync(int page)
    {
        _serverPage = page;
        await Task.Delay(150); // simulate a server round-trip
        _serverRows = _serverBackingStore
            .Skip((page - 1) * ServerPageSize)
            .Take(ServerPageSize)
            .ToList(); // a new reference so the Table re-copies its DataSource
        _serverTotal = _serverBackingStore.Count;
    }

    public record Row(int Id, string Name, decimal Price);
